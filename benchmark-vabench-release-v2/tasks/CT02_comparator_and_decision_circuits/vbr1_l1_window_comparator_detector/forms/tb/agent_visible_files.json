{
  "schema_version": "vabench-release-v2",
  "task_id": "vbr1_l1_window_comparator_detector:tb",
  "agent_prompt": "agent_prompt.md",
  "agent_visible_spec": "public/agent_visible_spec.md",
  "agent_visible": {
    "prompt": "agent_prompt.md",
    "support_files": [
      {
        "alias": "window_comparator_ref.va",
        "source_path": "public/support/window_comparator_ref.va",
        "render": true,
        "writable_by_agent": false
      }
    ],
    "target_files": [
      "tb_window_comparator_ref.scs"
    ],
    "spec": "public/agent_visible_spec.md"
  },
  "agent_hidden": [
    {
      "path": "task_release_card.json",
      "reason": "private task metadata and provenance"
    },
    {
      "path": "private/invisible_checker_config.yaml",
      "reason": "agent-invisible checker IDs, thresholds, sample windows, and expected outcomes"
    },
    {
      "path": "private/invisible_spec_checker_map.json",
      "reason": "agent-invisible public-spec to private-checker map and leak audit terms"
    },
    {
      "path": "private/gold/tb_window_comparator_ref.scs",
      "reason": "gold answer"
    }
  ],
  "render_policy": {
    "render_agent_visible_contract_only": true,
    "render_agent_prompt_only": false,
    "render_support_files_only_if_listed": true,
    "support_files_must_live_under_public_support": true,
    "never_render_checker_files": true,
    "never_render_private_directory": true,
    "never_render_gold_fixed_artifacts": true,
    "generic_runner_rules_allowed": true,
    "never_render_task_release_card": true
  },
  "leak_audit": {
    "forbidden_phrases": [
      "true_window_comparator",
      "check_true_window_comparator",
      "below_hi < 0.10",
      "above_hi < 0.10",
      "rise_hi > 0.80",
      "fall_hi > 0.80",
      "out_span_too_small",
      "private_threshold_policy",
      "gold_expectation"
    ],
    "allowed_public_concepts": [
      "the DUT support source is visible because this is a testbench-generation task",
      "window thresholds are part of the public DUT behavior",
      "public transient stimulus and save names are visible through public/agent_visible_spec.md",
      "generic Spectre AHDL syntax rules are visible"
    ]
  },
  "contract_audit": {
    "required_public_anchors": [
      {
        "id": "target_artifact",
        "all_of": [
          "tb_window_comparator_ref.scs"
        ]
      },
      {
        "id": "support_dut",
        "all_of": [
          "window_comparator_ref.va",
          "window_comparator_ref",
          "VDD",
          "VSS",
          "vin",
          "out"
        ]
      },
      {
        "id": "window_behavior",
        "all_of": [
          "0.3 V",
          "0.6 V",
          "inside",
          "outside"
        ]
      },
      {
        "id": "stimulus_coverage",
        "all_of": [
          "below `0.3 V`",
          "above `0.6 V`",
          "falling ramp"
        ]
      },
      {
        "id": "testbench_contract",
        "all_of": [
          "tran tran stop=90n maxstep=20p",
          "save",
          "vin",
          "out"
        ]
      }
    ]
  }
}
