        "word_valid"
      ]
    },
    {
      "id": "P_A_RISING_ALIGN_PULSE_RESETS_THE",
      "observable_contract": "A rising `align_pulse` resets the slot pointer so the next sampled serial bit is written to `out0`.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "serial_in",
        "align_pulse",
        "out0",
        "out1",
        "out2",
        "out3",
        "phase_metric",
        "word_valid"
      ]
    },
    {
      "id": "P_ON_EACH_RISING_CLK_EDGE_WHILE",
      "observable_contract": "On each rising `clk` edge while enabled, sample `serial_in` into the active output slot and advance the slot pointer.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "serial_in",
        "align_pulse",
        "out0",
        "out1",
        "out2",
        "out3",
        "phase_metric",
        "word_valid"
      ]
    },
    {
      "id": "P_ASSERT_WORD_VALID_AFTER_ALL_FOUR",
      "observable_contract": "Assert `word_valid` after all four output slots have been updated since the most recent alignment event.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "serial_in",
        "align_pulse",
        "out0",
        "out1",
        "out2",
        "out3",
        "phase_metric",
        "word_valid"
      ]
    },
    {
      "id": "P_PHASE_METRIC_MUST_EXPOSE_THE_ACTIVE",
