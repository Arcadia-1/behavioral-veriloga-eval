      "id": "P_ON_RESET_OR_WHEN_DISABLED_CLEAR",
      "observable_contract": "On reset or when disabled, clear all parallel outputs, `phase_metric`, and `word_valid`.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "serial_in",
        "align_pulse",
        "out0",
        "out1",
