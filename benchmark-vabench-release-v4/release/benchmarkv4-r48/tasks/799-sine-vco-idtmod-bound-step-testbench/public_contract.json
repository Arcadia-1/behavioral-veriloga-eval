      ]
    },
    {
      "id": "P_PHASE_Q_IDTMOD_FREQ_Q_0",
      "observable_contract": "`phase_q = idtmod(freq_q, 0.0, 1.0)` (modulo-1 phase accumulator)",
      "required_signals": [
        "time",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_OUT_VCO_AMP_SIN_M_TWO",
      "observable_contract": "`out = vco_amp * sin(M_TWO_PI * phase_q)` (bipolar sine centered at `0 V`)",
      "required_signals": [
        "time",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_METRIC_VCO_AMP_PHASE_Q_VOLTAGE",
      "observable_contract": "`metric = vco_amp * phase_q` (voltage-coded instantaneous wrapped phase, `0 V` to `vco_amp`)",
      "required_signals": [
        "time",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_CALL_BOUND_STEP_1_0_VCO",
      "observable_contract": "call `$bound_step(1.0 / (vco_ppc * freq_q))` every step so the sine is resolved",
