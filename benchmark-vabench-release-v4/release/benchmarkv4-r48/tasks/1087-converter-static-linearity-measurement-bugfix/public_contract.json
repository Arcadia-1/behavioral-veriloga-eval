  },
  "modeling_constraints": [
    "Use deterministic rising-edge sampled quantization and retained previous-step state.",
    "Use only the public reconstruction table and smoothed voltage outputs.",
    "Do not hard-code validation sweeps or use current contributions, transistor-level devices, continuous-time operators, or validation side channels."
  ],
  "problem_statement": "the supplied system violates the public contract",
  "properties": [
    {
      "id": "P_RESET_STATE",
      "observable_contract": "Active-high reset clears the retained conversion and previous-step state to the public reset values.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "code",
        "recon",
        "dnl",
        "inl"
      ]
    },
    {
      "id": "P_FOUR_BIT_QUANTIZATION",
      "observable_contract": "On each non-reset rising clk edge, vin clips to 0 through vfs and quantizes monotonically to one of 16 codes represented as code_index times vfs/15.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "code"
      ]
    },
    {
      "id": "P_PUBLIC_RECONSTRUCTION_TABLE",
      "observable_contract": "For each code 0 through 15, recon equals the corresponding value in the public monotonic non-ideal reconstruction table, with default table voltages scaled by vfs/0.9 for legal vfs overrides.",
      "required_signals": [
        "time",
        "clk",
        "code",
        "recon"
      ]
    },
    {
      "id": "P_INL_METRIC",
      "observable_contract": "INL encodes reconstruction error from the vfs/15-per-code ideal ramp using the public gain and 0.05 V through 0.85 V clamp.",
      "required_signals": [
        "time",
        "code",
        "recon",
        "inl"
      ]
    },
    {
      "id": "P_DNL_INCREASING_STEP",
      "observable_contract": "For a valid increasing code step, dnl encodes actual reconstruction-step error relative to vfs/15 per code step with the public scaling and clamp.",
      "required_signals": [
        "time",
        "clk",
        "code",
        "recon",
        "dnl"
      ]
    },
    {
      "id": "P_DNL_NO_STEP_BASELINE",
      "observable_contract": "Before a valid increasing step, or when code does not increase, dnl is held at the 0.45 V baseline.",
      "required_signals": [
        "time",
        "clk",
        "code",
        "recon",
        "dnl"
      ]
    }
  ],
