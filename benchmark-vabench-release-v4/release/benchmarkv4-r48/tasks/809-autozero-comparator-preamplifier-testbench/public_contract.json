  "properties": [
    {
      "id": "P_ON_RESET_CLEAR_STORED_OFFSET_DECISION",
      "observable_contract": "On reset, clear stored offset, `decision`, and `ready`.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "az_en",
        "eval_en",
        "decision",
        "offset_store",
        "ready"
      ]
    },
    {
      "id": "P_DURING_AN_AUTO_ZERO_CLOCK_UPDATE",
      "observable_contract": "During an auto-zero clock update with `az_en` high, store the apparent differential offset between `vinp` and `vinn`.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "az_en",
        "eval_en",
        "decision",
        "offset_store",
        "ready"
      ]
    },
    {
      "id": "P_DURING_AN_EVALUATION_CLOCK_UPDATE_WITH",
      "observable_contract": "During an evaluation clock update with `eval_en` high, subtract the stored offset from the live differential input.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "az_en",
        "eval_en",
        "decision",
        "offset_store",
        "ready"
      ]
    },
    {
      "id": "P_DRIVE_DECISION_HIGH_FOR_CORRECTED_NONNEGATIVE",
      "observable_contract": "Drive `decision` high for corrected nonnegative differential input and low otherwise.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "az_en",
        "eval_en",
        "decision",
        "offset_store",
        "ready"
      ]
    },
    {
      "id": "P_EXPOSE_STORED_OFFSET_ON_OFFSET_STORE",
      "observable_contract": "Expose stored offset on `offset_store` and assert `ready` after at least one auto-zero update.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "az_en",
        "eval_en",
        "decision",
        "offset_store",
        "ready"
      ]
    },
    {
      "id": "P_USE_ONLY_VOLTAGE_DOMAIN_BEHAVIORAL_STATE",
