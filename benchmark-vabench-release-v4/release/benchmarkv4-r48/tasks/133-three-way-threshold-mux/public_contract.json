        "cntrlm",
        "sigout"
      ]
    },
    {
      "id": "P_LOW_REGION_SELECTS_SIGIN1",
      "observable_contract": "When control is below `sigth_low`, drive `sigout` from `sigin1`.",
      "required_signals": [
        "time",
        "sigin1",
        "cntrlp",
        "cntrlm",
        "sigout"
      ]
    },
    {
      "id": "P_MIDDLE_REGION_SELECTS_SIGIN2",
      "observable_contract": "When control is in the inclusive window `[sigth_low, sigth_high]`, drive `sigout` from `sigin2`.",
      "required_signals": [
        "time",
        "sigin2",
        "cntrlp",
        "cntrlm",
        "sigout"
      ]
    },
    {
      "id": "P_HIGH_REGION_SELECTS_SIGIN3",
