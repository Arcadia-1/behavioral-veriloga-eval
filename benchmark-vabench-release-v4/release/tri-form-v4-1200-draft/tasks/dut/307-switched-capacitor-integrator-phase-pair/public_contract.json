  "modeling_constraints": [
    "Use deterministic voltage-domain behavioral Verilog-A.",
    "Do not hard-code validation stimulus, stop times, sample windows, gold internals, or simulator side channels."
  ],
  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_CLEAR",
      "observable_contract": "On reset or when disabled, clear the integration state, drive `vout` to `vcm`, and clear `valid`.",
      "required_signals": [
        "time",
        "vin",
        "phi1",
        "phi2",
        "rst",
        "enable",
        "vout",
        "phase_metric",
        "valid"
      ]
    },
    {
      "id": "P_ON_A_RISING_PHI1_CROSSING_SAMPLE",
      "observable_contract": "On a rising `phi1` crossing, sample the input deviation from `vcm` into the sampling state.",
      "required_signals": [
        "time",
        "vin",
        "phi1",
        "phi2",
        "rst",
        "enable",
        "vout",
        "phase_metric",
        "valid"
      ]
    },
    {
      "id": "P_ON_THE_FOLLOWING_RISING_PHI2_CROSSING",
      "observable_contract": "On the following rising `phi2` crossing, add `k_int` times the sampled deviation to the integrator state.",
      "required_signals": [
        "time",
        "vin",
        "phi1",
        "phi2",
        "rst",
        "enable",
        "vout",
        "phase_metric",
        "valid"
      ]
    },
    {
      "id": "P_REJECT_OVERLAPPING_PHI1_AND_PHI2_UPDATES",
      "observable_contract": "Reject overlapping `phi1` and `phi2` updates by holding the previous state and lowering `valid` for that cycle.",
      "required_signals": [
        "time",
        "vin",
        "phi1",
        "phi2",
        "rst",
        "enable",
        "vout",
        "phase_metric",
        "valid"
      ]
    },
    {
      "id": "P_EXPOSE_THE_MOST_RECENT_ACCEPTED_PHASE",
      "observable_contract": "Expose the most recent accepted phase pair on `phase_metric` and clamp `vout` to the rails.",
      "required_signals": [
        "time",
        "vin",
        "phi1",
        "phi2",
        "rst",
        "enable",
        "vout",
        "phase_metric",
        "valid"
      ]
    },
    {
      "id": "P_USE_ONLY_VOLTAGE_DOMAIN_BEHAVIORAL_STATE",
      "observable_contract": "Use only voltage-domain behavioral state and voltage contributions on public electrical outputs.",
      "required_signals": [
        "time",
        "vin",
        "phi1",
        "phi2",
        "rst",
        "enable",
        "vout",
        "phase_metric",
        "valid"
      ]
    }
  ],
