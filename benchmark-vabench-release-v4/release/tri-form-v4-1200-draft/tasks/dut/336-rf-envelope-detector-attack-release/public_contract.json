        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "envelope",
        "attack_metric",
        "valid"
      ]
    },
    {
      "id": "P_USE_A_FASTER_ATTACK_STEP_WHEN",
      "observable_contract": "Use a faster attack step when magnitude rises and a slower release step when it falls.",
