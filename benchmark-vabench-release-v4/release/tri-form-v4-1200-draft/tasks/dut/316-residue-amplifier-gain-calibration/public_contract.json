  "properties": [
    {
      "id": "P_ON_RESET_CLEAR_GAIN_CODE_OUTPUT",
      "observable_contract": "On reset, clear gain code, output, error metric, and `locked`.",
      "required_signals": [
        "time",
        "vin",
        "residue_ref",
        "clk",
        "rst",
        "cal_en",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "error_metric",
        "locked"
      ]
    },
    {
      "id": "P_WHILE_CAL_EN_IS_HIGH_COMPARE",
      "observable_contract": "While `cal_en` is high, compare the current residue output against `residue_ref` on each rising `clk` edge.",
      "required_signals": [
        "time",
        "vin",
        "residue_ref",
        "clk",
        "rst",
        "cal_en",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "error_metric",
        "locked"
      ]
    },
    {
      "id": "P_INCREMENT_OR_DECREMENT_THE_GAIN_CODE",
      "observable_contract": "Increment or decrement the gain code by one step to reduce the signed error.",
      "required_signals": [
        "time",
        "vin",
        "residue_ref",
        "clk",
        "rst",
        "cal_en",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "error_metric",
        "locked"
      ]
    },
    {
      "id": "P_DRIVE_VOUT_AS_A_CLAMPED_RESIDUE",
      "observable_contract": "Drive `vout` as a clamped residue-amplified version of `vin - vcm` using the active gain code.",
      "required_signals": [
        "time",
        "vin",
        "residue_ref",
        "clk",
        "rst",
        "cal_en",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "error_metric",
        "locked"
      ]
    },
    {
      "id": "P_ASSERT_LOCKED_AFTER_THREE_CONSECUTIVE_UPDATES",
      "observable_contract": "Assert `locked` after three consecutive updates with error magnitude below `lock_tol`.",
      "required_signals": [
        "time",
        "vin",
        "residue_ref",
        "clk",
        "rst",
        "cal_en",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "error_metric",
        "locked"
      ]
    },
