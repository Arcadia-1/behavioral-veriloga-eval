  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_CLEAR",
      "observable_contract": "On reset or when disabled, clear output, metric, and `valid`.",
      "required_signals": [
        "time",
        "symbol_1",
        "symbol_0",
        "clk",
        "rst",
        "enable",
        "level_out",
        "linearity_metric",
        "valid"
      ]
    },
    {
      "id": "P_ON_EACH_ENABLED_RISING_CLK_EDGE",
      "observable_contract": "On each enabled rising `clk` edge, decode `symbol_1..symbol_0` as one of four PAM4 levels.",
      "required_signals": [
        "time",
        "symbol_1",
        "symbol_0",
        "clk",
        "rst",
        "enable",
        "level_out",
        "linearity_metric",
        "valid"
      ]
    },
    {
      "id": "P_DRIVE_LEVEL_OUT_TO_EVENLY_SPACED",
      "observable_contract": "Drive `level_out` to evenly spaced voltage levels between `vss` and `vdd`.",
      "required_signals": [
        "time",
        "symbol_1",
        "symbol_0",
        "clk",
        "rst",
        "enable",
        "level_out",
        "linearity_metric",
        "valid"
      ]
    },
    {
      "id": "P_EXPOSE_A_LINEARITY_METRIC_THAT_IS",
      "observable_contract": "Expose a `linearity_metric` that is high only when adjacent level spacing is uniform.",
      "required_signals": [
        "time",
        "symbol_1",
        "symbol_0",
        "clk",
        "rst",
        "enable",
        "level_out",
        "linearity_metric",
        "valid"
      ]
    },
    {
      "id": "P_ASSERT_VALID_AFTER_EACH_SAMPLED_SYMBOL",
      "observable_contract": "Assert `valid` after each sampled symbol update.",
      "required_signals": [
        "time",
        "symbol_1",
        "symbol_0",
        "clk",
        "rst",
        "enable",
        "level_out",
        "linearity_metric",
        "valid"
      ]
    }
