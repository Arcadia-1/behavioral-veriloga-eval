  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_DRIVE",
      "observable_contract": "On reset or when disabled, drive `vout` to `vcm` and clear the metrics.",
      "required_signals": [
        "time",
        "vin_proxy",
        "bias",
        "enable",
        "rst",
        "vout",
        "transimpedance_metric",
        "overload"
      ]
    },
    {
      "id": "P_TREAT_VIN_PROXY_AS_A_VOLTAGE",
      "observable_contract": "Treat `vin_proxy` as a voltage-domain proxy for input current magnitude.",
      "required_signals": [
        "time",
        "vin_proxy",
        "bias",
        "enable",
        "rst",
        "vout",
        "transimpedance_metric",
        "overload"
      ]
    },
    {
      "id": "P_GENERATE_AN_OUTPUT_DEVIATION_AROUND_VCM",
      "observable_contract": "Generate an output deviation around `vcm` proportional to the proxy input and `rz_gain`.",
      "required_signals": [
        "time",
        "vin_proxy",
        "bias",
        "enable",
        "rst",
        "vout",
        "transimpedance_metric",
        "overload"
      ]
    },
    {
      "id": "P_REDUCE_EFFECTIVE_GAIN_WHEN_BIAS_FALLS",
      "observable_contract": "Reduce effective gain when `bias` falls below `bias_min` and expose the effective gain on `transimpedance_metric`.",
      "required_signals": [
        "time",
        "vin_proxy",
        "bias",
        "enable",
        "rst",
        "vout",
        "transimpedance_metric",
        "overload"
      ]
    },
    {
      "id": "P_ASSERT_OVERLOAD_WHEN_THE_UNCLAMPED_OUTPUT",
      "observable_contract": "Assert `overload` when the unclamped output target would exceed the rails.",
      "required_signals": [
        "time",
        "vin_proxy",
        "bias",
        "enable",
        "rst",
        "vout",
        "transimpedance_metric",
        "overload"
      ]
    },
