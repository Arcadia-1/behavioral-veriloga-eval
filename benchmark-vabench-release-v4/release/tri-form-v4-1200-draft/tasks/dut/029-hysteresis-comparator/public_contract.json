  "form": "dut",
  "identity": {
    "category": "comparator_decision",
    "difficulty": "D2",
    "level": "L1",
    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "Hysteresis Comparator"
  },
  "modeling_constraints": [
    "Update retained decision state only at initialization and differential threshold crossings.",
    "Drive complementary smoothed voltage contributions outside event blocks.",
    "Do not use current contributions, ddt(), idt(), validation hooks, or simulator-specific side channels."
  ],
  "properties": [
    {
      "id": "P_INITIAL_DECISION",
      "observable_contract": "OUTP initializes high only when the initial differential exceeds positive vhys over two; otherwise OUTP initializes low and OUTN high.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "out_p",
        "out_n"
      ]
    },
    {
      "id": "P_POSITIVE_SWITCH_THRESHOLD",
      "observable_contract": "The low OUTP state switches high only on a rising differential crossing of positive vhys over two.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "out_p",
        "out_n"
      ]
    },
    {
      "id": "P_NEGATIVE_SWITCH_THRESHOLD",
      "observable_contract": "The high OUTP state switches low only on a falling differential crossing of negative vhys over two.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "out_p",
        "out_n"
      ]
    },
    {
      "id": "P_HYSTERESIS_HOLD",
      "observable_contract": "The previous decision is retained while the differential remains inside the hysteresis band.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "out_p",
        "out_n"
      ]
    },
    {
      "id": "P_COMPLEMENTARY_RAIL_OUTPUT",
      "observable_contract": "OUTP and OUTN remain complementary and use the local VDD and VSS rail levels after smoothing.",
      "required_signals": [
        "time",
        "out_p",
        "out_n",
        "vdd",
        "vss"
      ]
    }
  ],
  "schema_version": "v4-tri-form-public-contract-v1",
