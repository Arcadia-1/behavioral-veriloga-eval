  "form": "dut",
  "identity": {
    "category": "comparator_decision",
    "difficulty": "D2",
    "level": "L1",
    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "Strongarm Style Latch Comparator"
  },
  "modeling_constraints": [
    "Use the local rail midpoint as the clock threshold.",
    "Update discrete decision state only on initialization and clock crossings, and drive smoothed voltage contributions outside event blocks.",
    "Use voltage contributions only; do not use current contributions, ddt(), idt(), validation hooks, or simulator-specific side channels."
  ],
  "properties": [
    {
      "id": "P_INITIAL_AND_FALLING_RESET",
      "observable_contract": "All decision and latch monitor outputs initialize low and return low after each falling clock crossing.",
      "required_signals": [
        "time",
        "clk",
        "out_n",
        "out_p",
        "lp",
        "lm"
      ]
    },
    {
      "id": "P_POSITIVE_DECISION",
      "observable_contract": "A rising clock crossing with VINP minus VINN minus voffset positive latches DCMPP and LP high while DCMPN and LM remain low.",
      "required_signals": [
        "time",
        "clk",
        "vinp",
        "vinn",
        "out_p",
        "out_n",
        "lp",
        "lm",
        "vdd",
        "vss"
      ]
    },
    {
      "id": "P_NEGATIVE_DECISION",
      "observable_contract": "A rising clock crossing with VINP minus VINN minus voffset negative latches DCMPN and LM high while DCMPP and LP remain low.",
      "required_signals": [
        "time",
        "clk",
        "vinp",
        "vinn",
        "out_p",
        "out_n",
        "lp",
        "lm",
        "vdd",
        "vss"
      ]
    },
    {
      "id": "P_ZERO_DIFFERENTIAL",
      "observable_contract": "An exactly zero effective differential sampled at a rising clock crossing leaves both complementary decision states low.",
      "required_signals": [
        "time",
        "clk",
        "vinp",
        "vinn",
        "out_p",
        "out_n",
        "lp",
        "lm"
      ]
    },
    {
      "id": "P_LATCH_HOLD",
      "observable_contract": "The sampled decision is held between clock events and does not track input changes while the clock remains high.",
      "required_signals": [
        "time",
        "clk",
        "vinp",
        "vinn",
        "out_p",
        "out_n",
        "lp",
        "lm"
      ]
    }
  ],
