  "properties": [
    {
      "id": "P_RESET_DISABLE_CLEAR",
      "observable_contract": "Reset or a low `enable` clears `vhold`, `aperture_metric`, `droop_metric`, and `valid`.",
      "required_signals": [
        "time",
        "vin",
        "track",
        "rst",
        "enable",
        "vhold",
        "aperture_metric",
        "droop_metric",
        "valid"
      ]
    },
    {
      "id": "P_TRACK_MODE_FOLLOWS_INPUT",
      "observable_contract": "While `track` is high and the DUT is enabled, the held state follows `vin` at the internal update cadence and `valid` remains low.",
      "required_signals": [
        "time",
        "vin",
        "track",
        "rst",
        "enable",
        "vhold",
        "valid"
      ]
    },
    {
      "id": "P_FALLING_TRACK_SAMPLE_APERTURE",
      "observable_contract": "A falling `track` edge samples `vin`, asserts `valid`, and reports an aperture metric proportional to the step from the previous tracked value.",
      "required_signals": [
        "time",
        "vin",
        "track",
        "enable",
        "vhold",
        "aperture_metric",
        "valid"
      ]
    },
    {
      "id": "P_HOLD_MODE_DROOP",
      "observable_contract": "During hold mode, `vhold` droops downward by `droop_per_tick` on each update tick without going below `vss`.",
      "required_signals": [
        "time",
        "track",
        "enable",
        "vhold",
        "droop_metric"
      ]
    },
    {
      "id": "P_DROOP_METRIC_ACCUMULATION",
      "observable_contract": "`droop_metric` accumulates total hold-mode droop and clears on a new sample, reset, or disable.",
      "required_signals": [
        "time",
        "track",
        "rst",
        "enable",
        "droop_metric",
        "valid"
      ]
    }
  ],
