  ],
  "properties": [
    {
      "id": "P_RESET_STATE",
      "observable_contract": "Active-high reset restores out to 0.45 V, clears rssi_mon and metric, and represents the initial gain 2.2 on gain_mon.",
      "required_signals": [
        "time",
        "rst",
        "out",
        "metric",
        "gain_mon",
        "rssi_mon"
      ]
    },
    {
      "id": "P_CLOCKED_GAIN_LOOP",
      "observable_contract": "The AGC samples and updates its held output and gain state only on rising clk crossings after reset releases.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "gain_mon"
      ]
    },
    {
      "id": "P_OUTPUT_ENVELOPE",
      "observable_contract": "Out is the current-gain amplification of vin about 0.45 V, clamped to 0.02 V through 0.88 V, and rssi_mon reports the normalized absolute output envelope.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out",
        "rssi_mon"
      ]
    },
    {
      "id": "P_GAIN_DIRECTION_AND_BOUNDS",
      "observable_contract": "Envelope above target_amp plus deadband lowers gain by 0.18, envelope below target_amp minus deadband raises gain by 0.10, and gain remains in 0.45 through 3.0.",
      "required_signals": [
        "time",
        "clk",
        "out",
        "gain_mon",
        "rssi_mon"
      ]
    },
    {
      "id": "P_DEADBAND_HOLD",
      "observable_contract": "When the observed envelope lies within the target deadband, the bounded gain state holds across the update.",
      "required_signals": [
        "time",
        "clk",
        "out",
        "gain_mon",
        "rssi_mon"
      ]
    },
    {
      "id": "P_SETTLING_METRIC",
      "observable_contract": "Metric decreases with absolute envelope error from target_amp according to the public scaling and remains clamped to 0 V through 0.9 V.",
      "required_signals": [
        "time",
        "out",
        "metric",
        "rssi_mon"
      ]
    }
  ],
