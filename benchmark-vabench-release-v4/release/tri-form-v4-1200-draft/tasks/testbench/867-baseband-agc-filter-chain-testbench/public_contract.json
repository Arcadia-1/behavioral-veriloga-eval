  "properties": [
    {
      "id": "P_RESET_DISABLE_CLEAR",
      "observable_contract": "Reset or disabled operation restores gain code 4, clears metrics and flags, and drives vout to vcm.",
      "required_signals": [
        "time",
        "rst",
        "enable",
        "vout",
        "gain_3",
        "gain_2",
        "gain_1",
        "gain_0",
        "level_metric",
        "clip_flag",
        "settled"
      ]
    },
    {
      "id": "P_LEVEL_GAIN_CONTROL",
      "observable_contract": "Each enabled rising clock samples the input magnitude and moves the bounded gain code toward the target deadband.",
      "required_signals": [
        "time",
        "vin",
        "target",
        "clk",
        "rst",
        "enable",
        "gain_3",
        "gain_2",
        "gain_1",
        "gain_0",
        "level_metric"
      ]
    },
    {
      "id": "P_VGA_FILTER_RESPONSE",
      "observable_contract": "The VGA applies gain_min plus gain_lsb times code and the sampled filter moves by alpha toward that VGA result.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "enable",
        "vout",
        "gain_3",
        "gain_2",
        "gain_1",
        "gain_0"
      ]
    },
    {
      "id": "P_CLIP_AND_SETTLE",
      "observable_contract": "clip_flag reports an unclamped filter excursion beyond the rails and settled asserts only after three consecutive in-tolerance updates.",
      "required_signals": [
        "time",
        "target",
        "clk",
        "enable",
        "vout",
        "level_metric",
        "clip_flag",
        "settled"
      ]
    }
  ],
