  "modeling_constraints": [
    "Sample the sine and optional seeded perturbation only on rising CLK crossings after reset release.",
    "Use deterministic seeded behavior and smoothed voltage contributions only.",
    "Do not use transistor-level devices, AC/noise analysis, waveform files, validation artifacts, or simulator-specific side channels."
  ],
  "properties": [
    {
      "id": "P_RESET_COMMON_MODE",
      "observable_contract": "While RST_N is below vth, both outputs hold near vdd divided by two.",
      "required_signals": [
        "time",
        "rst_n",
        "vinp",
        "vinn"
      ]
    },
    {
      "id": "P_RISING_EDGE_SAMPLE",
      "observable_contract": "After reset release, VOUT_P updates only on rising CLK crossings through vth.",
      "required_signals": [
        "time",
        "clk",
        "rst_n",
        "vinp"
      ]
    },
    {
      "id": "P_SAMPLED_SINE",
      "observable_contract": "At each qualifying clock edge, VOUT_P samples vdd/2 plus ampl times sin(2*pi*freq*time), plus the optional seeded perturbation.",
      "required_signals": [
        "time",
        "clk",
        "rst_n",
        "vinp"
      ]
    },
    {
      "id": "P_REFERENCE_SIDE_COMMON_MODE",
      "observable_contract": "VOUT_N remains at vdd divided by two during reset and active sampling.",
      "required_signals": [
        "time",
        "rst_n",
        "vinn"
      ]
    },
    {
      "id": "P_INTEREDGE_HOLD",
      "observable_contract": "Both outputs hold their sampled values between CLK events rather than continuously recomputing the sine or perturbation.",
      "required_signals": [
        "time",
        "clk",
        "vinp",
        "vinn"
      ]
    },
    {
      "id": "P_SEEDED_REPEATABILITY",
      "observable_contract": "For fixed SEED, sigma, controls, and timing, the sampled perturbation sequence and outputs are repeatable; sigma zero removes the perturbation.",
      "required_signals": [
        "time",
        "clk",
        "rst_n",
        "vinp",
        "vinn"
      ]
    }
  ],
