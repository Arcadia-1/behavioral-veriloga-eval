        "time",
        "lo_i",
        "lo_q",
        "phase_mon"
      ]
    },
    {
      "id": "P_MIXER_MONITORS",
      "observable_contract": "Each mixer monitor equals 0.45 V plus 1.25 times the vin deviation times its LO coefficient, clamped to 0.02 V through 0.88 V.",
      "required_signals": [
        "time",
        "vin",
        "lo_i",
        "lo_q",
        "mix_i",
        "mix_q"
      ]
    },
    {
      "id": "P_BASEBAND_UPDATES",
      "observable_contract": "On each valid edge, out and metric apply the public 0.85 first-order update toward mix_i and mix_q respectively and remain clamped to 0.02 V through 0.88 V.",
      "required_signals": [
        "time",
        "clk",
        "mix_i",
        "mix_q",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_PHASE_MONITOR",
      "observable_contract": "Phase_mon exposes the current four-state phase as phase/3 times 0.9 V.",
      "required_signals": [
        "time",
        "clk",
        "phase_mon"
      ]
