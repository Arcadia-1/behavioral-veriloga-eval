  "properties": [
    {
      "id": "P_STROBE_UPDATE",
      "observable_contract": "The retained error metric updates only on rising crossings of vsample through vth and holds between strobes.",
      "required_signals": [
        "time",
        "vsample",
        "vin",
        "d2",
        "d1",
        "d0",
        "maxerr"
      ]
    },
    {
      "id": "P_IDEAL_CODE",
      "observable_contract": "At a strobe, vin is clipped to 0 through vref and mapped to the ideal three-bit bin-floor code.",
      "required_signals": [
        "time",
        "vsample",
        "vin",
        "maxerr"
      ]
    },
    {
      "id": "P_OBSERVED_CODE",
      "observable_contract": "At a strobe, d2 through d0 are threshold-decoded as an unsigned three-bit word with d2 as MSB and d0 as LSB.",
      "required_signals": [
        "time",
        "vsample",
        "d2",
        "d1",
        "d0",
        "maxerr"
      ]
    },
    {
      "id": "P_ABSOLUTE_ERROR",
      "observable_contract": "Each sampled error is the absolute difference in codes between the ideal and observed three-bit words.",
      "required_signals": [
        "time",
        "vsample",
        "vin",
        "d2",
        "d1",
        "d0",
        "maxerr"
      ]
    },
    {
      "id": "P_MAX_RETENTION",
      "observable_contract": "maxerr never decreases during a run and represents the largest sampled absolute code error seen so far.",
      "required_signals": [
        "time",
        "vsample",
        "maxerr"
      ]
    },
    {
      "id": "P_METRIC_SCALE",
      "observable_contract": "maxerr equals the retained maximum code error multiplied by lsb_out, with smoothing set by tr.",
      "required_signals": [
        "time",
        "maxerr"
      ]
    }
  ],
