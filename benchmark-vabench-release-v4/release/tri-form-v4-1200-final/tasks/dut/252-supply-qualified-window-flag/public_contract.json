  "properties": [
    {
      "id": "P_MEASURE_ANALOG_INPUTS_RELATIVE_TO_THE",
      "observable_contract": "Measure analog inputs relative to the local `vss` rail and normalize by the current local supply span. Let `span = V(vdd, vss)` and treat the row as valid only when `V(en) > vth` and `span_min <= span <= span_max`; otherwise drive `out`, `flag`, and `metric` to `0 V`. If `span` is below `0.05 V`, use `0.05 V` as the normalization span. Define `clip01(y)` as `y` limited to the range `[0, 1]`, `x0..x3 = clip01((V(inN) - V(vss)) / span)`, and `c0 = clip01(V(ctrl0) / vhi)`.",
      "required_signals": [
        "time",
        "ctrl0",
        "ctrl1",
        "en",
        "flag",
        "in0",
        "in1",
        "in2",
        "in3",
        "metric",
        "out",
        "vdd",
        "vss"
      ]
    },
    {
      "id": "P_WHEN_VALID_DRIVE_OUT_VHI_CLIP01",
      "observable_contract": "When valid, drive `out = vhi * clip01(x0)`, assert `flag = vhi` only when `0.24 <= x0 <= 0.72` and `c0 > 0.35`, otherwise drive `flag = 0 V`, and drive `metric = vhi * clip01(abs(x0 - 0.48) / 0.48)`.",
      "required_signals": [
        "time",
        "ctrl0",
        "ctrl1",
        "en",
        "flag",
        "in0",
        "in1",
        "in2",
        "in3",
        "metric",
        "out",
        "vdd",
        "vss"
      ]
    },
    {
