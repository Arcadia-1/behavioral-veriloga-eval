    "title": "Soft Hysteretic Limiter"
  },
  "modeling_constraints": [
    "Use deterministic event-updated voltage-domain state and finite output smoothing.",
    "Do not use current contributions, transistor-level devices, AC/noise analysis, ddt(), or idt().",
    "Do not add validation-only hooks, ports, or simulator-specific side channels."
  ],
  "properties": [
    {
      "id": "P_RESET_NEUTRAL",
      "observable_contract": "Initialization or active reset sets out and metric to 0.45 V and clears the remembered hysteresis offset.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_HYSTERESIS_STATE_UPDATE",
      "observable_contract": "On rising clk crossings, vin above 0.62 V stores +hys_step, vin below 0.38 V stores -hys_step, and vin within the middle band preserves the prior offset.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "metric"
      ]
    },
    {
      "id": "P_GAINED_LIMITER_TRANSFER",
      "observable_contract": "The held output target is 0.45 V plus gain times vin minus 0.45 V plus the remembered hysteresis offset.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_OUTPUT_LIMITS",
      "observable_contract": "Out is clamped to 0.10 V through 0.82 V with finite transition smoothing.",
      "required_signals": [
        "time",
        "out"
      ]
    },
    {
      "id": "P_STATE_METRIC",
      "observable_contract": "Metric equals 0.45 V plus twice the remembered offset, producing 0.61 V and 0.29 V for the default high- and low-memory states.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "metric"
      ]
    }
  ],
