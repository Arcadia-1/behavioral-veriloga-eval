        "converged"
      ]
    },
    {
      "id": "P_ON_EACH_ENABLED_DECISION_CLOCK_LATCH",
      "observable_contract": "On each enabled decision clock, latch the sign of `sample_in - vcm` as the current decision.",
      "required_signals": [
        "time",
        "sample_in",
        "decision_clk",
        "rst",
        "enable",
        "tap_1",
        "tap_0",
        "corrected_out",
        "error_metric",
        "converged"
      ]
    },
    {
      "id": "P_USE_THE_PREVIOUS_DECISION_HISTORY_TO",
      "observable_contract": "Use the previous decision history to subtract a two-tap feedback estimate from the live sample.",
      "required_signals": [
        "time",
        "sample_in",
        "decision_clk",
        "rst",
        "enable",
        "tap_1",
        "tap_0",
        "corrected_out",
        "error_metric",
        "converged"
      ]
    },
    {
      "id": "P_EXPOSE_THE_ABSOLUTE_RESIDUAL_ON_ERROR",
      "observable_contract": "Expose the absolute residual on `error_metric`.",
      "required_signals": [
        "time",
        "sample_in",
        "decision_clk",
        "rst",
        "enable",
        "tap_1",
        "tap_0",
        "corrected_out",
        "error_metric",
        "converged"
      ]
    },
    {
      "id": "P_ASSERT_CONVERGED_WHEN_THE_RESIDUAL_REMAINS",
