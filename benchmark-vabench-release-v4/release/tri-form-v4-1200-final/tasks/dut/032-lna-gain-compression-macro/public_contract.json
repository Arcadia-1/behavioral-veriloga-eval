        "time",
        "clk",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_POSITIVE_COMPRESSION",
      "observable_contract": "Above linear 0.76 V, excess signal is compressed by factor 0.28 and metric is 0.8 V.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_NEGATIVE_COMPRESSION",
