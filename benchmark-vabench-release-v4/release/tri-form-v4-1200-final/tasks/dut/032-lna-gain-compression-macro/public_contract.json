        "time",
        "clk",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_FINAL_OUTPUT_CLAMP",
      "observable_contract": "The final held output remains within 0.04 V through 0.86 V.",
      "required_signals": [
        "time",
        "out"
      ]
    },
    {
      "id": "P_CLOCKED_HOLD",
