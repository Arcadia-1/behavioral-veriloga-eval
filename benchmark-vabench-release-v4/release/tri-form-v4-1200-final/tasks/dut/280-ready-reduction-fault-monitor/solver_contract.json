{"artifact_contract":{"files":[{"modules":[{"depends_on":[],"name":"ready_reduction_fault_monitor","parameters":[{"default":"0.45","name":"vth","override_behavior":"overrides vth","type":"real","units":"","valid_range":"finite"},{"default":"0.9","name":"vhi","override_behavior":"overrides vhi","type":"real","units":"","valid_range":"finite"},{"default":"0.62","name":"span_min","override_behavior":"overrides span_min","type":"real","units":"","valid_range":"finite"},{"default":"1.28","name":"span_max","override_behavior":"overrides span_max","type":"real","units":"","valid_range":"finite"},{"default":"50p","name":"tr","override_behavior":"overrides tr","type":"real","units":"","valid_range":"finite"}],"ports":[{"direction":"input","discipline":"electrical","name":"in0","position":0},{"direction":"input","discipline":"electrical","name":"in1","position":1},{"direction":"input","discipline":"electrical","name":"in2","position":2},{"direction":"input","discipline":"electrical","name":"in3","position":3},{"direction":"input","discipline":"electrical","name":"ctrl0","position":4},{"direction":"input","discipline":"electrical","name":"ctrl1","position":5},{"direction":"input","discipline":"electrical","name":"vdd","position":6},{"direction":"input","discipline":"electrical","name":"vss","position":7},{"direction":"input","discipline":"electrical","name":"en","position":8},{"direction":"output","discipline":"electrical","name":"out","position":9},{"direction":"output","discipline":"electrical","name":"flag","position":10},{"direction":"output","discipline":"electrical","name":"metric","position":11}],"role":"entry"}],"path":"ready_reduction_fault_monitor.va"}],"mode":"single_file"},"family_id":"280","form":"dut","modeling_constraints":["Use deterministic voltage-domain behavioral Verilog-A.","Do not hard-code validation stimulus, stop times, sample windows, gold internals, or simulator side channels."],"properties":[{"id":"P_MEASURE_ANALOG_INPUTS_RELATIVE_TO_THE","observable_contract":"Measure analog inputs relative to the local `vss` rail and normalize by the current local supply span. Let `span = V(vdd, vss)` and treat the row as valid only when `V(en) > vth` and `span_min <= span <= span_max`; otherwise drive `out`, `flag`, and `metric` to `0 V`. If `span` is below `0.05 V`, use `0.05 V` as the normalization span. Define `clip01(y)` as `y` limited to the range `[0, 1]` and `x0..x3 = clip01((V(inN) - V(vss)) / span)`."},{"id":"P_COUNT_HOW_MANY_OF_X0_X1","observable_contract":"Count how many of `x0`, `x1`, `x2`, and `x3` are greater than `0.50`. Drive `out = vhi * clip01(count / 4.0)` and `metric = vhi * clip01(count / 4.0)`. Assert `flag = vhi` when `count >= 3`, otherwise drive `flag = 0 V`."}],"schema_version":"v4-solver-contract-v1","submission_contract":{"agentic_submission_root":"public/submission","exact_declared_file_set_required":true,"target_artifacts_relative_to":"submission_root"},"target_artifacts":["ready_reduction_fault_monitor.va"],"task_id":"v4-280","title":"Ready Reduction Fault Monitor","trace_contract":{"required_signals":["time","in0","in1","in2","in3","ctrl0","ctrl1","vdd","vss","en","out","flag","metric"]}}
