      "id": "P_BISECTION_INITIAL_STATE",
      "observable_contract": "The differential residue initializes to zero, the step initializes to `step_initial`, and the previous decision polarity initializes to the low-decision direction.",
      "required_signals": [
        "time",
        "clk",
