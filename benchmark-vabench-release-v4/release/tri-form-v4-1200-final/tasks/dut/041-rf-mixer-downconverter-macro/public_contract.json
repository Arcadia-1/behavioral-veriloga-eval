  "properties": [
    {
      "id": "P_RESET_COMMON_MODE",
      "observable_contract": "Active reset drives out to 0.45 V common mode and metric low.",
      "required_signals": [
        "time",
        "rst",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_LO_POLARITY",
      "observable_contract": "With reset inactive, clk above vth selects LO coefficient +1 and clk at or below vth selects coefficient -1.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out"
      ]
    },
    {
      "id": "P_DOWNCONVERSION_TRANSFER",
      "observable_contract": "The baseband target is 0.45 V plus conv_gain times vin minus 0.45 V times the selected LO coefficient.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out"
      ]
    },
    {
      "id": "P_ACTIVE_METRIC",
      "observable_contract": "Metric is 0.9 V while reset is inactive and conversion is active, and low during reset.",
