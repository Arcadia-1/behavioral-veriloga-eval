  "properties": [
    {
      "id": "P_READOUT_RESET_CLEAR",
      "observable_contract": "Reset clears held channels, selector, out, and valid.",
      "required_signals": [
        "time",
        "rst",
        "out",
        "ch_sel_1",
        "ch_sel_0",
        "valid"
      ]
    },
    {
      "id": "P_READOUT_SIMULTANEOUS_SAMPLE",
      "observable_contract": "An enabled rising clock captures all four input channels into one coherent held bank.",
      "required_signals": [
        "time",
        "ch0",
        "ch1",
        "ch2",
        "ch3",
        "clk",
        "rst",
        "sample",
        "read",
        "out"
      ]
    },
    {
      "id": "P_READOUT_CHANNEL_ORDER",
      "observable_contract": "Read cycles select held channels in order zero, one, two, three and wrap.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "read",
        "ch_sel_1",
        "ch_sel_0"
      ]
    },
    {
      "id": "P_READOUT_HELD_VALUE",
      "observable_contract": "out equals the held value of the exposed selected channel, independent of later live-input changes.",
      "required_signals": [
        "time",
        "ch0",
        "ch1",
        "ch2",
        "ch3",
        "clk",
        "sample",
        "read",
        "out",
        "ch_sel_1",
        "ch_sel_0"
      ]
    },
    {
      "id": "P_READOUT_VALID_TIMING",
      "observable_contract": "valid is high only for read cycles; when read is low out holds and the pointer does not advance.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "read",
        "out",
        "ch_sel_1",
        "ch_sel_0",
        "valid"
      ]
    }
  ],
