  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_ENABLE_IS",
      "observable_contract": "On reset or when `enable` is low, drive `vout` and `stage1_metric` to `vcm`, clear `slew_metric`, `clamp_flag`, and `settled`.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "enable",
        "load_step",
        "vout",
        "stage1_metric",
