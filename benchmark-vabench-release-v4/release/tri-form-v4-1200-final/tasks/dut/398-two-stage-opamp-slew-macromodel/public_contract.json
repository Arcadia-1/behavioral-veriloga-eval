        "clamp_flag",
        "settled"
      ]
    },
    {
      "id": "P_ON_EACH_RISING_CLK_EDGE_WHILE",
      "observable_contract": "On each rising `clk` edge while enabled, sample the differential input `vinp - vinn`.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "enable",
        "load_step",
        "vout",
        "stage1_metric",
        "slew_metric",
        "clamp_flag",
        "settled"
      ]
    },
    {
      "id": "P_COMPUTE_A_FIRST_STAGE_METRIC_FROM",
      "observable_contract": "Compute a first-stage metric from the sampled differential input, centered around `vcm` and limited to `[vss, vdd]`.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "enable",
        "load_step",
        "vout",
        "stage1_metric",
        "slew_metric",
        "clamp_flag",
        "settled"
      ]
    },
    {
      "id": "P_COMPUTE_AN_OUTPUT_TARGET_FROM_THE",
      "observable_contract": "Compute an output target from the first-stage metric and `stage2_gain`; `load_step` may request a bounded target perturbation around the same common-mode reference.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "enable",
        "load_step",
        "vout",
        "stage1_metric",
        "slew_metric",
        "clamp_flag",
        "settled"
      ]
    },
    {
      "id": "P_CLAMP_THE_OUTPUT_TARGET_TO_VSS",
      "observable_contract": "Clamp the output target to `[vss, vdd]` and assert `clamp_flag` only when clamping occurs.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "enable",
        "load_step",
        "vout",
        "stage1_metric",
        "slew_metric",
        "clamp_flag",
        "settled"
      ]
    },
    {
      "id": "P_MOVE_VOUT_TOWARD_THE_CLAMPED_TARGET",
      "observable_contract": "Move `vout` toward the clamped target by no more than `slew_step` per enabled clock edge.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "enable",
        "load_step",
        "vout",
        "stage1_metric",
        "slew_metric",
        "clamp_flag",
        "settled"
      ]
    },
