  "modeling_constraints": [
    "Keep both requested source files and both public module interfaces in one DUT bundle.",
    "Use voltage contributions and event-driven state; place driven contributions outside event blocks.",
    "Do not use current contributions, ddt(), idt(), hard-coded sample points, or simulator-specific side channels."
  ],
  "properties": [
    {
      "id": "P_CLOCKED_DECISION",
      "observable_contract": "At each rising CLK crossing through half the VDD-to-VSS rail span, the comparator latches the sign of VINP minus VINN minus voffset into complementary DCMPP/DCMPN decisions, with LP mirroring DCMPP and LM mirroring DCMPN.",
      "required_signals": [
        "time",
        "clk",
        "vinn",
        "vinp",
        "gnd",
        "vdd",
        "out_n",
        "out_p",
        "lp_int",
        "lm_int"
      ]
    },
    {
      "id": "P_FALLING_RESET",
      "observable_contract": "Each falling CLK crossing resets both comparator decision outputs low.",
      "required_signals": [
        "time",
        "clk",
        "out_n",
        "out_p"
      ]
    },
    {
      "id": "P_DELAY_MAGNITUDE_TREND",
      "observable_contract": "For otherwise equal conditions, a smaller absolute effective differential input produces a longer clock-to-decision delay.",
      "required_signals": [
        "time",
        "clk",
        "vinn",
        "vinp",
        "out_p",
        "out_n"
      ]
    },
    {
      "id": "P_DELAY_CLAMP",
      "observable_contract": "The scheduled comparator decision delay follows the public log-linear regeneration relation and remains within td_min through td_max.",
      "required_signals": [
        "time",
        "clk",
        "vinn",
        "vinp",
        "vdd",
        "out_p",
        "out_n"
      ]
    },
    {
      "id": "P_EDGE_INTERVAL_MEASUREMENT",
      "observable_contract": "After a rising CLK_1 crossing arms the timer, the next rising CLK_2 crossing updates OUT_PS to the elapsed interval expressed in picoseconds and holds that completed measurement.",
      "required_signals": [
        "time",
        "clk",
        "out_p",
        "delay_ps"
      ]
    },
    {
      "id": "P_BUNDLE_BINDING",
      "observable_contract": "The timing helper observes the comparator clock as CLK_1 and the positive comparator decision as CLK_2, exposing their measured interval on delay_ps.",
      "required_signals": [
        "time",
        "clk",
        "out_p",
        "delay_ps"
      ]
    }
  ],
