  "modeling_constraints": [
    "Use deterministic event-driven voltage-domain sample and leakage updates.",
    "Use voltage contributions only; do not use current contributions, ddt(), or idt().",
    "Do not add validation hooks, hidden observables, or simulator-specific side channels."
  ],
  "properties": [
    {
      "id": "P_SAMPLE_CAPTURE",
      "observable_contract": "Each rising sample crossing while reset is inactive captures the instantaneous vin voltage into the held state.",
      "required_signals": [
        "time",
        "sample",
        "rst",
        "vin",
        "vout"
      ]
    },
    {
      "id": "P_HOLD_BETWEEN_EVENTS",
      "observable_contract": "Between sample and leakage events, vout reflects the retained held state rather than continuously tracking vin.",
      "required_signals": [
        "time",
        "sample",
        "vin",
        "vout"
      ]
    },
    {
      "id": "P_PERIODIC_DROOP",
      "observable_contract": "At every leak_period update while reset is inactive, the held value is multiplied by decay.",
      "required_signals": [
        "time",
        "rst",
        "vout"
      ]
    },
    {
      "id": "P_RESET_CLEAR",
      "observable_contract": "Active reset clears the held state to 0 V at sampling or leakage update events.",
      "required_signals": [
        "time",
        "sample",
        "rst",
        "vout"
      ]
    },
    {
      "id": "P_SMOOTH_OUTPUT",
      "observable_contract": "Vout approaches each held-state target with the finite transition smoothing set by tr.",
      "required_signals": [
        "time",
        "vout"
      ]
    }
