    },
    {
      "id": "P_TRIM_RESPONSE",
      "observable_contract": "The signed three-bit trim correction shifts sum and difference in opposite directions by trim_lsb per code.",
      "required_signals": [
        "time",
        "rst",
        "trim_2",
        "trim_1",
        "trim_0",
        "sum_out",
        "diff_out"
      ]
    },
    {
      "id": "P_DIRECTIONAL_METRICS",
      "observable_contract": "At rising clock edges forward and reverse metrics reconstruct the directional components from the mapped sum and difference outputs.",
