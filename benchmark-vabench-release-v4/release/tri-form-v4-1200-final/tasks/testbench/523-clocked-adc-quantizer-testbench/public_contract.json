        "vin",
        "clk",
        "dout2",
        "dout1",
        "dout0"
      ]
    },
    {
      "id": "P_CODE_CLAMP",
      "observable_contract": "Samples at or outside the conversion endpoints produce codes clamped to the inclusive range 0 through 7.",
