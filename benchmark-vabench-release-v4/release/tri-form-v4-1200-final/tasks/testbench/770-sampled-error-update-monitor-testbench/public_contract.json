        "progress"
      ]
    },
    {
      "id": "P_CORRECTED_OUTPUT_USES_SAMPLE_TARGET_AND_COEF",
      "observable_contract": "At each enabled rising clock edge, compute the clipped coefficient and drive the clamped corrected sample from sample, target, and coef.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "sample",
        "target",
        "coef",
        "out",
        "err_metric",
        "progress"
      ]
    },
    {
      "id": "P_ERROR_METRIC_REPORTS_ABSOLUTE_ERROR",
      "observable_contract": "Drive err_metric from the bounded absolute target-minus-sample error.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "sample",
        "target",
        "coef",
        "out",
        "err_metric",
        "progress"
      ]
    },
    {
      "id": "P_PROGRESS_COUNTS_CONSECUTIVE_IN_WINDOW_SAMPLES",
      "observable_contract": "Increment progress only for consecutive in-window sampled errors, clear it on an out-of-window sample, and saturate at ready_count.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "sample",
        "target",
        "coef",
        "out",
        "err_metric",
