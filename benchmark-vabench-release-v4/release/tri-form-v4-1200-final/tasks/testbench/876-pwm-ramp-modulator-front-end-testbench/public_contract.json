      "id": "P_RESET_OR_A_LOW_ENABLE_CLEARS",
      "observable_contract": "Reset or a low `enable` clears the ramp, PWM output, cycle marker, and duty metric.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "vctrl",
