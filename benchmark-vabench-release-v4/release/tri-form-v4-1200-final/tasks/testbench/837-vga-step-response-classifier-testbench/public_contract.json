  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_DRIVE",
      "observable_contract": "On reset or when disabled, drive `vout` to `vcm`, clear metric, and clear `settled`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "overshoot_metric",
        "settled"
      ]
    },
    {
      "id": "P_ON_EACH_ENABLED_RISING_CLK_EDGE",
      "observable_contract": "On each enabled rising `clk` edge, decode the gain code and update the target output from `vin`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "overshoot_metric",
        "settled"
      ]
    },
    {
      "id": "P_APPLY_BOUNDED_SETTLING_WITH_A_CODE",
      "observable_contract": "Apply bounded settling with a code-dependent overshoot proxy after large gain changes.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "overshoot_metric",
        "settled"
      ]
    },
    {
      "id": "P_EXPOSE_OVERSHOOT_MAGNITUDE_ON_OVERSHOOT_METRIC",
      "observable_contract": "Expose overshoot magnitude on `overshoot_metric`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "overshoot_metric",
        "settled"
      ]
    },
    {
      "id": "P_ASSERT_SETTLED_AFTER_TWO_CONSECUTIVE_UPDATES",
      "observable_contract": "Assert `settled` after two consecutive updates within `settle_tol` of the target.",
