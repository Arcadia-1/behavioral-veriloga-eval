  "properties": [
    {
      "id": "P_DETECT_RISING_REF_AND_FB_CROSSINGS",
      "observable_contract": "Detect rising `ref` and `fb` crossings at `vdd/2`.",
      "required_signals": [
        "time",
        "ref",
        "fb",
        "up",
        "down"
      ]
    },
    {
      "id": "P_A_RISING_REF_EDGE_SETS_THE",
      "observable_contract": "A rising `ref` edge sets the latch state so `up` is high and `down` is low.",
      "required_signals": [
        "time",
        "ref",
        "fb",
        "up",
        "down"
      ]
    },
    {
      "id": "P_A_RISING_FB_EDGE_RESETS_THE",
      "observable_contract": "A rising `fb` edge resets the latch state so `up` is low and `down` is high.",
      "required_signals": [
        "time",
        "ref",
        "fb",
        "up",
        "down"
      ]
    },
    {
      "id": "P_HOLD_THE_MOST_RECENT_LATCH_STATE",
      "observable_contract": "Hold the most recent latch state between qualifying input edges.",
      "required_signals": [
        "time",
        "ref",
        "fb",
        "up",
        "down"
      ]
    },
    {
      "id": "P_INITIALIZE_TO_THE_RESET_STATE_WITH",
      "observable_contract": "Initialize to the reset state with `up` low and `down` high.",
      "required_signals": [
        "time",
        "ref",
        "fb",
        "up",
        "down"
      ]
    }
  ],
