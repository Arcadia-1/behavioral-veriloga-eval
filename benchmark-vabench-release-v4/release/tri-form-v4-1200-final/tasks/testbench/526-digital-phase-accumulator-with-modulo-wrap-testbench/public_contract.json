        "time",
        "VDD",
        "VSS",
        "clk_out",
        "phase_out"
      ]
    },
    {
      "id": "P_PHASE_RAIL_SCALING",
      "observable_contract": "Phase_out equals wrapped normalized phase scaled by the local VDD-minus-VSS rail span.",
      "required_signals": [
        "time",
        "VDD",
        "VSS",
        "clk_out",
        "phase_out"
      ]
    },
    {
      "id": "P_PHASE_DERIVED_CLOCK",
      "observable_contract": "Clk_out is rail-high while normalized phase is below 0.5 and low while phase is at or above 0.5.",
      "required_signals": [
        "time",
        "VDD",
        "VSS",
        "clk_out",
        "phase_out"
      ]
    },
    {
      "id": "P_PARAMETERIZED_PERIOD",
      "observable_contract": "Changing dt or phase_step changes the observable phase and clock cadence according to the same update and wrap rules.",
