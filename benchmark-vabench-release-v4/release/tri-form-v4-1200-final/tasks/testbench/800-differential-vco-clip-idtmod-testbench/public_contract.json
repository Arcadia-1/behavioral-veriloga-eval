  "properties": [
    {
      "id": "P_FREQ_Q_CLIP_FNOM_DFDV_V",
      "observable_contract": "`freq_q = `clip(Fnom + dFdV * V(vinp, vinm), Fmin, Fmax)`",
      "required_signals": [
        "time",
        "vinp",
        "vinm",
        "outp",
        "outm",
        "metric"
      ]
    },
    {
      "id": "P_PHASE_Q_IDTMOD_FREQ_Q_0",
      "observable_contract": "`phase_q = idtmod(freq_q, 0.0, 1.0)` (modulo-1 phase accumulator)",
      "required_signals": [
        "time",
        "vinp",
        "vinm",
        "outp",
        "outm",
        "metric"
      ]
    },
    {
      "id": "P_OUTP_VCM_VAC_SIN_M_TWO",
      "observable_contract": "`outp = Vcm + Vac * sin(M_TWO_PI * phase_q)` (positive differential arm)",
      "required_signals": [
        "time",
        "vinp",
        "vinm",
        "outp",
        "outm",
        "metric"
      ]
    },
    {
      "id": "P_OUTM_VCM_VAC_SIN_M_TWO",
      "observable_contract": "`outm = Vcm - Vac * sin(M_TWO_PI * phase_q)` (negative differential arm)",
      "required_signals": [
        "time",
        "vinp",
        "vinm",
        "outp",
        "outm",
        "metric"
      ]
    },
    {
      "id": "P_METRIC_0_9_PHASE_Q_VOLTAGE",
      "observable_contract": "`metric = 0.9 * phase_q` (voltage-coded instantaneous wrapped phase, `0 V` to `0.9 V`)",
      "required_signals": [
        "time",
        "vinp",
        "vinm",
        "outp",
        "outm",
        "metric"
      ]
    }
  ],
