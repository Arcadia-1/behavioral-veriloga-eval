        "threshold_dbg"
      ]
    },
    {
      "id": "P_CAL_CODE_UPDATE",
      "observable_contract": "Each enabled rising clock updates and clamps the offset code in the direction selected by cal_ref.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "cal_en",
        "cal_ref",
        "decision",
        "ready",
        "offset_3",
        "offset_2",
        "offset_1",
        "offset_0",
        "threshold_dbg"
      ]
    },
    {
      "id": "P_CAL_OFFSET_DAC",
      "observable_contract": "threshold_dbg equals signed code minus eight times offset_lsb outside reset.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "cal_en",
        "cal_ref",
        "decision",
        "ready",
        "offset_3",
        "offset_2",
        "offset_1",
        "offset_0",
        "threshold_dbg"
      ]
    },
    {
      "id": "P_CAL_READY_QUALIFICATION",
      "observable_contract": "ready asserts after four updates in one calibration window and the code holds while cal_en is low.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "cal_en",
        "cal_ref",
        "decision",
        "ready",
        "offset_3",
        "offset_2",
        "offset_1",
        "offset_0",
        "threshold_dbg"
      ]
    },
    {
      "id": "P_CAL_COMPARATOR_DECISION",
      "observable_contract": "decision reflects the sign of vinp minus vinn plus threshold_dbg and is low in reset.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "cal_en",
        "cal_ref",
        "decision",
        "ready",
        "offset_3",
        "offset_2",
        "offset_1",
        "offset_0",
        "threshold_dbg"
      ]
    }
  ],
