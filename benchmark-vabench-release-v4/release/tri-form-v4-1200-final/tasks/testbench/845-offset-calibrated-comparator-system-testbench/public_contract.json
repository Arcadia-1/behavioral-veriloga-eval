  "properties": [
    {
      "id": "P_CAL_RESET_CLEAR",
      "observable_contract": "Reset clears offset code, decision, ready, and threshold_dbg.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
