        "time",
        "vin1",
        "vin2",
        "vsel",
        "vout"
      ]
    },
    {
      "id": "P_INITIAL_SELECTION",
      "observable_contract": "Before any select transition, vout is selected from the initial vsel level using the same strict-greater-than threshold rule.",
