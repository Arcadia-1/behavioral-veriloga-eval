  "properties": [
    {
      "id": "P_A_EDGE_ARMS",
      "observable_contract": "A rising a crossing arms a fresh measurement and clears seen_out until completion.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "a",
        "b",
        "delay_out",
        "seen_out"
      ]
    },
    {
      "id": "P_FIRST_B_EDGE_CAPTURES",
      "observable_contract": "The first rising b crossing after an armed a edge captures their elapsed time; b edges before arming do not complete a measurement.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "a",
        "b",
        "delay_out",
        "seen_out"
      ]
    },
    {
      "id": "P_DELAY_NORMALIZATION",
      "observable_contract": "Delay_out equals the VDD-to-VSS rail span multiplied by measured delay in picoseconds divided by scale_ps.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "a",
        "b",
        "delay_out",
        "seen_out"
      ]
    },
    {
      "id": "P_COMPLETION_MARKER",
      "observable_contract": "Seen_out is rail-high after a valid a-then-b capture and rail-low while a newly armed measurement is incomplete.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "a",
        "b",
        "delay_out",
        "seen_out"
      ]
    },
    {
      "id": "P_SINGLE_CAPTURE_PER_ARM",
      "observable_contract": "Additional b crossings after completion do not change delay_out until the next rising a edge rearms the timer.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "a",
        "b",
        "delay_out",
