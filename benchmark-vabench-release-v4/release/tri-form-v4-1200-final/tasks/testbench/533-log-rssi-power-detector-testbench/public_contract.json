  "properties": [
    {
      "id": "P_RESET_BASELINE",
      "observable_contract": "Initialization or active reset drives out to 0.12 V and metric to 0 V.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_CLOCKED_MAGNITUDE_SAMPLE",
      "observable_contract": "Each rising clk crossing while reset is inactive samples the magnitude abs(vin - 0.45 V); the held outputs do not track vin between samples.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_RSSI_BINS",
      "observable_contract": "Sampled magnitudes below 0.035 V, from 0.035 V to below 0.11 V, from 0.11 V to below 0.22 V, and at least 0.22 V map to out levels 0.12 V, 0.30 V, 0.54 V, and 0.72 V respectively.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_AMPLITUDE_METRIC",
      "observable_contract": "Metric equals three times the sampled magnitude, clamped to the 0 V to 0.9 V range.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_OUTPUT_BOUNDS",
      "observable_contract": "Out remains within the public 0.08 V to 0.82 V clamp range with finite transition smoothing.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    }
