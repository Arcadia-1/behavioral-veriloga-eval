  "properties": [
    {
      "id": "P_RESET_MIDSCALE",
      "observable_contract": "When rst is high, vctrl resets to the midpoint of vmin and vmax and metric is 0.45 V.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "up",
        "dn",
        "vctrl",
        "metric"
      ]
    },
    {
      "id": "P_UP_ONLY_STEP",
      "observable_contract": "A rising clock crossing sampling up high and dn low increases vctrl by step and encodes metric at 0.75 V.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "up",
        "dn",
        "vctrl",
        "metric"
      ]
    },
    {
      "id": "P_DN_ONLY_STEP",
      "observable_contract": "A rising clock crossing sampling dn high and up low decreases vctrl by step and encodes metric at 0.15 V.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "up",
        "dn",
        "vctrl",
        "metric"
      ]
    },
    {
      "id": "P_HOLD_CASES",
      "observable_contract": "A rising clock crossing sampling both or neither request holds vctrl and encodes metric at 0.45 V.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "up",
        "dn",
        "vctrl",
        "metric"
      ]
    },
    {
      "id": "P_CONTROL_CLAMP",
      "observable_contract": "Repeated sampled movement cannot drive vctrl below vmin or above vmax.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "up",
        "dn",
        "vctrl",
        "metric"
      ]
    },
    {
      "id": "P_SAMPLED_HOLD",
      "observable_contract": "Changes on up or dn between rising clock crossings do not immediately change vctrl.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "up",
        "dn",
        "vctrl",
        "metric"
      ]
    }
