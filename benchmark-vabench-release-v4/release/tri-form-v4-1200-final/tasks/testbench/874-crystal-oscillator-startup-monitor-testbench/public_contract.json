  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_ENABLE_IS",
      "observable_contract": "On reset or when `enable` is low, clear oscillator amplitude, `osc_out`, `valid`, and `startup_done`.",
      "required_signals": [
        "time",
        "enable",
        "rst",
        "clk_ref",
        "osc_out",
        "amp_metric",
        "valid",
        "startup_done"
      ]
    },
    {
      "id": "P_INCREASE_A_BEHAVIORAL_AMPLITUDE_STATE_BY",
      "observable_contract": "Increase a behavioral amplitude state by `amp_step` on each rising `clk_ref` edge while enabled until `amp_target` is reached.",
      "required_signals": [
        "time",
        "enable",
        "rst",
        "clk_ref",
        "osc_out",
        "amp_metric",
        "valid",
        "startup_done"
      ]
    },
    {
      "id": "P_CLAMP_THE_AMPLITUDE_AT_AMP_TARGET",
      "observable_contract": "Clamp the amplitude at `amp_target` and expose it on `amp_metric`.",
      "required_signals": [
        "time",
        "enable",
        "rst",
        "clk_ref",
        "osc_out",
        "amp_metric",
        "valid",
        "startup_done"
      ]
    },
    {
      "id": "P_TOGGLE_OSC_OUT_FROM_CLK_REF",
      "observable_contract": "Toggle `osc_out` from `clk_ref` only after the amplitude state is nonzero.",
      "required_signals": [
        "time",
        "enable",
        "rst",
        "clk_ref",
        "osc_out",
        "amp_metric",
        "valid",
        "startup_done"
      ]
    },
    {
      "id": "P_ASSERT_STARTUP_DONE_WHEN_AMP_METRIC",
      "observable_contract": "Assert `startup_done` when `amp_metric` reaches `amp_target`.",
      "required_signals": [
        "time",
        "enable",
        "rst",
        "clk_ref",
        "osc_out",
        "amp_metric",
        "valid",
        "startup_done"
      ]
    },
    {
      "id": "P_ASSERT_VALID_AFTER_TWO_CONSECUTIVE_SLICED",
      "observable_contract": "Assert `valid` after two consecutive sliced oscillator periods after startup is done.",
      "required_signals": [
        "time",
        "enable",
        "rst",
        "clk_ref",
        "osc_out",
        "amp_metric",
        "valid",
        "startup_done"
      ]
    }
