        "valid"
      ]
    },
    {
      "id": "P_ON_EACH_ENABLED_RISING_CLK_EDGE",
      "observable_contract": "On each enabled rising `clk` edge, decode `bw_1..bw_0` as a bandwidth setting.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "bw_1",
        "bw_0",
        "vout",
        "bandwidth_metric",
        "valid"
      ]
    },
    {
      "id": "P_UPDATE_VOUT_AS_A_FIRST_ORDER",
      "observable_contract": "Update `vout` as a first-order discrete-time low-pass response to `vin`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "bw_1",
        "bw_0",
        "vout",
        "bandwidth_metric",
        "valid"
      ]
    },
    {
      "id": "P_HIGHER_BANDWIDTH_CODE_MUST_MOVE_VOUT",
      "observable_contract": "Higher bandwidth code must move `vout` closer to `vin` per update.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "bw_1",
        "bw_0",
        "vout",
        "bandwidth_metric",
        "valid"
      ]
    },
    {
      "id": "P_EXPOSE_THE_ACTIVE_BANDWIDTH_CODE_ON",
      "observable_contract": "Expose the active bandwidth code on `bandwidth_metric` and assert `valid` after the first update.",
