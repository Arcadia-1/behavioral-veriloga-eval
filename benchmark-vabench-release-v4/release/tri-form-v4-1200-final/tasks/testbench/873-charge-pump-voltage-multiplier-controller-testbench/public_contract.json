  "properties": [
    {
      "id": "P_RESET_DISABLE_CLEAR",
      "observable_contract": "Reset clears vout, pump control, readiness, and regulation state; disabled operation suppresses pumping.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "target",
        "vout",
        "phase_a",
        "phase_b",
        "pump_en",
        "regulation_error",
        "ready"
      ]
    },
    {
      "id": "P_NONOVERLAP_PHASES",
      "observable_contract": "Enabled clock updates alternate phase_a and phase_b while never asserting both phases together.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "target",
        "vout",
        "phase_a",
        "phase_b",
        "pump_en",
        "regulation_error",
        "ready"
      ]
    },
    {
      "id": "P_PUMP_REGULATION",
      "observable_contract": "While pump_en is active, enabled phase updates raise vout in bounded pump steps; without pumping, vout leaks downward and remains within rails.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "target",
        "vout",
        "phase_a",
        "phase_b",
        "pump_en",
        "regulation_error",
        "ready"
      ]
    },
    {
      "id": "P_ERROR_REPORTING",
      "observable_contract": "regulation_error continuously reports target minus vout and pump_en requests pumping below the lower tolerance boundary.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "target",
        "vout",
        "phase_a",
        "phase_b",
        "pump_en",
        "regulation_error",
        "ready"
      ]
    },
    {
      "id": "P_READY_QUALIFICATION",
      "observable_contract": "Ready asserts only after three consecutive enabled clock updates within the regulation tolerance and clears outside qualification.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "target",
        "vout",
        "phase_a",
        "phase_b",
        "pump_en",
        "regulation_error",
        "ready"
      ]
    }
  ],
