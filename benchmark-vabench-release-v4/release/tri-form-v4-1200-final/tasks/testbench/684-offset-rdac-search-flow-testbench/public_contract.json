        "vrefp"
      ]
    },
    {
      "id": "P_OFFSET_SEARCH_BISECTION",
      "observable_contract": "The eight offset-search clocks compare consecutive directions, halve the search step on direction changes, and update `vin/vref` with the declared polarity.",
