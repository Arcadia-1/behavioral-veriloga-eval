      ]
    },
    {
      "id": "P_ON_EACH_RISING_CLK_EDGE_WITH",
      "observable_contract": "On each rising `clk` edge with `sample_en` high, capture `vin` into `vhold`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "sample_en",
        "vhold",
        "aperture_metric",
        "valid"
      ]
    },
    {
      "id": "P_THE_APERTURE_METRIC_AFTER_A_CAPTURE",
      "observable_contract": "The aperture metric after a capture is proportional to the absolute difference between the new sample and the previous held sample.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "sample_en",
        "vhold",
        "aperture_metric",
        "valid"
      ]
    },
    {
      "id": "P_HOLD_VHOLD_AND_THE_LAST_METRIC",
      "observable_contract": "Hold `vhold` and the last metric between enabled sampling events.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "sample_en",
        "vhold",
        "aperture_metric",
        "valid"
      ]
    },
    {
      "id": "P_VALID_IS_HIGH_AFTER_THE_FIRST",
      "observable_contract": "`valid` is high after the first enabled sample and low during reset.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "sample_en",
        "vhold",
        "aperture_metric",
        "valid"
