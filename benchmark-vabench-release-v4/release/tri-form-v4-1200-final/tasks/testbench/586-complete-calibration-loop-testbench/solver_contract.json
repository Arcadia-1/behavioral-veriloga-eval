orm":"testbench","modeling_constraints":["Use deterministic rising-edge sampled closed-loop calibration state.","Use bounded state and smoothed voltage contributions only.","Do not use current contributions, transistor-level devices, continuous-time operators, AC/noise analysis, or validation side channels."],"properties":[{"id":"P_RESET_TO_TARGET","observable_contract":"Active-high reset initializes out, trim_mon, residual_mon, and metric to their target-state values.","required_signals":["time","clk","rst","vin","out","metric","trim_mon","residual_mon"]},{"id":"P_CLOCKED_LOOP_UPDATE","observable_contract":"After reset releases, calibration state updates on rising clk crossings and holds between updates.","required_signals":["time","clk","rst","vin","out","metric","trim_mon","residual_mon"]},{"id":"P_RESIDUAL_OBSERVATION","observable_contract":"Residual_mon exposes clamp(target + raw_error + (trim_mon_next - target), vmin, vmax), where raw_error is V(vin)-target and trim_mon_next is the current edge's bounded negative-feedback trim update.","required_signals":["time","clk","rst","vin","out","metric","trim_mon","residual_mon"]},{"id":"P_NEGATIVE_FEEDBACK_DIRECTION","observable_contract":"The trim correction uses trim_mon_next = clamp(trim_mon - loop_gain * residual_before_update, vmin, vmax), so positive residual decreases trim and negative residual increases trim.","required_signals":["time","clk","rst","vin","out","metric","trim_mon","residual_mon"]},{"id":"P_PLANT_CONVERGENCE","observable_contract":"Out follows out_next = clamp(out + plant_alpha * (residual_mon_next - out), vmin, vmax) on each non-reset update.","required_signals":["time","clk","rst","vin","out","metric","trim_mon","residual_mon"]},{"id":"P_BOUNDS_AND_METRIC","observable_contract":"Bounded analog states remain within vmin through vmax, while metric equals clamp(0.9 - 1.5 * abs(out-target), 0.0, 0.9) after each update.","required_signals":["time","clk","rst","vin","out","metric","trim_mon","residual_mon"]}],"schema_version":"v4-solver-contract-v1","security_policy":{"allowed_include_paths":["./dut/complete_calibration_loop.va"],"candidate_artifacts":["testbench.scs"],"forbidden_rules":["undeclared_include","absolute_path","path_traversal","process_execution","network_access","simulator_scripting_escape","dut_redefinition","direct_dut_output_drive","private_hierarchical_probe","unbounded_resource_use"],"limits":{"max_analyses":1,"max_candidate_bytes":1000000,"max_cpu_time_s":120,"max_memory_mb":2048,"max_output_bytes":100000000,"max_saved_signals":64,"max_stop_time_s":1.0,"max_wall_time_s":180},"rejection_outcome":"invalid_run","required_rules":["declared_dut_binding","transient_analysis","all_required_public_traces"],"schema_version":"v4-testbench-security-policy-v2"},"submission_contract":{"agentic_submission_root":"public/submission","exact_declared_file_set_required":true,"target_artifacts_relative_to":"submission_root"},"supplied_inputs":{"dut_instances":[{"connections":[{"net":"clk","port_ref":"clk","position":0},{"net":"rst","port_ref":"rst","position":1},{"net":"vin","port_ref":"vin","position":2},{"net":"out","port_ref":"out","position":3},{"net":"metric","port_ref":"metric","position":4},{"net":"trim_mon","port_ref":"trim_mon","position":5},{"net":"residual_mon","port_ref":"residual_mon","position":6}],"module_ref":"complete_calibration_loop","name":"XDUT","ordered_nets":["clk","rst","vin","out","metric","trim_mon","residual_mon"],"public_output_nets":["out","metric","trim_mon","residual_mon"]}],"read_only_dut_artifacts":[{"public_input_path":"supplied_dut/complete_calibration_loop.va","testbench_include_path":"./dut/complete_calibration_loop.va"}],"read_only_support_artifacts":[]},"target_artifacts":["testbench.scs"],"task_id":"v4-586","title":"Complete Calibration Loop","trace_contract":{"required_signals":["time","clk","rst","vin","out","metric","trim_mon","residual_mon"]}}
