  "properties": [
    {
      "id": "P_PHASE_RAMP",
      "observable_contract": "Within each period, phase_out rises linearly from VSS toward VDD as normalized phase advances from zero toward one.",
      "required_signals": [
        "time",
        "guard_out",
        "phase_out",
        "VDD",
        "VSS"
      ]
    },
    {
      "id": "P_PHASE_WRAP",
      "observable_contract": "At each period boundary, phase_out wraps from the end of the ramp back to VSS and begins the next ramp.",
      "required_signals": [
        "time",
        "guard_out",
        "phase_out",
        "VDD",
        "VSS"
      ]
    },
    {
      "id": "P_GUARD_WINDOW",
      "observable_contract": "guard_out is at VDD during the first min(pulse_w, period) seconds of each period.",
      "required_signals": [
        "time",
        "guard_out",
        "phase_out",
        "VDD",
        "VSS"
      ]
    },
    {
      "id": "P_GUARD_LOW",
      "observable_contract": "If pulse_w is less than period, guard_out remains at VSS after the guard window and before the next period boundary; if pulse_w is greater than or equal to period, guard_out has no low remainder in that period.",
      "required_signals": [
        "time",
        "guard_out",
        "phase_out",
        "VDD",
        "VSS"
      ]
    },
    {
      "id": "P_RAIL_TRACKING",
      "observable_contract": "Both outputs derive their low and high endpoints from the observed VSS and VDD rails rather than fixed absolute voltages.",
      "required_signals": [
        "time",
        "guard_out",
        "phase_out",
        "VDD",
        "VSS"
      ]
    },
    {
      "id": "P_PERIODICITY",
      "observable_contract": "The ramp-wrap and guard-window pattern repeats every period with guard transitions smoothed by tedge.",
      "required_signals": [
        "time",
        "guard_out",
        "phase_out",
        "VDD",
        "VSS"
      ]
    }
  ],
