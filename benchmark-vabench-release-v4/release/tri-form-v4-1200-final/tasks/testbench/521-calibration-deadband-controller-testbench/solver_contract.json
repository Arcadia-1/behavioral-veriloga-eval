{"artifact_contract":{"files":[{"modules":[{"depends_on":[],"name":"calibration_deadband_controller","parameters":[{"default":1e-10,"name":"tr","override_behavior":"sets output transition smoothing","type":"real","units":"s","valid_range":"tr > 0"},{"default":0.45,"name":"vth","override_behavior":"sets clk and rst logic threshold","type":"real","units":"V","valid_range":"finite real"},{"default":0.45,"name":"target","override_behavior":"sets initial, reset, and zero-error trim target","type":"real","units":"V","valid_range":"vmin <= target <= vmax"},{"default":0.05,"name":"deadband","override_behavior":"sets the symmetric no-update error interval","type":"real","units":"V","valid_range":"deadband >= 0"},{"default":0.06,"name":"step_size","override_behavior":"sets trim increment or decrement per accepted update","type":"real","units":"V","valid_range":"step_size > 0"},{"default":0.05,"name":"vmin","override_behavior":"sets lower output clamp","type":"real","units":"V","valid_range":"vmin <= target and vmin < vmax"},{"default":0.85,"name":"vmax","override_behavior":"sets upper output clamp","type":"real","units":"V","valid_range":"vmax >= target and vmax > vmin"}],"ports":[{"direction":"input","discipline":"electrical","name":"clk","position":0},{"direction":"input","discipline":"electrical","name":"rst","position":1},{"direction":"input","discipline":"electrical","name":"vin","position":2},{"direction":"output","discipline":"electrical","name":"out","position":3},{"direction":"output","discipline":"electrical","name":"metric","position":4}],"role":"entry"}],"path":"calibration_deadband_controller.va"}],"mode":"single_file"},"evaluation_summary":{"anonymous_negative_cases":5,"full_credit":"valid candidate and reference pass and all five negatives killed behaviorally","reference_cases":1},"family_id":"021","form":"testbench","modeling_constraints":["Use deterministic rising-edge sampled state updates.","Use voltage contributions only.","Do not use current contributions, transistor-level devices, AC/noise analysis, or validation side channels."],"properties":[{"id":"P_INITIAL_AND_RESET_TARGET","observable_contract":"Out initializes to target and returns to target while rst is above vth; metric is low during reset.","required_signals":["time","clk","rst","vin","out","metric"]},{"id":"P_POSITIVE_ERROR_STEP","observable_contract":"At a rising clock crossing with vin minus target greater than deadband, out increases by one step_size and metric goes high.","required_signals":["time","clk","rst","vin","out","metric"]},{"id":"P_NEGATIVE_ERROR_STEP","observable_contract":"At a rising clock crossing with vin minus target less than negative deadband, out decreases by one step_size and metric goes high.","required_signals":["time","clk","rst","vin","out","metric"]},{"id":"P_DEADBAND_HOLD","observable_contract":"At a rising clock crossing with signed error inside the inclusive deadband, out holds and metric remains low.","required_signals":["time","clk","rst","vin","out","metric"]},{"id":"P_OUTPUT_CLAMP","observable_contract":"Repeated updates cannot drive out below vmin or above vmax.","required_signals":["time","clk","rst","vin","out","metric"]},{"id":"P_BETWEEN_EDGE_HOLD","observable_contract":"Out state does not follow vin between rising clock crossings.","required_signals":["time","clk","rst","vin","out","metric"]}],"schema_version":"v4-solver-contract-v1","security_policy":{"allowed_include_paths":["./dut/calibration_deadband_controller.va"],"candidate_artifacts":["testbench.scs"],"forbidden_rules":["undeclared_include","absolute_path","path_traversal","process_execution","network_access","simulator_scripting_escape","dut_redefinition","direct_dut_output_drive","private_hierarchical_probe","unbounded_resource_use"],"limits":{"max_analyses":1,"max_candidate_bytes":1000000,"max_cpu_time_s":120,"max_memory_mb":2048,"max_output_bytes":100000000,"max_saved_signals":64,"max_stop_time_s":1.0,"max_wall_time_s":180},"rejection_outcome":"invalid_