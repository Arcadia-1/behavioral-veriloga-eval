        "div_clk",
        "freq_metric"
      ]
    },
    {
      "id": "P_RESTART_MONOTONICITY",
      "observable_contract": "Enable restarts both clocks low with the first DCO rise one half-period later, and larger frequency words produce nondecreasing edge counts.",
