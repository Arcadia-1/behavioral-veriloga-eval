    "Do not add undeclared ports, artifacts, or validation-only timing hooks."
  ],
  "properties": [
    {
      "id": "P_RISING_SELECTION",
      "observable_contract": "When rise_en is above vth, each rising crossing of sig through vth produces one output pulse.",
      "required_signals": [
        "time",
        "sig",
        "rise_en",
        "pulse"
      ]
    },
    {
      "id": "P_FALLING_SELECTION",
      "observable_contract": "When rise_en is below vth, each falling crossing of sig through vth produces one output pulse.",
      "required_signals": [
        "time",
        "sig",
        "rise_en",
        "pulse"
      ]
    },
    {
      "id": "P_OPPOSITE_EDGE_REJECTION",
      "observable_contract": "An edge opposite to the polarity selected by rise_en does not produce a pulse.",
      "required_signals": [
        "time",
        "sig",
        "rise_en",
        "pulse"
      ]
    },
    {
      "id": "P_BOUNDED_PULSE",
      "observable_contract": "Each detected edge produces a bounded short pulse with nominal width about 2 ns rather than a latched high level.",
      "required_signals": [
        "time",
        "sig",
        "rise_en",
        "pulse"
      ]
    },
    {
      "id": "P_OUTPUT_LEVELS",
      "observable_contract": "pulse uses 0 V and vdd levels with finite transition smoothing set by tr.",
      "required_signals": [
        "time",
        "sig",
        "rise_en",
        "pulse"
      ]
    }
