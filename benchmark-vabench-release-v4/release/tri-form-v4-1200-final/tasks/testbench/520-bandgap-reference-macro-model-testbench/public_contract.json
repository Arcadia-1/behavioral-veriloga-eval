    {
      "id": "P_CLOCKED_FIRST_ORDER_SETTLING",
      "observable_contract": "On eligible rising clock crossings, the held reference advances by 0.35 of the remaining error to the clamped line-corrected target.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_TARGET_AND_OUTPUT_CLAMPS",
      "observable_contract": "The line-corrected target is clamped to 0 through vin minus 0.05 V, and driven out remains within 0 through 0.9 V.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_VALIDITY_ENCODING",
      "observable_contract": "Metric is 0 V in reset or brownout, 0.2 V during startup below the 0.48 V validity threshold, and 0.9 V after the held reference exceeds it.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_CLOCKED_HOLD",
      "observable_contract": "Above startup, the reference state changes only on rising clock crossings and holds between samples.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
