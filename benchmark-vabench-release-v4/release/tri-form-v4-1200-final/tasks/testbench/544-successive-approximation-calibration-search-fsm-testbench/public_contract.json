  "properties": [
    {
      "id": "P_RESET_SEARCH_STATE",
      "observable_contract": "Active reset restores out to target, the current step to step_init, the cycle count to zero, and metric low.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_SIGNED_TRIAL_UPDATE",
      "observable_contract": "On each active rising clk update before completion, vin above target increases out by the current step and vin below target decreases it.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_SUCCESSIVE_STEP_HALVING",
      "observable_contract": "The current step halves after every active decision update, yielding the public successive-approximation sequence from step_init.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_FOUR_STEP_DONE",
      "observable_contract": "Metric asserts after four active search updates and subsequent rising clocks hold the completed trial state until reset.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_TRIM_CLAMP",
      "observable_contract": "Out remains within vmin through vmax for every trial update.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    }
  ],
