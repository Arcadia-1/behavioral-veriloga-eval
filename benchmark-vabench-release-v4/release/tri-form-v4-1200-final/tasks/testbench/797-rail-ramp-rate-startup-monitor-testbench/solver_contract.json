led rail level above which settling qualification is","required_signals":["time","clk","en","rail_ok","ramp_ok","slew_metric","startup_ready","vdd","vss"]}],"schema_version":"v4-solver-contract-v1","security_policy":{"allowed_include_paths":["./dut/rail_ramp_rate_startup_monitor.va"],"candidate_artifacts":["testbench.scs"],"forbidden_rules":["undeclared_include","absolute_path","path_traversal","process_execution","network_access","simulator_scripting_escape","dut_redefinition","direct_dut_output_drive","private_hierarchical_probe","unbounded_resource_use"],"limits":{"max_analyses":1,"max_candidate_bytes":1000000,"max_cpu_time_s":120,"max_memory_mb":2048,"max_output_bytes":100000000,"max_saved_signals":64,"max_stop_time_s":1.0,"max_wall_time_s":180},"rejection_outcome":"invalid_run","required_rules":["declared_dut_binding","transient_analysis","all_required_public_traces"],"schema_version":"v4-testbench-security-policy-v2"},"submission_contract":{"agentic_submission_root":"public/submission","exact_declared_file_set_required":true,"target_artifacts_relative_to":"submission_root"},"supplied_inputs":{"dut_instances":[{"connections":[{"net":"clk","port_ref":"clk","position":0},{"net":"vdd","port_ref":"vdd","position":1},{"net":"vss","port_ref":"vss","position":2},{"net":"en","port_ref":"en","position":3},{"net":"rail_ok","port_ref":"rail_ok","position":4},{"net":"ramp_ok","port_ref":"ramp_ok","position":5},{"net":"startup_ready","port_ref":"startup_ready","position":6},{"net":"slew_metric","port_ref":"slew_metric","position":7}],"module_ref":"rail_ramp_rate_startup_monitor","name":"XDUT","ordered_nets":["clk","vdd","vss","en","rail_ok","ramp_ok","startup_ready","slew_metric"],"public_output_nets":["rail_ok","ramp_ok","startup_ready","slew_metric"]}],"read_only_dut_artifacts":[{"public_input_path":"supplied_dut/rail_ramp_rate_startup_monitor.va","testbench_include_path":"./dut/rail_ramp_rate_startup_monitor.va"}],"read_only_support_artifacts":[]},"target_artifacts":["te