  "properties": [
    {
      "id": "P_ON_EACH_RISING_CROSSING_OF_CLK",
      "observable_contract": "On each rising crossing of `clk` through `vth`, sample `d1..d6` and decode an unsigned 6-bit code with weights `32, 16, 8, 4, 2, 1`. Hold the decoded output until the next rising clock event. Map the sampled code to a bipolar 1.8 V mid-rise level:",
      "required_signals": [
        "time",
        "clk",
        "d1",
        "d2",
        "d3",
        "d4",
        "d5",
        "d6",
        "vout"
      ]
    },
    {
      "id": "P_TEXT_VOUT_CODE_0_5_3",
      "observable_contract": "```text vout = (code + 0.5) * 3.6 / 64 - 1.8 ```",
      "required_signals": [
        "time",
        "clk",
        "d1",
        "d2",
        "d3",
        "d4",
        "d5",
        "d6",
        "vout"
      ]
    },
    {
      "id": "P_THE_ALL_ZERO_CODE_THEREFORE_PRODUCES",
      "observable_contract": "The all-zero code therefore produces the lowest half-LSB-centered negative level, and the all-one code produces the highest half-LSB-centered positive level.",
      "required_signals": [
        "time",
        "clk",
        "d1",
        "d2",
        "d3",
        "d4",
        "d5",
        "d6",
        "vout"
      ]
    }
  ],
