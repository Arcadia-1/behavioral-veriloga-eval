  ],
  "properties": [
    {
      "id": "P_SUPPLY_AND_ENABLE_MONITORS",
      "observable_contract": "Supply_ok is 0.9 V exactly when vdd_in exceeds 0.32 V, while enable_mon is 0.9 V exactly when en exceeds vth.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vdd_in",
        "en",
        "out",
        "metric",
        "supply_ok",
        "enable_mon",
        "state_mon",
        "startup_mon"
      ]
    },
    {
      "id": "P_RESET_OR_BROWNOUT",
      "observable_contract": "Active reset or a bad supply clears out, metric, startup progress, and state; a supply dip also removes valid status.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vdd_in",
        "en",
        "out",
        "metric",
        "supply_ok",
        "enable_mon",
        "state_mon",
        "startup_mon"
      ]
    },
    {
      "id": "P_DISABLED_REFERENCE",
      "observable_contract": "With supply good and enable low, out is 0.05 V, metric is 0.1 V, startup progress is cleared, and state_mon represents state 1.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vdd_in",
        "en",
        "out",
        "metric",
        "supply_ok",
        "enable_mon",
        "state_mon",
        "startup_mon"
      ]
    },
    {
      "id": "P_ENABLED_SETTLING",
      "observable_contract": "On each rising clk crossing with supply good and enable high, out advances by 0.32 times its remaining error to 0.55 V and the startup count increments up to 8.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vdd_in",
        "en",
        "out",
        "metric",
        "supply_ok",
        "enable_mon",
        "state_mon",
        "startup_mon"
      ]
    },
    {
      "id": "P_STARTUP_VALIDITY",
      "observable_contract": "During enabled startup metric is 0.25 V and state is 2; after at least five enabled updates with out above 0.48 V, metric is 0.9 V and state is 3.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vdd_in",
        "en",
        "out",
        "metric",
        "supply_ok",
        "enable_mon",
        "state_mon",
        "startup_mon"
      ]
    },
    {
      "id": "P_BROWNOUT_RECOVERY",
      "observable_contract": "After a supply dip and restoration with enable asserted, the output and monitors repeat the same startup sequence before returning valid.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vdd_in",
        "en",
        "out",
        "metric",
        "supply_ok",
        "enable_mon",
        "state_mon",
        "startup_mon"
      ]
    }
