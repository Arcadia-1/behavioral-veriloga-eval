  "modeling_constraints": [
    "AMS role: deterministic jittered clock stimulus source for repeatable timing-margin and aperture-stress checks.",
    "Use deterministic timer-driven state and no random distribution functions.",
    "Decode seed inputs only through vth and preserve repeatability for identical input histories.",
    "Do not add undeclared ports, random state, or validation-only timing cases."
  ],
  "properties": [
    {
      "id": "P_NOMINAL_CLOCK",
      "observable_contract": "With jitter_en below vth, clk_out has a constant 10 ns half-period and 20 ns full period.",
      "required_signals": [
        "time",
        "jitter_en",
        "seed0",
        "seed1",
        "seed2",
        "seed3",
        "seed4",
        "seed5",
        "seed6",
        "seed7",
        "clk_out"
      ]
    },
    {
      "id": "P_SEED_DECODE",
      "observable_contract": "Seed7:seed0 is sampled through vth only at each output transition and interpreted as one unsigned eight-bit seed with seed7 as MSB; seed changes affect the next scheduled half-period, not the already scheduled current edge.",
      "required_signals": [
        "time",
        "jitter_en",
        "seed0",
        "seed1",
        "seed2",
        "seed3",
        "seed4",
        "seed5",
        "seed6",
        "seed7",
        "clk_out"
      ]
    },
    {
      "id": "P_EDGE_MODULATION",
      "observable_contract": "For edge index k, the next half-period is 10 ns plus (((seed + 3*k) modulo 5) minus 2) times 0.8 ns.",
      "required_signals": [
        "time",
        "jitter_en",
        "seed0",
        "seed1",
        "seed2",
        "seed3",
        "seed4",
        "seed5",
        "seed6",
        "seed7",
        "clk_out"
      ]
    },
    {
      "id": "P_REPEATABILITY",
      "observable_contract": "With constant seed and enable history, the modulo-5 half-period sequence repeats every five output transitions; identical input histories also produce the same edge-time sequence on repeated runs.",
      "required_signals": [
        "time",
        "jitter_en",
        "seed0",
        "seed1",
        "seed2",
        "seed3",
        "seed4",
        "seed5",
        "seed6",
        "seed7",
        "clk_out"
      ]
    },
    {
      "id": "P_TIMING_BOUNDS",
      "observable_contract": "Every jitter-enabled half-period remains within the public modulation range from 8.4 ns through 11.6 ns.",
      "required_signals": [
        "time",
        "jitter_en",
        "seed0",
        "seed1",
        "seed2",
        "seed3",
        "seed4",
        "seed5",
        "seed6",
        "seed7",
        "clk_out"
      ]
    },
    {
      "id": "P_OUTPUT_LEVELS",
      "observable_contract": "clk_out uses 0 V and vdd levels with finite transition smoothing set by tr.",
      "required_signals": [
        "time",
        "jitter_en",
        "seed0",
        "seed1",
        "seed2",
        "seed3",
        "seed4",
        "seed5",
        "seed6",
        "seed7",
        "clk_out"
      ]
    }
  ],
