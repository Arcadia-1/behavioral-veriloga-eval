  ],
  "properties": [
    {
      "id": "P_RESET_DISABLE_CLEAR",
      "observable_contract": "Reset or disabled operation clears PWM, duty metric, soft reference, and power-good.",
      "required_signals": [
        "time",
        "vfb",
        "vref",
        "clk",
        "rst",
        "enable",
        "pwm",
        "duty_metric",
        "soft_ref",
        "pgood"
      ]
    },
    {
      "id": "P_SOFT_START_TRACKING",
      "observable_contract": "At enabled rising clock edges soft_ref moves toward vref by the configured soft-step and never overshoots the target.",
      "required_signals": [
        "time",
        "vfb",
        "vref",
        "clk",
        "rst",
        "enable",
        "pwm",
        "duty_metric",
        "soft_ref",
        "pgood"
      ]
    },
    {
      "id": "P_DUTY_DIRECTION_BOUNDS",
      "observable_contract": "The duty metric increases when vfb is below soft_ref, decreases otherwise, and remains within the configured duty bounds.",
      "required_signals": [
        "time",
        "vfb",
        "vref",
        "clk",
        "rst",
        "enable",
        "pwm",
        "duty_metric",
        "soft_ref",
        "pgood"
      ]
    },
    {
      "id": "P_PWM_ENCODING",
      "observable_contract": "PWM high samples are rail-valid and their enabled-cycle activity is consistent with a nonzero bounded duty command.",
      "required_signals": [
        "time",
        "vfb",
        "vref",
        "clk",
        "rst",
        "enable",
        "pwm",
        "duty_metric",
        "soft_ref",
        "pgood"
      ]
    },
    {
      "id": "P_POWER_GOOD_QUALIFICATION",
      "observable_contract": "Power-good asserts only after three consecutive enabled clock updates with vfb within pgood_tol of vref and clears when qualification is lost.",
      "required_signals": [
        "time",
        "vfb",
        "vref",
        "clk",
        "rst",
        "enable",
        "pwm",
        "duty_metric",
        "soft_ref",
        "pgood"
      ]
    }
  ],
