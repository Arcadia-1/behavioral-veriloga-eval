        "time",
        "vctrl",
        "phase",
        "clk"
      ]
    },
    {
      "id": "P_WRAP_TOGGLES_CLOCK",
      "observable_contract": "Each phase wrap by one cycle toggles the voltage-coded clock between 0 V and 0.9 V.",
      "required_signals": [
        "time",
        "vctrl",
        "phase",
        "clk"
      ]
    },
    {
      "id": "P_CONTROLLED_EDGE_RATE",
      "observable_contract": "A sustained higher vctrl produces more clock toggles over the same observation interval than a sustained lower vctrl.",
