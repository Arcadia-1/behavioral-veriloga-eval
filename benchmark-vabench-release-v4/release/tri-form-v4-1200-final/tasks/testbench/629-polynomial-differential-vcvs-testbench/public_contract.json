      "id": "P_HALF_SWING_SPLIT",
      "observable_contract": "Divide the polynomial result by two and drive `outp = vcmo + limited_vod`, `outn = vcmo - limited_vod`.",
      "required_signals": [
        "time",
        "inn",
        "inp",
        "outn",
        "outp"
      ]
    },
    {
      "id": "P_SYMMETRIC_SATURATION",
      "observable_contract": "Limit the half-swing to the inclusive interval `[-vsat, vsat]` before driving both outputs.",
