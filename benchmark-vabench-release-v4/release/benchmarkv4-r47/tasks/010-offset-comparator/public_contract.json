  "properties": [
    {
      "id": "P_RISING_EDGE_SAMPLE",
      "observable_contract": "OUT_P updates only on CLK rising crossings through the local rail midpoint.",
      "required_signals": [
        "time",
        "VDD",
        "VSS",
        "CLK",
        "VINP",
        "VINN",
        "OUT_P"
      ]
    },
    {
      "id": "P_OFFSET_DECISION",
      "observable_contract": "OUT_P latches high only when VINP relative to VINN is greater than the positive vos threshold.",
      "required_signals": [
        "time",
        "CLK",
        "VINP",
        "VINN",
        "OUT_P"
      ]
    },
    {
      "id": "P_LATCH_HOLD",
      "observable_contract": "OUT_P holds its sampled decision between rising clock edges.",
      "required_signals": [
        "time",
        "CLK",
        "VINP",
        "VINN",
        "OUT_P"
      ]
    },
    {
      "id": "P_RAIL_REFERENCE",
      "observable_contract": "OUT_P low and high levels track VSS and VDD respectively with finite smoothing.",
      "required_signals": [
        "time",
        "VDD",
        "VSS",
        "OUT_P"
      ]
    }
  ],
