  ],
  "properties": [
    {
      "id": "P_POSITIVE_DITHER",
      "observable_contract": "When DPN is above vth, the output differential exceeds the input differential by DITHER_AMP.",
      "required_signals": [
        "time",
        "vres_p",
        "vres_n",
        "dpn",
        "vout_p",
        "vout_n"
      ]
    },
    {
      "id": "P_NEGATIVE_DITHER",
      "observable_contract": "When DPN is at or below vth, the output differential is lower than the input differential by DITHER_AMP.",
      "required_signals": [
        "time",
        "vres_p",
        "vres_n",
        "dpn",
        "vout_p",
        "vout_n"
      ]
    },
    {
      "id": "P_SYMMETRIC_SPLIT",
      "observable_contract": "Half of the selected differential dither is added to VOUT_P and half is subtracted from VOUT_N.",
      "required_signals": [
        "time",
        "vres_p",
        "vres_n",
        "dpn",
        "vout_p",
        "vout_n"
      ]
    },
    {
      "id": "P_COMMON_MODE_PRESERVATION",
      "observable_contract": "The output pair preserves the input common mode and does not introduce a vdd/2 offset.",
      "required_signals": [
        "time",
        "vres_p",
        "vres_n",
        "vout_p",
        "vout_n"
      ]
    },
    {
      "id": "P_PARAMETER_OVERRIDE",
      "observable_contract": "Legal DITHER_AMP and vth overrides change only dither magnitude and polarity decision as declared.",
      "required_signals": [
        "time",
        "dpn",
        "vres_p",
        "vres_n",
        "vout_p",
        "vout_n"
      ]
    }
