  "form": "dut",
  "identity": {
    "category": "baseband_signal_conditioning",
    "difficulty": "D2",
    "level": "L1",
    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "Precision Rectifier Envelope Detector"
  },
  "modeling_constraints": [
    "Drive rect as a continuous voltage-domain rectified observable and env/metric from event-updated state.",
    "Use voltage contributions only; do not use current contributions, transistor-level devices, or AC/noise behavior.",
    "Do not add validation-only ports, hooks, or simulator-specific side channels."
  ],
  "properties": [
    {
      "id": "P_FULL_WAVE_RECTIFICATION",
      "observable_contract": "Rect equals vcm plus the absolute input deviation from vcm, so equal positive and negative excursions produce equal rectified levels, bounded to 0 V through 0.9 V.",
      "required_signals": [
        "time",
        "vin",
        "rect"
      ]
    },
    {
      "id": "P_RESET_ENVELOPE",
      "observable_contract": "Initialization or a rising clk update with rst active restores env to vcm and clears envelope memory.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "env",
        "metric"
      ]
    },
    {
      "id": "P_PEAK_ATTACK",
      "observable_contract": "At a rising clk update, a rectified value above the stored envelope is acquired immediately as the new env value.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "rect",
        "env"
      ]
    },
    {
      "id": "P_BOUNDED_DECAY",
      "observable_contract": "When rect is below the stored envelope, each rising clk update lowers env by at most decay and never below rect or vcm.",
      "required_signals": [
        "time",
        "clk",
        "rect",
        "env"
      ]
    },
    {
      "id": "P_ENVELOPE_LAG_METRIC",
      "observable_contract": "Metric is high while env exceeds rect by more than 30 mV and low otherwise.",
      "required_signals": [
        "time",
        "rect",
        "env",
        "metric"
      ]
    }
  ],
