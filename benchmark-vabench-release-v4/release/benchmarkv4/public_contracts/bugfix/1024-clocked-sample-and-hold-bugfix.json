      "required_signals": [
        "time",
        "in",
        "clk",
        "out"
      ]
    },
    {
      "id": "P_INTERSAMPLE_HOLD",
      "observable_contract": "OUT retains the most recently sampled value between rising CLK crossings.",
      "required_signals": [
        "time",
        "in",
        "clk",
        "out"
      ]
    },
    {
      "id": "P_NO_HIGH_PHASE_TRACKING",
      "observable_contract": "Changes on IN while CLK remains high do not make OUT transparent before the next rising crossing.",
      "required_signals": [
        "time",
        "in",
        "clk",
        "out"
      ]
    },
    {
      "id": "P_LOCAL_RAIL_REFERENCE",
      "observable_contract": "The held analog voltage is driven as a smooth voltage-domain output referenced to the local VDD and VSS rails.",
