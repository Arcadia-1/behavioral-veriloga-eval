  "properties": [
    {
      "id": "P_RESET_CLEARS_SYMBOL_HISTORY_AND_DRIVES",
      "observable_contract": "Reset clears symbol history and drives all outputs to common mode.",
      "required_signals": [
        "time",
        "data",
        "clk",
        "rst",
        "pre_1",
        "pre_0",
        "post_1",
        "post_0",
        "vout",
        "main_dbg",
        "pre_dbg",
        "post_dbg"
      ]
    },
    {
      "id": "P_ON_EACH_RISING_CLK_SAMPLE_DATA",
      "observable_contract": "On each rising `clk`, sample `data` as +1 for high and -1 for low.",
      "required_signals": [
        "time",
        "data",
        "clk",
        "rst",
        "pre_1",
        "pre_0",
        "post_1",
        "post_0",
        "vout",
        "main_dbg",
        "pre_dbg",
        "post_dbg"
      ]
    },
    {
      "id": "P_DRIVE_MAIN_DBG_PRE_DBG_AND",
      "observable_contract": "Drive `main_dbg`, `pre_dbg`, and `post_dbg` as voltage-coded per-tap contributions around common mode.",
      "required_signals": [
        "time",
        "data",
        "clk",
        "rst",
        "pre_1",
        "pre_0",
        "post_1",
        "post_0",
        "vout",
        "main_dbg",
        "pre_dbg",
        "post_dbg"
      ]
    },
    {
      "id": "P_VOUT_IS_THE_CLIPPED_SUM_OF",
      "observable_contract": "`vout` is the clipped sum of the current main contribution, previous-symbol pre contribution, and older-symbol post contribution.",
      "required_signals": [
        "time",
        "data",
        "clk",
        "rst",
        "pre_1",
        "pre_0",
        "post_1",
        "post_0",
        "vout",
        "main_dbg",
        "pre_dbg",
        "post_dbg"
      ]
    },
    {
      "id": "P_HIGHER_TAP_CONTROL_CODES_MUST_INCREASE",
      "observable_contract": "Higher tap-control codes must increase the corresponding contribution magnitude.",
      "required_signals": [
        "time",
        "data",
        "clk",
        "rst",
        "pre_1",
        "pre_0",
        "post_1",
        "post_0",
        "vout",
        "main_dbg",
        "pre_dbg",
        "post_dbg"
      ]
    }
