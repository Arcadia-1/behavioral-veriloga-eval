  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_CLEAR",
      "observable_contract": "On reset or when disabled, clear limited command, foldback metric, and status.",
      "required_signals": [
        "time",
        "power_cmd",
        "temp_sense",
        "clk",
        "rst",
        "enable",
        "limited_cmd",
        "foldback_metric",
        "thermal_ok"
      ]
    },
    {
      "id": "P_ON_EACH_ENABLED_RISING_CLK_EDGE",
      "observable_contract": "On each enabled rising `clk` edge, compare `temp_sense` against the foldback threshold.",
      "required_signals": [
        "time",
        "power_cmd",
        "temp_sense",
        "clk",
        "rst",
        "enable",
        "limited_cmd",
        "foldback_metric",
        "thermal_ok"
      ]
    },
    {
      "id": "P_PASS_POWER_CMD_THROUGH_WHILE_TEMPERATURE",
      "observable_contract": "Pass `power_cmd` through while temperature is below threshold.",
      "required_signals": [
        "time",
        "power_cmd",
        "temp_sense",
        "clk",
        "rst",
        "enable",
        "limited_cmd",
        "foldback_metric",
        "thermal_ok"
      ]
    },
    {
      "id": "P_REDUCE_LIMITED_CMD_AS_TEMPERATURE_RISES",
      "observable_contract": "Reduce `limited_cmd` as temperature rises above threshold and expose the reduction on `foldback_metric`.",
      "required_signals": [
        "time",
        "power_cmd",
        "temp_sense",
        "clk",
        "rst",
        "enable",
        "limited_cmd",
        "foldback_metric",
        "thermal_ok"
      ]
    },
    {
      "id": "P_ASSERT_THERMAL_OK_ONLY_WHEN_NO",
      "observable_contract": "Assert `thermal_ok` only when no foldback reduction is active.",
      "required_signals": [
        "time",
        "power_cmd",
        "temp_sense",
        "clk",
        "rst",
        "enable",
        "limited_cmd",
        "foldback_metric",
        "thermal_ok"
      ]
    }
  ],
