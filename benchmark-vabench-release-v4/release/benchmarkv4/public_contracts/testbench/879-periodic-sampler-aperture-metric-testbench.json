        "time",
        "vin",
        "clk",
        "rst",
        "sample_en",
        "vhold",
        "aperture_metric",
        "valid"
      ]
    },
    {
      "id": "P_THE_APERTURE_METRIC_AFTER_A_CAPTURE",
      "observable_contract": "The aperture metric after a capture is proportional to the absolute difference between the new sample and the previous held sample.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "sample_en",
        "vhold",
        "aperture_metric",
        "valid"
      ]
    },
    {
      "id": "P_HOLD_VHOLD_AND_THE_LAST_METRIC",
