    "level": "L1",
    "supported_scope": "voltage-domain event-driven transient measurement Verilog-A with a final_step text-metric side effect",
    "title": "Final Step File Metric"
  },
  "modeling_constraints": [
    "Use deterministic rising-crossing count state and a final_step text-metric write.",
    "Smooth only the retained metric target rather than a continuously varying branch expression.",
    "Do not generate waveform or validation artifacts or use current contributions, transistor-level devices, ddt, or idt."
  ],
  "properties": [
    {
      "id": "P_ZERO_INITIAL_STATE",
      "observable_contract": "Before any qualifying ref edge, the event count and metric_out are zero.",
      "required_signals": [
        "time",
        "ref",
        "metric_out"
      ]
    },
    {
      "id": "P_RISING_EDGE_COUNT",
      "observable_contract": "Every rising ref crossing through vth increments the retained event count exactly once; falling crossings do not.",
      "required_signals": [
        "time",
        "ref",
        "metric_out"
      ]
    },
    {
      "id": "P_NORMALIZED_METRIC",
      "observable_contract": "Metric_out equals the VDD-to-VSS rail span multiplied by the retained event count divided by four.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "ref",
        "metric_out"
      ]
    },
    {
      "id": "P_EVENT_UPDATED_OUTPUT",
      "observable_contract": "Metric_out changes only after counted rising events and uses finite transition smoothing of the retained target.",
      "required_signals": [
        "time",
        "ref",
        "metric_out"
      ]
    },
    {
      "id": "P_FINAL_TEXT_RECORD",
      "observable_contract": "At final_step, the module emits one text metric record to candidate.out in the simulator working directory with format count=<integer> metric=<fixed-point to three decimals>.",
      "required_signals": [
        "time",
        "ref",
        "metric_out"
      ]
    }
  ],
