    {
      "id": "P_ON_EACH_ENABLED_RISING_CLK_EDGE",
      "observable_contract": "On each enabled rising `clk` edge, advance `ramp_out` by `ramp_step` and wrap to `vss` at full scale.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "vctrl",
        "ramp_out",
        "pwm_out",
        "cycle_start",
        "duty_metric"
      ]
    },
    {
      "id": "P_CYCLE_START_PULSES_HIGH_FOR_THE",
      "observable_contract": "`cycle_start` pulses high for the clock edge where the ramp wraps.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "vctrl",
        "ramp_out",
        "pwm_out",
        "cycle_start",
        "duty_metric"
      ]
    },
    {
      "id": "P_PWM_OUT_IS_HIGH_WHEN_VCTRL",
      "observable_contract": "`pwm_out` is high when `vctrl` is greater than the current ramp value and low otherwise.",
