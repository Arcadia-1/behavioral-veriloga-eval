  ],
  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_ENABLE_IS",
      "observable_contract": "On reset or while disabled drive vout=vcm, drive the zero-error encoding error_metric=vcm, clear settled to vss, and clear the settle counter.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "error_metric",
        "settled"
      ]
    },
    {
      "id": "P_DECODE_GAIN_2_GAIN_0_INTO",
      "observable_contract": "Poll every tick=250ps, decode code=4*gain_2+2*gain_1+gain_0, and compute target=clamp(vcm+(1+gain_lsb*code)*(vin-vcm),vss,vdd).",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "error_metric",
        "settled"
      ]
    },
    {
      "id": "P_UPDATE_VOUT_ONCE_PER_RISING_CLK",
      "observable_contract": "On each enabled rising clk edge update vout_next=clamp(vout+alpha*(target-vout),vss,vdd) and then error=target-vout_next.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "error_metric",
        "settled"
      ]
    },
    {
      "id": "P_CLAMP_VOUT_TO_THE_RANGE_VSS",
      "observable_contract": "Clamp `vout` to the range `vss` through `vdd`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "error_metric",
        "settled"
      ]
    },
    {
      "id": "P_ERROR_METRIC_MUST_EXPOSE_THE_SIGNED",
      "observable_contract": "Encode target-minus-output error as the vcm-centered public voltage error_metric=vcm+(target-vout_next), so vcm denotes zero error on active updates and during reset or disable.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "error_metric",
        "settled"
      ]
    },
    {
      "id": "P_ASSERT_SETTLED_AFTER_THREE_CONSECUTIVE_UPDATES",
      "observable_contract": "Increment the counter when abs(target-vout_next)<settle_tol, clear it otherwise, and assert settled=vdd at count three.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "error_metric",
        "settled"
      ]
    }
  ],
