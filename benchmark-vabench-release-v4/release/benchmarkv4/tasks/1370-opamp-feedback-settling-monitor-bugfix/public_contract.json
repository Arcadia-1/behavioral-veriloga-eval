      "id": "P_DECODE_GAIN_2_GAIN_0_INTO",
      "observable_contract": "Decode `gain_2..gain_0` into a closed-loop target gain of at least unity.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
