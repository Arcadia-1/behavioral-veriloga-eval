  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_ENABLE_IS",
      "observable_contract": "On reset or when `enable` is low, clear path states, metrics, `valid`, and drive outputs to `vcm`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "i_out",
        "q_out",
        "amp_metric",
        "phase_metric",
        "valid"
      ]
    },
    {
      "id": "P_ON_EACH_RISING_CLK_EDGE_WHILE",
      "observable_contract": "On each rising `clk` edge while enabled, update an in-phase sampled state from `vin`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "i_out",
        "q_out",
        "amp_metric",
        "phase_metric",
        "valid"
      ]
    },
    {
      "id": "P_UPDATE_A_QUADRATURE_SAMPLED_STATE_USING",
      "observable_contract": "Update a quadrature sampled state using the previous in-phase state so the Q output is phase-shifted relative to I.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "i_out",
        "q_out",
        "amp_metric",
        "phase_metric",
        "valid"
      ]
    },
    {
      "id": "P_DRIVE_I_OUT_AND_Q_OUT",
      "observable_contract": "Drive `i_out` and `q_out` around `vcm` from the two path states.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "i_out",
        "q_out",
        "amp_metric",
        "phase_metric",
        "valid"
      ]
    },
    {
      "id": "P_REPORT_A_BOUNDED_PHASE_ORDER_METRIC",
      "observable_contract": "Report a bounded phase/order metric on `phase_metric` and an amplitude-balance metric on `amp_metric`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "i_out",
        "q_out",
        "amp_metric",
        "phase_metric",
        "valid"
      ]
    },
    {
      "id": "P_ASSERT_VALID_AFTER_AT_LEAST_FOUR",
      "observable_contract": "Assert `valid` after at least four enabled sample updates.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "i_out",
        "q_out",
        "amp_metric",
        "phase_metric",
        "valid"
      ]
    }
  ],
