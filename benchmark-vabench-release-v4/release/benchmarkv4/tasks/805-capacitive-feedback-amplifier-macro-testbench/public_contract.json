  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_DRIVE",
      "observable_contract": "On reset or when disabled, drive `vout` to `vcm`, clear `sampled_metric`, and clear `settled`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_1",
        "gain_0",
        "vout",
        "sampled_metric",
        "settled"
      ]
    },
    {
      "id": "P_ON_EACH_RISING_CLK_EDGE_WHILE",
      "observable_contract": "On each rising `clk` edge while enabled, sample `vin` and decode `gain_1..gain_0` as a programmable capacitor ratio.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_1",
        "gain_0",
        "vout",
        "sampled_metric",
        "settled"
      ]
    },
    {
      "id": "P_DRIVE_SAMPLED_METRIC_WITH_THE_HELD",
      "observable_contract": "Drive `sampled_metric` with the held input sample.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_1",
        "gain_0",
        "vout",
        "sampled_metric",
        "settled"
      ]
    },
    {
      "id": "P_MOVE_VOUT_TOWARD_VCM_GAIN_SAMPLE",
      "observable_contract": "Decode `code = (gain_0 > vth ? 1 : 0) + 2*(gain_1 > vth ? 1 : 0)` and `gain = 1.0 + gain_step*code`; on each accepted edge drive `vout = clamp(vcm + gain*(sample - vcm), vss, vdd)` without an additional slew step.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_1",
        "gain_0",
        "vout",
        "sampled_metric",
        "settled"
      ]
    },
    {
      "id": "P_ASSERT_SETTLED_AFTER_THE_OUTPUT_HAS",
      "observable_contract": "Assert `settled` after the output has stayed within `settle_tol` of the target for two enabled updates.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_1",
        "gain_0",
        "vout",
        "sampled_metric",
        "settled"
      ]
    },
    {
      "id": "P_USE_ONLY_VOLTAGE_DOMAIN_BEHAVIORAL_STATE",
      "observable_contract": "Use only voltage-domain behavioral state and voltage contributions on public electrical outputs.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_1",
        "gain_0",
        "vout",
        "sampled_metric",
        "settled"
      ]
    }
