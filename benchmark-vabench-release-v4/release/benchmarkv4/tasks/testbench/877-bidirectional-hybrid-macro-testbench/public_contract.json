  "properties": [
    {
      "id": "P_RESET_CLEAR",
      "observable_contract": "Reset centers the continuous sum and difference outputs and clears sampled metrics and balance qualification.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "sum_out",
        "diff_out",
        "forward_metric",
        "reverse_metric",
        "balance_ok"
      ]
    },
    {
      "id": "P_SUM_DIFF_MAPPING",
      "observable_contract": "sum_out and diff_out implement the clipped common and differential mappings of port_a and port_b around vcm.",
      "required_signals": [
        "time",
        "rst",
        "port_a",
        "port_b",
        "trim_2",
        "trim_1",
        "trim_0",
        "sum_out",
        "diff_out"
      ]
    },
    {
      "id": "P_TRIM_RESPONSE",
      "observable_contract": "The signed three-bit trim correction shifts sum and difference in opposite directions by trim_lsb per code.",
      "required_signals": [
        "time",
        "rst",
        "trim_2",
        "trim_1",
        "trim_0",
        "sum_out",
        "diff_out"
      ]
    },
    {
      "id": "P_DIRECTIONAL_METRICS",
      "observable_contract": "At rising clock edges forward and reverse metrics reconstruct the directional components from the mapped sum and difference outputs.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "sum_out",
        "diff_out",
        "forward_metric",
        "reverse_metric"
      ]
    },
    {
      "id": "P_BALANCE_QUALIFICATION",
      "observable_contract": "balance_ok asserts only after two consecutive metric updates whose directional mismatch is within balance_tol.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "forward_metric",
        "reverse_metric",
        "balance_ok"
      ]
    }
  ],
