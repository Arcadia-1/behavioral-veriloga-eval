  "properties": [
    {
      "id": "P_RESET_DISABLE_CLEAR",
      "observable_contract": "Reset or low enable clears pulse, lock, reacquire, divider, and phase-code outputs.",
      "required_signals": [
        "time",
        "rst",
        "enable",
        "up",
        "down",
        "lock",
        "reacquire",
        "div2_clk",
        "phase_3",
        "phase_2",
        "phase_1",
        "phase_0"
      ]
    },
    {
      "id": "P_PHASE_COMPARE",
      "observable_contract": "UP and DOWN identify which observed rising edge led each completed comparison.",
      "required_signals": [
        "time",
        "ref_clk",
        "fb_clk",
        "rst",
        "enable",
        "up",
        "down"
      ]
    },
    {
      "id": "P_PHASE_CODE",
      "observable_contract": "The offset-binary phase code updates by one per completed comparison and clamps to its public range.",
      "required_signals": [
        "time",
        "ref_clk",
        "fb_clk",
        "rst",
        "enable",
        "phase_3",
        "phase_2",
        "phase_1",
        "phase_0"
      ]
    },
    {
      "id": "P_DIVIDE_BY_FOUR_EDGES",
      "observable_contract": "DIV2 toggles after each pair of feedback-clock rising edges.",
      "required_signals": [
        "time",
        "fb_clk",
        "rst",
        "enable",
        "div2_clk"
      ]
    },
    {
      "id": "P_LOCK_REACQUIRE",
      "observable_contract": "Lock requires four consecutive in-window comparisons and reacquire requires two post-lock out-of-window comparisons.",
      "required_signals": [
        "time",
        "ref_clk",
        "fb_clk",
        "rst",
        "enable",
        "lock",
        "reacquire",
        "phase_3",
        "phase_2",
        "phase_1",
        "phase_0"
      ]
    }
  ],
