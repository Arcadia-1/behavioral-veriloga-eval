  "properties": [
    {
      "id": "P_WINDOW_DEFINITION",
      "observable_contract": "The input is qualified in-window exactly while the absolute vin-to-target error is no greater than tol.",
      "required_signals": [
        "time",
        "vin",
        "target",
        "tol",
