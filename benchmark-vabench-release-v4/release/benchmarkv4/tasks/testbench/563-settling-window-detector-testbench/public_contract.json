      ]
    },
    {
      "id": "P_ENTRY_AND_HOLD",
      "observable_contract": "Entering the window records the entry time, but settled remains low until vin has stayed continuously in-window for at least 20 ns.",
      "required_signals": [
        "time",
        "vin",
        "target",
        "tol",
        "settled",
        "t_code0",
        "t_code1",
        "t_code2",
