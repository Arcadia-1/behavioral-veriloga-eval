        "t_code7"
      ]
    },
    {
      "id": "P_EXIT_RESETS_QUALIFICATION",
      "observable_contract": "Leaving the tolerance window before or after qualification clears the entry state, drives settled low, and clears the time code.",
      "required_signals": [
        "time",
        "vin",
        "target",
        "tol",
        "settled",
