        "sigin_p",
        "sigin_n",
        "sigout"
      ]
    },
    {
      "id": "P_LEAK_INSIDE_DEADBAND",
      "observable_contract": "For `dead_low <= V(sigin_p, sigin_n) <= dead_high`, drive `sigout` to the parameter `leak`.",
      "required_signals": [
        "time",
        "sigin_p",
        "sigin_n",
        "sigout"
      ]
    },
    {
      "id": "P_GAINED_RESIDUE_OUTSIDE_DEADBAND",
      "observable_contract": "Below `dead_low`, drive `gain * (diff - dead_low) + leak`; above `dead_high`, drive `gain * (diff - dead_high) + leak`.",
      "required_signals": [
        "time",
        "sigin_p",
        "sigin_n",
        "sigout"
      ]
    }
