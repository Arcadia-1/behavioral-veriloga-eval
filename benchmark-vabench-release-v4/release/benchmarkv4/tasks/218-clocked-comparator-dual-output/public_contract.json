  "properties": [
    {
      "id": "P_INITIALIZE_BOTH_DECISION_OUTPUTS_LOW",
      "observable_contract": "Initialize both decision outputs low.",
      "required_signals": [
        "time",
        "clk",
        "outn",
        "outp",
        "vinn",
        "vinp"
      ]
    },
    {
      "id": "P_WHENEVER_CLK_FALLS_THROUGH_VDD_2",
      "observable_contract": "Whenever `clk` falls through `vdd/2`, reset both outputs low.",
      "required_signals": [
        "time",
        "clk",
        "outn",
        "outp",
        "vinn",
        "vinp"
      ]
    },
    {
      "id": "P_WHENEVER_CLK_RISES_THROUGH_VDD_2",
      "observable_contract": "Whenever `clk` rises through `vdd/2`, latch a differential decision.",
      "required_signals": [
        "time",
        "clk",
        "outn",
        "outp",
        "vinn",
        "vinp"
      ]
    },
    {
      "id": "P_DRIVE_OUTP_HIGH_AND_OUTN_LOW",
      "observable_contract": "Drive `outp` high and `outn` low for `vinp > vinn`.",
      "required_signals": [
        "time",
        "clk",
        "outn",
        "outp",
        "vinn",
        "vinp"
      ]
    },
    {
      "id": "P_DRIVE_OUTN_HIGH_AND_OUTP_LOW",
      "observable_contract": "Drive `outn` high and `outp` low for `vinp < vinn`.",
      "required_signals": [
        "time",
        "clk",
        "outn",
        "outp",
        "vinn",
        "vinp"
      ]
    },
    {
      "id": "P_DRIVE_BOTH_OUTPUTS_LOW_FOR_AN",
      "observable_contract": "Drive both outputs low for an equal-input decision.",
      "required_signals": [
        "time",
        "clk",
        "outn",
        "outp",
        "vinn",
        "vinp"
      ]
    }
  ],
