      ]
    },
    {
      "id": "P_USE_LOW_TRIP_AND_HIGH_TRIP",
      "observable_contract": "Use `low_trip` and `high_trip` as public voltage thresholds.",
      "required_signals": [
        "time",
        "vin",
        "rst",
        "enable",
        "low_trip",
        "high_trip",
        "inside_flag",
        "state_metric",
        "toggled"
      ]
    },
    {
      "id": "P_ASSERT_INSIDE_FLAG_WHEN_VIN_ENTERS",
      "observable_contract": "Assert `inside_flag` when `vin` enters the window and keep it asserted until `vin` crosses outside the hysteresis margins.",
      "required_signals": [
        "time",
        "vin",
        "rst",
        "enable",
        "low_trip",
        "high_trip",
        "inside_flag",
        "state_metric",
        "toggled"
      ]
    },
    {
      "id": "P_EXPOSE_THE_CURRENT_STATE_AS_STATE",
      "observable_contract": "Expose the current state as `state_metric` and pulse `toggled` high on state changes.",
      "required_signals": [
        "time",
        "vin",
        "rst",
        "enable",
        "low_trip",
        "high_trip",
        "inside_flag",
        "state_metric",
        "toggled"
      ]
    },
    {
      "id": "P_DO_NOT_CHATTER_FOR_SMALL_INPUT",
