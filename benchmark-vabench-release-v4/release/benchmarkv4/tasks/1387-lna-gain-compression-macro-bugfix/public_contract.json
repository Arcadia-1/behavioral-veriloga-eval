  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_DRIVE",
      "observable_contract": "On reset or when disabled, drive `vout` to `vcm`, clear `gain_metric`, and clear `compression_flag`.",
      "required_signals": [
        "time",
        "vin",
        "enable",
        "rst",
        "vout",
        "gain_metric",
        "compression_flag"
      ]
    },
    {
      "id": "P_WHEN_ENABLED_PROVIDE_HIGH_GAIN_FOR",
      "observable_contract": "While enabled compute excess=max(0,abs(vin-vcm)-input_clip) and active_gain=small_gain/(1+excess/0.20).",
      "required_signals": [
        "time",
        "vin",
        "enable",
        "rst",
        "vout",
        "gain_metric",
        "compression_flag"
      ]
    },
    {
      "id": "P_REDUCE_EFFECTIVE_GAIN_MONOTONICALLY_WHEN_THE",
      "observable_contract": "Drive vout=clamp(vcm+active_gain*(vin-vcm),vss,vdd), with active_gain decreasing monotonically once abs(vin-vcm)>input_clip.",
      "required_signals": [
        "time",
        "vin",
        "enable",
        "rst",
        "vout",
        "gain_metric",
        "compression_flag"
      ]
    },
    {
      "id": "P_EXPOSE_ACTIVE_GAIN_ON_GAIN_METRIC",
      "observable_contract": "Drive gain_metric=clamp(vdd*active_gain/small_gain,vss,vdd) and compression_flag=vdd exactly when active_gain<0.85*small_gain, otherwise vss.",
      "required_signals": [
        "time",
        "vin",
        "enable",
        "rst",
        "vout",
        "gain_metric",
        "compression_flag"
      ]
    },
    {
      "id": "P_CLAMP_VOUT_INSIDE_VSS_VDD",
      "observable_contract": "Clamp `vout` inside `[vss, vdd]`.",
      "required_signals": [
        "time",
        "vin",
        "enable",
        "rst",
        "vout",
        "gain_metric",
        "compression_flag"
      ]
    }
  ],
