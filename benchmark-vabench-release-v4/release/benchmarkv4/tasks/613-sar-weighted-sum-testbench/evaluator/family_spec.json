  "properties": [
    {
      "id": "P_THRESHOLD_DECODE",
      "observable_contract": "Each D input contributes logic 1 only while its voltage is strictly above vth; a value at or below vth contributes logic 0.",
      "required_signals": [
        "time",
        "d10",
        "d9",
        "d8",
        "d7",
        "d6",
        "d5",
        "d4",
        "d3",
        "d2",
        "d1",
        "d0",
        "vout"
      ]
    },
    {
      "id": "P_WEIGHT_ORDER",
      "observable_contract": "The decoded contribution order is D10 at seven-eighths full scale, D9 at one-half, D8 at one-quarter, a 5:3 split across D7 and D6, then a binary tail from D5 through D0.",
      "required_signals": [
        "time",
        "d10",
        "d9",
        "d8",
        "d7",
        "d6",
        "d5",
        "d4",
        "d3",
        "d2",
        "d1",
        "d0",
        "vout"
      ]
    },
    {
      "id": "P_BIPOLAR_ENDPOINTS",
      "observable_contract": "All decision inputs low produce -1 V, while all decision inputs high produce one 512-unit step below +1 V on the normalized bipolar scale.",
      "required_signals": [
        "time",
        "d10",
        "d9",
        "d8",
        "d7",
        "d6",
        "d5",
        "d4",
