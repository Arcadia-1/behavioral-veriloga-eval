        "d0",
        "vout"
      ]
    },
    {
      "id": "P_MONOTONIC_CODE_WEIGHT",
      "observable_contract": "Changing any decoded decision from low to high without lowering another decision cannot decrease VOUT.",
      "required_signals": [
        "time",
        "d10",
        "d9",
        "d8",
        "d7",
        "d6",
        "d5",
        "d4",
