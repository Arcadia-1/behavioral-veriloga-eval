  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_CLEAR",
      "observable_contract": "On reset or when disabled, clear `decision`, `kickback_metric`, and `valid`.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "enable",
        "decision",
        "kickback_metric",
        "valid"
      ]
    },
    {
      "id": "P_ON_EACH_ENABLED_RISING_CLK_EDGE",
      "observable_contract": "On each enabled rising `clk` edge, latch the sign of `vinp - vinn` into `decision`.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "enable",
        "decision",
        "kickback_metric",
        "valid"
      ]
    },
    {
      "id": "P_DRIVE_KICKBACK_METRIC_AS_A_VOLTAGE",
      "observable_contract": "Let `overdrive = abs(V(vinp)-V(vinn))` and drive `kickback_metric = clamp(vcm + 0.30/(1.0 + overdrive/0.030), vss, vdd)`.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "enable",
        "decision",
        "kickback_metric",
        "valid"
      ]
    },
    {
      "id": "P_SMALL_OVERDRIVE_MUST_PRODUCE_A_LARGER",
      "observable_contract": "Small overdrive must produce a larger kickback metric than large overdrive, up to the public rail limits.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "enable",
        "decision",
        "kickback_metric",
        "valid"
      ]
    },
    {
      "id": "P_ASSERT_VALID_AFTER_EACH_COMPLETED_DECISION",
      "observable_contract": "Assert `valid` after each completed decision update.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "enable",
        "decision",
        "kickback_metric",
        "valid"
      ]
    },
    {
