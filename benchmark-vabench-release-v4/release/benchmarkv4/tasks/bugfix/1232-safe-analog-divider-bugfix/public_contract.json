      "required_signals": [
        "time",
        "sigdenom",
        "signumer",
        "sigout"
      ]
    },
    {
      "id": "P_DRIVE_SIGOUT_TO_GAIN_V_SIGNUMER",
      "observable_contract": "Drive `sigout` to the observable transfer `gain * V(signumer) / guarded_denominator`.",
