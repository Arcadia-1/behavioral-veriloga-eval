  "modeling_constraints": [
    "Use deterministic periodic extrema sampling after start_time.",
    "Use event-updated metric and validity targets with rail-referenced smoothing.",
    "Do not generate testbenches or waveform artifacts or use current contributions, transistor-level devices, ddt, or idt."
  ],
  "problem_statement": "the supplied system violates the public contract",
  "properties": [
    {
      "id": "P_START_TIME_GATING",
      "observable_contract": "Samples before start_time do not contribute to measured input or output extrema and valid remains low.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "voutp",
        "voutn",
        "valid"
      ]
    },
    {
      "id": "P_PERIODIC_EXTREMA",
      "observable_contract": "At each sample_period after start_time, the estimator updates minima and maxima of the input and output differential voltages.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "voutp",
        "voutn",
        "gain_out",
        "valid"
      ]
    },
    {
      "id": "P_VALIDITY_THRESHOLD",
      "observable_contract": "Valid remains rail-low until the observed input differential span exceeds min_input_span and remains rail-high afterwards.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "vinp",
        "vinn",
        "valid"
      ]
    },
    {
      "id": "P_SPAN_RATIO",
      "observable_contract": "Once valid, the measured gain equals output differential span divided by input differential span.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "voutp",
        "voutn",
        "gain_out",
        "valid"
      ]
    },
    {
      "id": "P_NORMALIZED_GAIN_OUTPUT",
      "observable_contract": "Gain_out equals the VDD-to-VSS rail span multiplied by measured gain divided by gain_scale.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "gain_out",
        "valid"
      ]
    },
    {
      "id": "P_EVENT_UPDATED_TARGETS",
      "observable_contract": "Gain_out and valid reflect event-updated retained targets with finite smoothing rather than continuously varying transition inputs.",
      "required_signals": [
        "time",
        "gain_out",
        "valid"
      ]
    }
  ],
