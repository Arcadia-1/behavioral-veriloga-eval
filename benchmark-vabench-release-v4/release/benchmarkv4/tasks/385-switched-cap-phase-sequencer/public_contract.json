  "properties": [
    {
      "id": "P_RESET_DISABLE_CLEAR",
      "observable_contract": "Reset or disabled operation clears all phase outputs, commands, phase code, and valid.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "phi1",
        "phi2",
        "phi3",
        "phi4",
        "sample_cmd",
        "hold_cmd",
        "phase_code_1",
        "phase_code_0",
        "valid"
      ]
    },
    {
      "id": "P_ONE_HOT_SEQUENCE",
      "observable_contract": "Enabled rising clock edges advance cyclically through four one-hot phases with no overlapping high phases.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "phi1",
        "phi2",
        "phi3",
        "phi4"
      ]
    },
    {
      "id": "P_COMMAND_MAPPING",
      "observable_contract": "sample_cmd is high exactly for phi1 or phi2, while hold_cmd is high exactly for phi3 or phi4.",
      "required_signals": [
        "time",
        "phi1",
        "phi2",
        "phi3",
        "phi4",
        "sample_cmd",
        "hold_cmd"
      ]
    },
    {
      "id": "P_PHASE_CODE",
      "observable_contract": "phase_code_1 and phase_code_0 encode the active phase index zero through three.",
      "required_signals": [
        "time",
        "phi1",
        "phi2",
        "phi3",
        "phi4",
        "phase_code_1",
        "phase_code_0"
      ]
    },
    {
      "id": "P_VALID_AFTER_SEQUENCE",
      "observable_contract": "valid remains low initially and asserts only after a complete enabled four-phase sample/hold sequence.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "phase_code_1",
        "phase_code_0",
        "valid"
      ]
    }
  ],
