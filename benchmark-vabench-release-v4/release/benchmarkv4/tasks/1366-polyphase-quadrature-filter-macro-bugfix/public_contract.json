  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_ENABLE_IS",
      "observable_contract": "On reset or while disabled restore i_state=q_state=vcm, clear the update count, and drive amp_metric=phase_metric=valid=vss.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "i_out",
        "q_out",
        "amp_metric",
        "phase_metric",
        "valid"
      ]
    },
    {
      "id": "P_ON_EACH_RISING_CLK_EDGE_WHILE",
      "observable_contract": "Poll every tick=250ps and on each enabled rising clk edge update i_state=i_state+alpha*(vin-i_state).",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "i_out",
        "q_out",
        "amp_metric",
        "phase_metric",
        "valid"
      ]
    },
    {
      "id": "P_UPDATE_A_QUADRATURE_SAMPLED_STATE_USING",
      "observable_contract": "Save old_i before the I update and then update q_state=q_state+alpha*(old_i-q_state).",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "i_out",
        "q_out",
        "amp_metric",
        "phase_metric",
        "valid"
      ]
    },
    {
      "id": "P_DRIVE_I_OUT_AND_Q_OUT",
      "observable_contract": "Drive `i_out` and `q_out` around `vcm` from the two path states.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "i_out",
        "q_out",
        "amp_metric",
        "phase_metric",
        "valid"
      ]
    },
    {
      "id": "P_REPORT_A_BOUNDED_PHASE_ORDER_METRIC",
      "observable_contract": "After each enabled update drive amp_metric=min(vdd,2*abs(i_state-q_state)) and phase_metric=0.65V when i_state>=q_state, otherwise 0.25V.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "i_out",
        "q_out",
        "amp_metric",
        "phase_metric",
        "valid"
      ]
    },
    {
      "id": "P_ASSERT_VALID_AFTER_AT_LEAST_FOUR",
      "observable_contract": "Increment the enabled-update count once per detected rising edge and drive valid=vdd starting with update four, otherwise vss.",
