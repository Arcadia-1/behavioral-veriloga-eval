  "problem_statement": "the supplied system violates the public contract",
  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_DRIVE",
      "observable_contract": "On reset or while disabled, restore `prev_code=0` and the unchanged-code counter to zero, drive `vout=vcm`, and drive `overshoot_metric=settled=vss`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "overshoot_metric",
        "settled"
      ]
    },
    {
      "id": "P_ON_EACH_ENABLED_RISING_CLK_EDGE",
      "observable_contract": "Poll every `tick`; on each enabled rising `clk` edge decode `code=4*gain_2+2*gain_1+gain_0` and drive `vout=clamp(vcm+(1+gain_lsb*code)*(vin-vcm),vss,vdd)`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "overshoot_metric",
        "settled"
      ]
    },
    {
      "id": "P_APPLY_BOUNDED_SETTLING_WITH_A_CODE",
      "observable_contract": "Use the `tr` transition for bounded output smoothing without adding an overshoot excursion to `vout`; expose the code-step proxy separately on `overshoot_metric`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "overshoot_metric",
        "settled"
      ]
    },
    {
      "id": "P_EXPOSE_OVERSHOOT_MAGNITUDE_ON_OVERSHOOT_METRIC",
      "observable_contract": "On every enabled rising edge drive `overshoot_metric=vdd*abs(code-prev_code)/7` before storing the current code as `prev_code`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "overshoot_metric",
        "settled"
      ]
    },
    {
      "id": "P_ASSERT_SETTLED_AFTER_TWO_CONSECUTIVE_UPDATES",
      "observable_contract": "Use unchanged gain code as the deterministic settling proxy: increment the counter when `code==prev_code`, clear it otherwise, assert `settled=vdd` at count two, and drive `vss` otherwise; a newly changed code therefore needs two subsequent unchanged-code comparisons.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "vout",
        "overshoot_metric",
        "settled"
      ]
    }
  ],
