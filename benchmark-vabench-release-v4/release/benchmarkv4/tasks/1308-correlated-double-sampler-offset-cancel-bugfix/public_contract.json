  "properties": [
    {
      "id": "P_ON_RESET_CLEAR_RESET_SAMPLE_SIGNAL",
      "observable_contract": "On reset, clear reset-sample, signal-sample, output, debug metric, and `valid`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "sample_reset",
        "sample_signal",
        "vout",
        "offset_dbg",
        "valid"
      ]
    },
    {
      "id": "P_ON_A_RISING_CLK_EDGE_WITH",
      "observable_contract": "On a rising `clk` edge with `sample_reset` high, capture `vin` as the reset/reference sample.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "sample_reset",
        "sample_signal",
        "vout",
        "offset_dbg",
        "valid"
      ]
    },
    {
      "id": "P_ON_A_LATER_RISING_CLK_EDGE",
      "observable_contract": "On a later rising `clk` edge with `sample_signal` high, capture `vin` as the signal sample.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "sample_reset",
        "sample_signal",
        "vout",
        "offset_dbg",
        "valid"
      ]
    },
    {
      "id": "P_DRIVE_VOUT_AS_VCM_PLUS_THE",
      "observable_contract": "Drive `vout` as `vcm` plus the signal-minus-reset difference scaled by `cds_gain`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "sample_reset",
        "sample_signal",
        "vout",
        "offset_dbg",
        "valid"
      ]
    },
    {
      "id": "P_EXPOSE_THE_RESET_SAMPLE_ON_OFFSET",
      "observable_contract": "Expose the reset sample on `offset_dbg` and assert `valid` only after a complete reset/signal pair.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "sample_reset",
        "sample_signal",
        "vout",
        "offset_dbg",
        "valid"
      ]
    },
