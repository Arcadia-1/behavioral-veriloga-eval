  ],
  "properties": [
    {
      "id": "P_RESET_CLEARS_STATE_AND_OBSERVABLES",
      "observable_contract": "At each rising clk edge with V(rst) > vth, clear the stable count, out, err_metric, and progress to zero.",
      "required_signals": [
        "clk",
        "coef",
        "err_metric",
        "out",
        "progress",
        "rst",
        "sample",
        "target",
        "time"
      ]
    },
    {
      "id": "P_CORRECTED_OUTPUT_USES_SAMPLE_TARGET_AND_COEF",
      "observable_contract": "At each reset-low rising edge, let coeff=clip01(V(coef)/vhi) and error=V(target)-V(sample), then store out=clamp(V(sample)+coeff*error,0,vhi).",
      "required_signals": [
        "clk",
        "coef",
        "err_metric",
        "out",
        "progress",
        "rst",
        "sample",
        "target",
        "time"
      ]
    },
    {
      "id": "P_ERROR_METRIC_REPORTS_ABSOLUTE_ERROR",
      "observable_contract": "At the same edge, store err_metric=vhi*clip01(abs(error)/err_fullscale).",
      "required_signals": [
        "clk",
        "coef",
        "err_metric",
        "out",
        "progress",
        "rst",
        "sample",
        "target",
        "time"
      ]
    },
    {
      "id": "P_PROGRESS_COUNTS_CONSECUTIVE_IN_WINDOW_SAMPLES",
      "observable_contract": "Increment the stable count capped at ready_count exactly when abs(error)<=err_window, otherwise clear it; store progress=vhi*clip01(stable_count/ready_count).",
      "required_signals": [
        "clk",
        "coef",
        "err_metric",
        "out",
        "progress",
        "rst",
        "sample",
        "target",
        "time"
      ]
    }
  ],
