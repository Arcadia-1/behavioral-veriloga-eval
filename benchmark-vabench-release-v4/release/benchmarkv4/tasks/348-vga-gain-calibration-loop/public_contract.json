    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "VGA Gain Calibration Loop"
  },
  "modeling_constraints": [
    "Use deterministic voltage-domain transient behavioral Verilog-A.",
    "Preserve the declared multi-module architecture and exact public artifact interfaces.",
    "Do not use current contributions, unsupported continuous operators, validation logic, hard-coded evaluator timing, or simulator side channels."
  ],
  "properties": [
    {
      "id": "P_VGA_RESET_STATE",
      "observable_contract": "Reset restores gain code four and clears peak_metric and locked.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "gain_3",
        "gain_2",
        "gain_1",
        "gain_0",
        "peak_metric",
        "locked"
      ]
    },
    {
      "id": "P_VGA_PEAK_SAMPLE",
      "observable_contract": "Each enabled rising clock samples the absolute vin magnitude into peak_metric.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "start",
        "peak_metric"
      ]
    },
    {
      "id": "P_VGA_GAIN_DIRECTION",
      "observable_contract": "The gain code moves one bounded step toward target according to the prior sampled peak and clamps to zero through fifteen.",
      "required_signals": [
        "time",
        "target",
        "clk",
        "rst",
        "start",
        "peak_metric",
        "gain_3",
        "gain_2",
        "gain_1",
        "gain_0"
      ]
    },
    {
      "id": "P_VGA_OUTPUT_GAIN",
      "observable_contract": "vout continuously equals vin times gain_min plus gain_lsb times gain code.",
      "required_signals": [
        "time",
        "vin",
        "vout",
        "gain_3",
        "gain_2",
        "gain_1",
        "gain_0"
      ]
    },
    {
      "id": "P_VGA_LOCK_QUALIFICATION",
      "observable_contract": "locked asserts after three consecutive enabled updates whose prior sampled peak lies within tolerance.",
      "required_signals": [
        "time",
        "target",
        "clk",
        "rst",
        "start",
        "peak_metric",
        "locked"
      ]
    }
  ],
