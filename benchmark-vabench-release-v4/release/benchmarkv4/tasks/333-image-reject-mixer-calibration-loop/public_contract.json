    {
      "id": "P_ON_EACH_ENABLED_RISING_CLK_EDGE",
      "observable_contract": "On each enabled rising `clk` edge, sample RF and quadrature LO inputs as voltage-domain mixer proxies.",
      "required_signals": [
        "time",
        "rf_in",
        "lo_i",
        "lo_q",
        "clk",
        "rst",
        "enable",
        "i_out",
