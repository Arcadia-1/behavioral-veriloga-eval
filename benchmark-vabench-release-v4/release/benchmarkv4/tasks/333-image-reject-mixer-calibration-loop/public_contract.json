        "calibrated"
      ]
    },
    {
      "id": "P_GENERATE_I_AND_Q_OUTPUTS_USING",
      "observable_contract": "Generate I and Q outputs using opposite LO polarities.",
      "required_signals": [
        "time",
        "rf_in",
        "lo_i",
        "lo_q",
        "clk",
        "rst",
        "enable",
        "i_out",
        "q_out",
        "image_metric",
        "calibrated"
      ]
    },
    {
      "id": "P_UPDATE_A_SIMPLE_GAIN_PHASE_CORRECTION",
      "observable_contract": "Update a simple gain/phase correction state to reduce the image metric.",
      "required_signals": [
        "time",
        "rf_in",
        "lo_i",
        "lo_q",
        "clk",
        "rst",
        "enable",
        "i_out",
        "q_out",
        "image_metric",
        "calibrated"
      ]
    },
    {
      "id": "P_ASSERT_CALIBRATED_AFTER_THREE_CONSECUTIVE_UPDA",
      "observable_contract": "Assert `calibrated` after three consecutive updates with image metric below `image_tol`.",
