                "type": "real",
                "units": "V",
                "valid_range": "vdd > 0"
              },
              {
                "default": 2e-09,
                "name": "tol",
                "override_behavior": "sets maximum ref-to-feedback edge separation",
                "type": "real",
                "units": "s",
                "valid_range": "tol >= 0"
              },
              {
                "default": 3,
                "name": "need",
                "override_behavior": "sets consecutive aligned reference events required for lock",
                "type": "integer",
                "units": null,
                "valid_range": "need >= 1"
              },
              {
                "default": 5e-10,
                "name": "tr",
