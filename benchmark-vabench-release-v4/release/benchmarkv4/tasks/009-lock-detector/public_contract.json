  "form": "dut",
  "identity": {
    "category": "pll_clock_timing",
    "difficulty": "D2",
    "level": "L1",
    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "Lock Detector"
  },
  "modeling_constraints": [
    "Use deterministic voltage-domain edge timing.",
    "Use voltage contributions with finite smoothing only.",
    "Do not hard-code evaluator stimulus, stop times, or sample windows."
  ],
  "properties": [
    {
      "id": "P_ALIGNMENT_STREAK",
      "observable_contract": "lock asserts only after need consecutive reference edges whose most recent feedback edge is within tol.",
      "required_signals": [
        "time",
        "ref_clk",
        "fb_clk",
        "rst_n",
        "lock"
      ]
    },
    {
      "id": "P_PREMATURE_LOCK",
      "observable_contract": "lock remains low before the need-th consecutive aligned reference event.",
      "required_signals": [
        "time",
        "ref_clk",
        "fb_clk",
        "lock"
      ]
    },
    {
      "id": "P_MISS_BREAKS_STREAK",
      "observable_contract": "A reference event outside tol breaks the streak and clears lock.",
      "required_signals": [
        "time",
        "ref_clk",
        "fb_clk",
        "lock"
      ]
    },
    {
      "id": "P_RESET_REACQUIRE",
      "observable_contract": "Active-low reset clears stored edge history, streak, and lock and requires a fresh post-reset acquisition.",
      "required_signals": [
        "time",
        "ref_clk",
        "fb_clk",
        "rst_n",
        "lock"
      ]
    }
  ],
