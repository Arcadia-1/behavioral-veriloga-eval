  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_CLEAR",
      "observable_contract": "On reset or when disabled, clear both sample states and all metrics.",
      "required_signals": [
        "time",
        "vin_a",
        "vin_b",
        "clk_a",
        "clk_b",
        "rst",
        "enable",
        "skew_metric",
        "magnitude_metric",
        "alarm"
      ]
    },
    {
      "id": "P_CAPTURE_VIN_A_ON_RISING_CLK",
      "observable_contract": "Capture `vin_a` on rising `clk_a` and `vin_b` on rising `clk_b`.",
      "required_signals": [
        "time",
        "vin_a",
        "vin_b",
        "clk_a",
        "clk_b",
        "rst",
        "enable",
        "skew_metric",
        "magnitude_metric",
        "alarm"
      ]
    },
    {
      "id": "P_ESTIMATE_A_SKEW_PROXY_FROM_THE",
      "observable_contract": "Estimate a skew proxy from the signed difference between the two most recent samples.",
      "required_signals": [
        "time",
        "vin_a",
        "vin_b",
        "clk_a",
        "clk_b",
        "rst",
        "enable",
        "skew_metric",
        "magnitude_metric",
        "alarm"
      ]
    },
    {
      "id": "P_DRIVE_SKEW_METRIC_WITH_THE_ABSOLUTE",
      "observable_contract": "Drive `skew_metric` with the absolute skew proxy and `magnitude_metric` with the average sample magnitude.",
      "required_signals": [
        "time",
        "vin_a",
        "vin_b",
        "clk_a",
        "clk_b",
        "rst",
        "enable",
        "skew_metric",
        "magnitude_metric",
        "alarm"
      ]
    },
    {
      "id": "P_ASSERT_ALARM_WHEN_SKEW_METRIC_EXCEEDS",
      "observable_contract": "Assert `alarm` when `skew_metric` exceeds `skew_limit` for two consecutive comparisons.",
      "required_signals": [
        "time",
        "vin_a",
        "vin_b",
        "clk_a",
        "clk_b",
        "rst",
        "enable",
        "skew_metric",
        "magnitude_metric",
        "alarm"
      ]
    },
    {
      "id": "P_USE_ONLY_VOLTAGE_DOMAIN_BEHAVIORAL_STATE",
      "observable_contract": "Use only voltage-domain behavioral state and voltage contributions on public electrical outputs.",
      "required_signals": [
        "time",
        "vin_a",
        "vin_b",
        "clk_a",
        "clk_b",
        "rst",
        "enable",
        "skew_metric",
        "magnitude_metric",
        "alarm"
      ]
    }
  ],
