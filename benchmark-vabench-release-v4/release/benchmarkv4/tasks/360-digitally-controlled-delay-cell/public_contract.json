  "properties": [
    {
      "id": "P_RESET_CLEAR",
      "observable_contract": "Reset clears the loaded code state, delayed clock, delay metric, valid indication, and pending edges.",
      "required_signals": [
        "time",
        "rst",
        "load",
        "out_clk",
        "delay_metric",
        "valid"
      ]
    },
    {
      "id": "P_CODE_CAPTURE_METRIC",
      "observable_contract": "A rising load edge captures the six-bit unsigned code and the delay metric reports the normalized captured code.",
      "required_signals": [
        "time",
        "load",
        "code_5",
        "code_4",
        "code_3",
        "code_2",
        "code_1",
        "code_0",
        "delay_metric"
      ]
    },
    {
      "id": "P_EDGE_DELAY_MAPPING",
      "observable_contract": "Each input-clock edge appears at the output after delay_min plus delay_lsb times the code captured for that edge.",
      "required_signals": [
        "time",
        "in_clk",
        "out_clk",
        "load",
        "code_5",
        "code_4",
        "code_3",
        "code_2",
        "code_1",
        "code_0"
      ]
    },
    {
      "id": "P_PULSE_INTEGRITY_VALID",
      "observable_contract": "Rising and falling edges receive equal delay, preserving pulse width, and valid asserts after the first delayed rising edge.",
      "required_signals": [
        "time",
        "rst",
        "in_clk",
        "out_clk",
        "valid"
      ]
    }
  ],
