      ]
    },
    {
      "id": "P_DECISION_DELAY_CAPTURE",
      "observable_contract": "The first qualifying `outp` or `outn` decision edge while armed reports the elapsed clock-to-decision delay in `delay_ps`.",
      "required_signals": [
        "time",
        "clk",
        "outp",
        "outn",
        "delay_ps",
        "valid"
      ]
    },
    {
      "id": "P_ABSOLUTE_OVERDRIVE_METRIC",
      "observable_contract": "`overdrive_mv` reports the absolute input differential magnitude at launch time.",
