        "clk",
        "vinp",
        "vinn",
        "overdrive_mv"
      ]
    },
    {
      "id": "P_POLARITY_AND_VALID_FLAG",
      "observable_contract": "`polarity` reports the winning output decision direction and `valid` asserts only for a completed armed measurement.",
