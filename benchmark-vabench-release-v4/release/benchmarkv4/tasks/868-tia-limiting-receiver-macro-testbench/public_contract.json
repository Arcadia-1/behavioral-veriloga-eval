  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_ENABLE_IS",
      "observable_contract": "On reset or when `enable` is low, drive `vout` to `vcm` and clear `decision`, `limit_flag`, `valid`, and `amp_metric`.",
      "required_signals": [
        "time",
        "vin_proxy",
        "clk",
        "rst",
        "enable",
        "vout",
        "decision",
        "limit_flag",
        "valid",
        "amp_metric"
      ]
    },
    {
      "id": "P_TREAT_VIN_PROXY_AS_A_VOLTAGE",
      "observable_contract": "Treat `vin_proxy` as a voltage-domain proxy for receiver input magnitude; no current ports are required.",
      "required_signals": [
        "time",
        "vin_proxy",
        "clk",
        "rst",
        "enable",
        "vout",
        "decision",
        "limit_flag",
        "valid",
        "amp_metric"
      ]
    },
    {
      "id": "P_APPLY_GAIN_TO_THE_DEVIATION_FROM",
      "observable_contract": "Apply gain to the deviation from `vcm` and clamp the output to `vcm +/- limit`.",
      "required_signals": [
        "time",
        "vin_proxy",
        "clk",
        "rst",
        "enable",
        "vout",
        "decision",
        "limit_flag",
        "valid",
        "amp_metric"
      ]
    },
    {
      "id": "P_ASSERT_LIMIT_FLAG_WHEN_THE_UNCLAMPED",
      "observable_contract": "Assert `limit_flag` when the unclamped amplified signal would exceed the limiter range.",
      "required_signals": [
        "time",
        "vin_proxy",
        "clk",
        "rst",
        "enable",
        "vout",
        "decision",
        "limit_flag",
        "valid",
        "amp_metric"
      ]
    },
    {
      "id": "P_ON_EACH_RISING_CLK_EDGE_DRIVE",
      "observable_contract": "On each rising `clk` edge, drive `decision` high when the limited output is at or above `vcm`, otherwise low.",
      "required_signals": [
        "time",
        "vin_proxy",
        "clk",
        "rst",
        "enable",
        "vout",
        "decision",
        "limit_flag",
        "valid",
        "amp_metric"
      ]
    },
    {
      "id": "P_ASSERT_VALID_WHEN_AMP_METRIC_IS",
      "observable_contract": "Assert `valid` when `amp_metric` is at least `valid_min` for two consecutive clock updates.",
      "required_signals": [
        "time",
        "vin_proxy",
        "clk",
        "rst",
        "enable",
        "vout",
        "decision",
        "limit_flag",
        "valid",
        "amp_metric"
      ]
    }
  ],
