  "properties": [
    {
      "id": "P_RESET_DISABLE_CLEAR",
      "observable_contract": "Reset or low enable clears trim, duty metric, lock, and output clock.",
      "required_signals": [
        "time",
        "clk_in",
        "rst",
        "enable",
        "clk_out",
        "trim_3",
        "trim_2",
        "trim_1",
