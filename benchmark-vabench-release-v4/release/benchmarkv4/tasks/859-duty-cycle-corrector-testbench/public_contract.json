        "duty_metric",
        "locked"
      ]
    },
    {
      "id": "P_DUTY_MEASUREMENT",
      "observable_contract": "The metric reports high-time fraction over each complete input-clock cycle.",
      "required_signals": [
        "time",
        "clk_in",
        "rst",
        "enable",
        "duty_metric"
      ]
    },
    {
      "id": "P_TRIM_DIRECTION",
      "observable_contract": "The trim code moves up below the target window and down above it, with rail saturation.",
      "required_signals": [
        "time",
        "clk_in",
        "rst",
        "enable",
        "trim_3",
        "trim_2",
        "trim_1",
        "trim_0",
        "duty_metric"
      ]
    },
    {
      "id": "P_EDGE_DELAY",
      "observable_contract": "Rising edges pass without intentional delay while falling edges receive the latched trim-code delay.",
      "required_signals": [
        "time",
        "clk_in",
        "clk_out",
        "rst",
        "enable",
        "trim_3",
        "trim_2",
        "trim_1",
        "trim_0"
      ]
    },
    {
      "id": "P_LOCK_QUALIFICATION",
      "observable_contract": "Lock asserts after three consecutive measured cycles inside the target window.",
      "required_signals": [
        "time",
        "clk_in",
        "rst",
        "enable",
        "duty_metric",
        "locked"
      ]
    }
  ],
