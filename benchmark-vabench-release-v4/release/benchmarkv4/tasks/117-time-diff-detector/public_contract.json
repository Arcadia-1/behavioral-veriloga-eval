{
  "artifact_contract": {
    "files": [
      {
        "modules": [
          {
            "depends_on": [],
            "name": "time_diff_detector",
            "parameters": [
              {
                "default": 0.9,
                "name": "vdd",
                "override_behavior": "sets the symmetric positive and negative output clipping magnitude",
                "type": "real",
                "units": "V",
                "valid_range": "vdd > 0"
              },
              {
                "default": 0.45,
                "name": "vth_clk",
                "override_behavior": "sets the rising clock threshold that reports and rearms each measurement window",
                "type": "real",
                "units": "V",
                "valid_range": "finite real value"
              },
              {
                "default": 0.45,
                "name": "vth_in",
                "override_behavior": "sets the rising threshold independently used to timestamp vinp and vinn",
                "type": "real",
                "units": "V",
                "valid_range": "finite real value"
              },
              {
                "default": 0,
                "name": "td",
                "override_behavior": "sets output transition delay after a reported measurement",
                "type": "real",
                "units": "s",
                "valid_range": "td >= 0"
              },
              {
                "default": 1e-12,
                "name": "tr",
                "override_behavior": "sets output transition smoothing",
                "type": "real",
                "units": "s",
                "valid_range": "tr > 0"
              },
              {
                "default": 1000000000.0,
                "name": "scale",
                "override_behavior": "multiplies the signed input edge-time difference before clipping",
                "type": "real",
                "units": "V/s",
                "valid_range": "finite real value"
              }
            ],
            "ports": [
              {
                "direction": "input",
                "discipline": "electrical",
                "name": "clk",
                "position": 0
              },
              {
                "direction": "input",
                "discipline": "electrical",
                "name": "vinp",
                "position": 1
              },
              {
                "direction": "input",
                "discipline": "electrical",
                "name": "vinn",
                "position": 2
              },
              {
                "direction": "output",
                "discipline": "electrical",
                "name": "vout",
                "position": 3
              }
            ],
            "role": "entry"
          }
        ],
        "path": "time_diff_detector.va"
      }
    ],
    "mode": "single_file"
  },
  "family_id": "117",
  "feedback": {
    "available_in_modes": [
