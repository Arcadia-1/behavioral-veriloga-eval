  "form": "dut",
  "identity": {
    "category": "mixed_signal",
    "difficulty": "D2",
    "level": "L1",
    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "Time Diff Detector"
  },
  "modeling_constraints": [
    "Use deterministic threshold-crossing event detection and per-window state.",
    "Capture no more than one rising edge per input in each clock window.",
    "Do not use fixed stimulus timestamps, current contributions, or validation-only hooks."
  ],
  "properties": [
    {
      "id": "P_FIRST_EDGE_CAPTURE",
      "observable_contract": "Within each clock window, only the first rising vinp crossing and first rising vinn crossing through vth_in define the stored timing measurement.",
      "required_signals": [
        "time",
        "clk",
        "vinp",
        "vinn",
        "vout"
      ]
    },
    {
      "id": "P_PREVIOUS_WINDOW_REPORT",
      "observable_contract": "At each rising clk crossing through vth_clk, vout reports the edge-time difference captured in the preceding valid clock window; if either input edge was absent, vout holds its previous value.",
      "required_signals": [
        "time",
        "clk",
        "vinp",
        "vinn",
        "vout"
      ]
    },
    {
      "id": "P_SIGNED_DIFFERENCE",
      "observable_contract": "The reported value preserves the sign of the vinp first-edge time minus the vinn first-edge time and applies the public scale factor.",
      "required_signals": [
        "time",
        "clk",
        "vinp",
        "vinn",
        "vout"
      ]
    },
    {
      "id": "P_OUTPUT_CLIP",
      "observable_contract": "The scaled reported voltage is bounded to the closed interval from -vdd to +vdd.",
      "required_signals": [
        "time",
        "clk",
        "vinp",
        "vinn",
        "vout"
      ]
    },
    {
      "id": "P_WINDOW_REARM",
      "observable_contract": "Each reporting clock edge rearms both input-edge detectors so the next window is measured independently.",
      "required_signals": [
        "time",
        "clk",
        "vinp",
        "vinn",
        "vout"
      ]
    },
    {
      "id": "P_OUTPUT_TRANSITION",
      "observable_contract": "Reported output changes use the declared td delay and tr transition time.",
      "required_signals": [
        "time",
        "clk",
        "vout"
      ]
    }
  ],
