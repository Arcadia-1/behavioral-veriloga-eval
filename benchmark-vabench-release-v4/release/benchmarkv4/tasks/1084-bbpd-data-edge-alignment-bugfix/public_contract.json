    "title": "BBPD Data Edge Alignment"
  },
  "modeling_constraints": [
    "Use deterministic event-driven edge timing and rail-referenced voltage-coded outputs.",
    "Retain data only on rising clock crossings and generate bounded correction pulses.",
    "Do not hard-code validation waveforms or use transistor-level, AC/noise, or simulator side channels."
  ],
  "problem_statement": "the supplied system violates the public contract",
  "properties": [
    {
      "id": "P_CLOCKED_RETIMING",
      "observable_contract": "Each rising clk edge captures the current data logic level onto retimed_data, which holds between clock edges.",
      "required_signals": [
        "time",
        "clk",
        "data",
        "retimed_data"
      ]
    },
    {
      "id": "P_EARLY_TRANSITION_UP",
      "observable_contract": "A data transition closer to the upcoming nominal clock edge and outside the deadzone produces an UP pulse of pulse_w duration.",
      "required_signals": [
        "time",
        "clk",
        "data",
        "up",
        "dn"
      ]
    },
    {
      "id": "P_LATE_TRANSITION_DN",
      "observable_contract": "A data transition closer to the previous nominal clock edge and outside the deadzone produces a DN pulse of pulse_w duration.",
      "required_signals": [
        "time",
        "clk",
        "data",
        "up",
        "dn"
      ]
    },
    {
      "id": "P_DEADZONE_SUPPRESSION",
      "observable_contract": "Data transitions within deadzone of the relevant nominal clock edge produce neither correction pulse.",
      "required_signals": [
        "time",
        "clk",
        "data",
        "up",
        "dn"
      ]
    },
    {
      "id": "P_BOTH_DATA_POLARITIES",
      "observable_contract": "Both rising and falling data transitions participate in timing classification.",
      "required_signals": [
        "time",
        "clk",
        "data",
        "up",
        "dn"
      ]
    },
    {
      "id": "P_MUTUAL_EXCLUSION",
      "observable_contract": "UP and DN are mutually exclusive apart from finite analog transition overlap and use the vdd-to-vss logic range.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "up",
        "dn"
      ]
    }
  ],
