  ],
  "properties": [
    {
      "id": "P_ON_EACH_RISING_CLOCK_CROSSING_COMPUTE",
      "observable_contract": "Update the stored output and residual metric only on each rising clk crossing.",
      "required_signals": [
        "time",
        "clk",
        "en",
        "gain_ctrl",
        "offset_ctrl",
        "out",
        "raw",
        "resid_metric",
        "rst"
      ]
    },
    {
      "id": "P_MAP_GAIN_CTRL_TO_A_PUBLIC",
      "observable_contract": "Let gain = gain_base + gain_span * clip01(V(gain_ctrl) / vhi), offset = V(offset_ctrl) - center, and transformed = center + gain * (V(raw) - center) + offset.",
      "required_signals": [
        "time",
        "clk",
        "en",
        "gain_ctrl",
        "offset_ctrl",
        "out",
        "raw",
        "resid_metric",
        "rst"
      ]
    },
    {
      "id": "P_CLEAR_OUTPUT_AND_METRIC_WHILE_RESET",
      "observable_contract": "At a rising edge, V(rst) > vth or V(en) <= vth stores both outputs at 0 V; otherwise store out = clamp(transformed, 0, vhi).",
      "required_signals": [
        "time",
        "clk",
        "en",
        "gain_ctrl",
        "offset_ctrl",
        "out",
        "raw",
        "resid_metric",
        "rst"
      ]
    },
    {
      "id": "P_EXPOSE_A_BOUNDED_RESIDUAL_METRIC_FOR",
      "observable_contract": "Store resid_metric = vhi * clip01(abs(transformed - V(raw)) / resid_fullscale), where clip01 limits its argument to [0, 1].",
      "required_signals": [
        "time",
        "clk",
        "en",
        "gain_ctrl",
        "offset_ctrl",
        "out",
        "raw",
        "resid_metric",
        "rst"
      ]
    },
    {
      "id": "P_USE_LOCAL_ANALOG_HELPER_FUNCTIONS_RATHER",
      "observable_contract": "Use local analog helper functions rather than user task/endtask syntax.",
      "required_signals": [
        "time",
        "clk",
        "en",
        "gain_ctrl",
        "offset_ctrl",
        "out",
        "raw",
        "resid_metric",
        "rst"
      ]
    }
  ],
