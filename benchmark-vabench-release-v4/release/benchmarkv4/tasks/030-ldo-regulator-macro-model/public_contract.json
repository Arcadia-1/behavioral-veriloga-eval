    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "LDO Regulator Macro Model"
  },
  "modeling_constraints": [
    "Treat vin as a bounded load or disturbance control, not as a supply rail.",
    "Use voltage-domain sampled settling only.",
    "Do not use current contributions, transistor devices, AC/noise analysis, KCL/KVL regulation loops, or validation side channels."
  ],
  "properties": [
    {
      "id": "P_INITIAL_AND_RESET_STATE",
      "observable_contract": "Initialization or active-high reset sets out to 0.60 V and metric to 0.9 V.",
      "required_signals": [
        "time",
        "rst",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_LOAD_TARGET",
      "observable_contract": "At each eligible rising clock crossing, vin is clamped to 0 through 0.9 V and target equals 0.62 V minus 0.055 times that load.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_FIRST_ORDER_REGULATION",
      "observable_contract": "Out advances by 0.35 of the remaining target error on each eligible rising clock crossing.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out"
      ]
    },
    {
      "id": "P_REGULATED_OUTPUT_CLAMP",
      "observable_contract": "The held output remains within 0.25 V through 0.75 V.",
      "required_signals": [
        "time",
        "out"
      ]
    },
    {
      "id": "P_ERROR_METRIC",
      "observable_contract": "Metric equals 0.9 V minus four times the absolute output-to-target error, clamped to 0 through 0.9 V.",
      "required_signals": [
        "time",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_CLOCKED_HOLD",
      "observable_contract": "Out and metric hold between rising clock crossings except for transition smoothing.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out",
        "metric"
      ]
    }
  ],
