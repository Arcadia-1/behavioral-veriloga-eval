  ],
  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_CLEAR",
      "observable_contract": "On reset or when disabled, clear signed tap weights and decision history; drive `tap_1`, `tap_0`, and `corrected_out` to `vcm`, and drive `error_metric` and `converged` to `vss`.",
      "required_signals": [
        "time",
        "sample_in",
        "decision_clk",
        "rst",
        "enable",
        "tap_1",
        "tap_0",
        "corrected_out",
        "error_metric",
        "converged"
      ]
    },
    {
      "id": "P_ON_EACH_ENABLED_DECISION_CLOCK_LATCH",
      "observable_contract": "On each enabled rising `decision_clk` edge, use the pre-edge history for the weight update, then latch `d = +1` when `sample_in >= vcm` else `-1` and shift `h0 = h1; h1 = d`.",
      "required_signals": [
        "time",
        "sample_in",
        "decision_clk",
        "rst",
        "enable",
        "tap_1",
        "tap_0",
        "corrected_out",
        "error_metric",
        "converged"
      ]
    },
    {
      "id": "P_USE_THE_PREVIOUS_DECISION_HISTORY_TO",
      "observable_contract": "With `x = sample_in-vcm`, compute `r0 = x-w1*h1-w0*h0`, update `w1 = clamp(w1+0.04*r0*h1,-0.18,0.18)` and `w0 = clamp(w0+0.025*r0*h0,-0.12,0.12)`, then recompute `r = x-w1*h1-w0*h0`.",
      "required_signals": [
        "time",
        "sample_in",
        "decision_clk",
        "rst",
        "enable",
        "tap_1",
        "tap_0",
        "corrected_out",
        "error_metric",
        "converged"
      ]
    },
    {
      "id": "P_EXPOSE_THE_ABSOLUTE_RESIDUAL_ON_ERROR",
      "observable_contract": "Drive `tap_1 = vcm+w1`, `tap_0 = vcm+w0`, `corrected_out = clamp(vcm+r,vss,vdd)`, and `error_metric = clamp(abs(r),vss,vdd)` after each enabled update.",
      "required_signals": [
        "time",
        "sample_in",
        "decision_clk",
        "rst",
        "enable",
        "tap_1",
        "tap_0",
        "corrected_out",
        "error_metric",
        "converged"
      ]
    },
    {
      "id": "P_ASSERT_CONVERGED_WHEN_THE_RESIDUAL_REMAINS",
      "observable_contract": "Drive `converged = vdd` after three consecutive enabled updates with `abs(r) <= residual_tol`, otherwise drive `vss`.",
      "required_signals": [
        "time",
        "sample_in",
        "decision_clk",
        "rst",
        "enable",
        "tap_1",
        "tap_0",
        "corrected_out",
        "error_metric",
        "converged"
      ]
    }
  ],
