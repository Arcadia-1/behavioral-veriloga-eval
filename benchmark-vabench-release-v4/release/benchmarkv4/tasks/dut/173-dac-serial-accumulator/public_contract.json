  "properties": [
    {
      "id": "P_SAMPLE_CLOCK_RESET",
      "observable_contract": "Each falling `clk_sample` crossing resets the accumulator and serial bit counter.",
      "required_signals": [
        "time",
        "clk_sample",
        "out"
      ]
    },
    {
      "id": "P_SARREADY_SERIAL_ACCUMULATION",
      "observable_contract": "Falling `clk_sarready` crossings during the active bit window add the sampled `data` bit to the accumulator.",
      "required_signals": [
        "time",
        "clk_sarready",
        "data",
        "out"
      ]
    },
    {
      "id": "P_BINARY_WEIGHT_ORDER",
      "observable_contract": "The first accepted serial bit has the largest binary weight and later bits use descending weights.",
      "required_signals": [
        "time",
        "clk_sarready",
        "data",
        "out"
      ]
    },
    {
      "id": "P_BIPOLAR_OUTPUT_MAPPING",
      "observable_contract": "The accumulated code is mapped to the required bipolar output range rather than an unipolar code.",
      "required_signals": [
        "time",
        "out"
      ]
    }
