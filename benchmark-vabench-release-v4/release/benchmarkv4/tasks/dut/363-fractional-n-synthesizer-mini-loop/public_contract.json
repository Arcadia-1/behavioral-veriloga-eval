  "properties": [
    {
      "id": "P_RESET_DISABLE_CLEAR",
      "observable_contract": "Reset or disabled operation clears accumulator/divider state and all public outputs.",
      "required_signals": [
        "time",
        "rst",
        "enable",
        "div_clk",
        "div_sel",
        "avg_ratio_metric",
        "valid"
      ]
    },
    {
      "id": "P_FRACTIONAL_SELECTION",
      "observable_contract": "The fraction code drives deterministic n_int versus n_int+1 selection through accumulator carry events.",
      "required_signals": [
        "time",
        "dco_clk",
        "frac_3",
        "frac_2",
        "frac_1",
        "frac_0",
        "div_sel"
      ]
    },
    {
      "id": "P_DCO_DERIVED_DIVIDER",
      "observable_contract": "div_clk transitions are derived only from counted rising dco_clk edges using the selected modulus.",
      "required_signals": [
        "time",
        "ref_clk",
        "dco_clk",
        "div_clk",
        "div_sel"
      ]
    },
    {
      "id": "P_RATIO_WINDOW",
      "observable_contract": "At each full window, avg_ratio_metric reports n_int plus the observed fraction of larger-modulus selections and valid pulses.",
      "required_signals": [
        "time",
        "dco_clk",
        "div_sel",
        "avg_ratio_metric",
        "valid"
      ]
    },
    {
      "id": "P_FRACTION_MONOTONICITY",
      "observable_contract": "Larger fraction commands produce nondecreasing average selected divide-ratio metrics over equal windows.",
      "required_signals": [
        "time",
        "frac_3",
        "frac_2",
        "frac_1",
        "frac_0",
        "avg_ratio_metric",
        "valid"
      ]
    }
  ],
