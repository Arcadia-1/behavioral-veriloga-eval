  "properties": [
    {
      "id": "P_RESET_DISABLE_CLEAR",
      "observable_contract": "On reset, clear trim code, corrected output, error metric, and done; when calibration is disabled, do not advance trim search state.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "cal_en",
        "corrected_out",
        "trim_4",
        "trim_3",
        "trim_2",
        "trim_1",
        "trim_0",
        "error_metric",
        "done"
      ]
    },
    {
      "id": "P_TRIM_SEARCH_DIRECTION",
      "observable_contract": "Update the signed 5-bit trim code in the direction that reduces sampled differential error.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "cal_en",
        "corrected_out",
        "trim_4",
        "trim_3",
        "trim_2",
        "trim_1",
        "trim_0",
        "error_metric",
        "done"
      ]
    },
    {
      "id": "P_CORRECTED_RESIDUAL",
      "observable_contract": "Drive corrected_out as the differential input minus the signed trim correction.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "cal_en",
        "corrected_out",
        "trim_4",
        "trim_3",
        "trim_2",
        "trim_1",
        "trim_0",
        "error_metric",
        "done"
      ]
    },
    {
      "id": "P_ERROR_METRIC",
      "observable_contract": "Expose the current residual offset on error_metric after each enabled trim update.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "cal_en",
        "corrected_out",
        "trim_4",
        "trim_3",
        "trim_2",
        "trim_1",
        "trim_0",
        "error_metric",
        "done"
      ]
    },
    {
      "id": "P_DONE_QUALIFICATION",
      "observable_contract": "Assert done only after four consecutive calibration updates with residual magnitude within error_tol.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "cal_en",
        "corrected_out",
        "trim_4",
        "trim_3",
        "trim_2",
        "trim_1",
        "trim_0",
        "error_metric",
        "done"
      ]
    }
  ],
