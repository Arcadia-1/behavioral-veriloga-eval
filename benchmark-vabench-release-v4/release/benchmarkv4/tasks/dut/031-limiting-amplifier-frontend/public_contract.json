    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "Limiting Amplifier Frontend"
  },
  "modeling_constraints": [
    "Use deterministic rising-edge sampled piecewise limiting behavior.",
    "Use smoothed voltage contributions only.",
    "Do not hard-code validation timing or use simulator-specific side channels."
  ],
  "properties": [
    {
      "id": "P_INITIAL_AND_RESET_COMMON_MODE",
      "observable_contract": "Initialization sets out to 0.45 V and metric to 0 V; an active-high reset sampled on a rising clk crossing restores the same state.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_LINEAR_REGION",
      "observable_contract": "For sampled input deviation from -0.09 V through 0.09 V, out equals 0.45 V plus 1.7 times the deviation and metric is 0 V.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_POSITIVE_LIMITING",
      "observable_contract": "Above the positive boundary, out follows 0.73 V plus 0.45 times excess deviation and metric is 0.85 V.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_NEGATIVE_LIMITING",
      "observable_contract": "Below the negative boundary, out follows 0.17 V plus 0.45 times excess negative deviation and metric is 0.85 V.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_OUTPUT_CLAMP",
      "observable_contract": "The final held output remains within 0.04 V through 0.86 V.",
      "required_signals": [
        "time",
        "out"
      ]
    },
    {
      "id": "P_CLOCKED_HOLD",
      "observable_contract": "Out and metric update only on rising clock crossings and hold between samples.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out",
        "metric"
      ]
    }
  ],
