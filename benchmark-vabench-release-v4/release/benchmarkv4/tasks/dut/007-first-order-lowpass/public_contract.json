        "time",
        "vin",
        "vout"
      ]
    },
    {
      "id": "P_STEP_MONOTONICITY",
      "observable_contract": "For a positive input step, vout is monotone and bounded by the input level.",
      "required_signals": [
        "time",
        "vin",
        "vout"
      ]
    },
    {
      "id": "P_LOW_PASS_RESPONSE",
