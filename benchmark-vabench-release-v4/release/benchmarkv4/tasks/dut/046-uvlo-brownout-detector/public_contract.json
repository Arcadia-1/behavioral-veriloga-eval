  "modeling_constraints": [
    "Use deterministic sampled voltage-domain hysteresis state.",
    "Do not use current contributions, transistor-level devices, AC/noise analysis, or KCL/KVL regulation loops.",
    "Do not add validation-only state, ports, or simulator-specific side channels."
  ],
  "properties": [
    {
      "id": "P_RESET_FAULT",
      "observable_contract": "Active reset clears the power-good out signal and drives metric to the public fault code 0.9 V.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_UPPER_TRIP_ASSERT",
      "observable_contract": "On a sampled update, vin strictly greater than 0.65 V asserts power-good out.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out"
      ]
    },
    {
      "id": "P_HYSTERESIS_HOLD",
      "observable_contract": "For sampled vin values from 0.55 V through 0.65 V inclusive, out preserves its previous power-good state.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out"
      ]
    },
    {
      "id": "P_BROWNOUT_CLEAR",
      "observable_contract": "On a sampled update, vin strictly less than 0.55 V clears out to the brownout state.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out"
      ]
    },
    {
      "id": "P_STATUS_DISTINCTION",
      "observable_contract": "Metric is the checker-observable status code: 0.1 V when out is power-good high and 0.9 V when reset, undervoltage, or brownout is active.",
      "required_signals": [
        "time",
        "vin",
        "out",
        "metric"
      ]
    }
  ],
