  "form": "dut",
  "identity": {
    "category": "calibration_dem_control",
    "difficulty": "D2",
    "level": "L2",
    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "Complete Calibration Loop"
  },
  "modeling_constraints": [
    "Use deterministic rising-edge sampled closed-loop calibration state.",
    "Use bounded state and smoothed voltage contributions only.",
    "Do not use current contributions, transistor-level devices, continuous-time operators, AC/noise analysis, or validation side channels."
  ],
  "properties": [
    {
      "id": "P_RESET_TO_TARGET",
      "observable_contract": "Active-high reset initializes out, trim_mon, residual_mon, and metric to their target-state values.",
      "required_signals": [
        "time",
        "rst",
        "out",
        "metric",
        "trim_mon",
        "residual_mon"
      ]
    },
    {
      "id": "P_CLOCKED_LOOP_UPDATE",
      "observable_contract": "After reset releases, calibration state updates on rising clk crossings and holds between updates.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "trim_mon",
        "residual_mon"
      ]
    },
    {
      "id": "P_RESIDUAL_OBSERVATION",
      "observable_contract": "Residual_mon exposes clamp(target + raw_error + (trim_mon_next - target), vmin, vmax), where raw_error is V(vin)-target and trim_mon_next is the current edge's bounded negative-feedback trim update.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "trim_mon",
        "residual_mon"
      ]
    },
    {
      "id": "P_NEGATIVE_FEEDBACK_DIRECTION",
      "observable_contract": "The trim correction uses trim_mon_next = clamp(trim_mon - loop_gain * residual_before_update, vmin, vmax), so positive residual decreases trim and negative residual increases trim.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out",
        "trim_mon",
        "residual_mon"
      ]
    },
    {
      "id": "P_PLANT_CONVERGENCE",
      "observable_contract": "Out follows out_next = clamp(out + plant_alpha * (residual_mon_next - out), vmin, vmax) on each non-reset update.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out",
        "residual_mon"
      ]
    },
    {
      "id": "P_BOUNDS_AND_METRIC",
      "observable_contract": "Bounded analog states remain within vmin through vmax, while metric equals clamp(0.9 - 1.5 * abs(out-target), 0.0, 0.9) after each update.",
      "required_signals": [
        "time",
        "out",
        "metric",
        "trim_mon",
        "residual_mon"
      ]
    }
  ],
