  "trace_contract": {"required_signals": ["time", "vdd", "vss", "in", "clk", "out"]},
  "modeling_constraints": ["Use deterministic rising-edge sampled state and intersample hold.", "Use smoothed voltage contributions only.", "Do not use current contributions, ddt(), idt(), extra observability ports, or validation side channels."]
