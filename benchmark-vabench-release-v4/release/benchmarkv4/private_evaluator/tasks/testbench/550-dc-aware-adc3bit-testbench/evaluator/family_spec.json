              },
              {
                "name": "vh",
                "type": "real",
                "default": 0.9,
                "units": "V",
                "valid_range": "vh > 0",
                "override_behavior": "sets the voltage-coded output high level"
              },
              {
                "name": "tr",
                "type": "real",
                "default": 2e-11,
                "units": "s",
                "valid_range": "tr > 0",
                "override_behavior": "sets output transition smoothing"
              }
            ]
          }
        ]
      }
    ]
