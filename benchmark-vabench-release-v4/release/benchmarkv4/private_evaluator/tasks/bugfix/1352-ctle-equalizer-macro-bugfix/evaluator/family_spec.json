  "properties": [
    {
      "id": "P_RESET_INITIALIZES_THE_EQUALIZED_OUTPUT_TO",
      "observable_contract": "Reset initializes the equalized output to common mode and clears metric outputs.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "boost_2",
        "boost_1",
        "boost_0",
        "vout",
        "edge_metric",
        "sat_flag"
      ]
    },
    {
      "id": "P_ON_EACH_RISING_CLK_SAMPLE_THE",
      "observable_contract": "On each rising `clk`, sample the boost code and the current input.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "boost_2",
        "boost_1",
        "boost_0",
        "vout",
        "edge_metric",
        "sat_flag"
      ]
    },
    {
      "id": "P_DRIVE_VOUT_FROM_THE_CURRENT_INPUT",
      "observable_contract": "Drive `vout` from the current input plus a boost-code-scaled edge term relative to the previous sampled input.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "boost_2",
        "boost_1",
        "boost_0",
        "vout",
        "edge_metric",
        "sat_flag"
      ]
    },
    {
      "id": "P_CLAMP_VOUT_TO_THE_VSS_TO",
      "observable_contract": "Clamp `vout` to the `vss` to `vdd` range.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "boost_2",
        "boost_1",
        "boost_0",
        "vout",
        "edge_metric",
        "sat_flag"
      ]
    },
    {
      "id": "P_EDGE_METRIC_REPORTS_THE_ABSOLUTE_BOOSTED",
      "observable_contract": "`edge_metric` reports the absolute boosted edge contribution after clipping to full scale.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "boost_2",
        "boost_1",
        "boost_0",
        "vout",
        "edge_metric",
        "sat_flag"
      ]
    },
    {
      "id": "P_SAT_FLAG_IS_HIGH_WHEN_THE",
      "observable_contract": "`sat_flag` is high when the unclamped equalized target would exceed either output rail.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "boost_2",
        "boost_1",
        "boost_0",
        "vout",
        "edge_metric",
        "sat_flag"
      ]
    }
