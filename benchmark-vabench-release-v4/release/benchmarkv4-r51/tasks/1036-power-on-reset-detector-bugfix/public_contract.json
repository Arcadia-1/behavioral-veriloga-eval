    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "Power-On Reset Detector"
  },
  "modeling_constraints": [
    "Use deterministic voltage-domain reset-sequencing behavior.",
    "Do not use current contributions, transistor-level devices, AC/noise analysis, or KCL/KVL regulation loops.",
    "Do not encode a particular validation stimulus, stop time, or sample window."
  ],
  "problem_statement": "the supplied system violates the public contract",
  "properties": [
    {
      "id": "P_RESET_ASSERTED_UNSAFE",
      "observable_contract": "Out is active-high reset and remains asserted while rst is high or vin is below vtrip.",
      "required_signals": [
        "time",
        "rst",
        "vin",
        "out"
      ]
    },
    {
      "id": "P_DELAYED_RELEASE",
      "observable_contract": "After rst releases and vin is power-good, out stays asserted for four rising clk updates before deasserting.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out"
      ]
    },
    {
      "id": "P_RELEASE_STATUS",
      "observable_contract": "Metric uses an intermediate status level during the release delay, is high after delayed reset release completes, and is cleared when reset is reasserted or supply is not power-good.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_FAULT_REASSERTION",
      "observable_contract": "A new reset assertion or a brownout below vtrip immediately reasserts out and clears the accumulated release delay, independent of the next clk edge.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_VOLTAGE_CODED_LEVELS",
      "observable_contract": "Out and metric use bounded voltage-coded low and high levels with finite transition smoothing.",
      "required_signals": [
        "time",
        "out",
        "metric"
      ]
    }
  ],
