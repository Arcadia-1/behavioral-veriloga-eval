  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_CLEAR",
      "observable_contract": "On reset or when disabled, clear tap states, output, adapt metric, and `done`.",
      "required_signals": [
        "time",
        "err_in",
        "clk",
        "rst",
        "enable",
        "tap_pre",
        "tap_post",
        "main_out",
        "adapt_metric",
        "done"
      ]
    },
    {
      "id": "P_ON_EACH_ENABLED_RISING_CLK_EDGE",
      "observable_contract": "On each enabled rising `clk` edge, update pre and post tap signs according to `err_in - vcm`.",
      "required_signals": [
        "time",
        "err_in",
        "clk",
        "rst",
        "enable",
        "tap_pre",
        "tap_post",
        "main_out",
        "adapt_metric",
        "done"
      ]
    },
    {
      "id": "P_DRIVE_MAIN_OUT_AS_THE_CURRENT",
      "observable_contract": "Drive `main_out` as the current main cursor correction around `vcm`.",
      "required_signals": [
        "time",
        "err_in",
        "clk",
        "rst",
        "enable",
        "tap_pre",
        "tap_post",
        "main_out",
        "adapt_metric",
        "done"
      ]
    },
    {
      "id": "P_EXPOSE_AGGREGATE_TAP_MAGNITUDE_ON_ADAPT",
      "observable_contract": "Expose aggregate tap magnitude on `adapt_metric`.",
      "required_signals": [
        "time",
        "err_in",
        "clk",
        "rst",
        "enable",
        "tap_pre",
        "tap_post",
        "main_out",
        "adapt_metric",
        "done"
      ]
    },
    {
      "id": "P_ASSERT_DONE_AFTER_SIX_ENABLED_ADAPTATION",
      "observable_contract": "Assert `done` after six enabled adaptation updates.",
      "required_signals": [
        "time",
        "err_in",
        "clk",
        "rst",
        "enable",
        "tap_pre",
        "tap_post",
        "main_out",
        "adapt_metric",
        "done"
      ]
    }
  ],
