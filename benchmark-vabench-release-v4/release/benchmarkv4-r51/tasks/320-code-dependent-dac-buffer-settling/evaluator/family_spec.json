  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_CLEAR",
      "observable_contract": "On reset or when disabled, drive `vout` to `vcm` and drive `target_dbg`, `settling_metric`, and `settled` to `vss`.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "code_3",
        "code_2",
        "code_1",
        "code_0",
        "vout",
        "target_dbg",
        "settling_metric",
        "settled"
      ]
    },
    {
      "id": "P_ON_EACH_ENABLED_RISING_CLK_EDGE",
      "observable_contract": "Decode code 0..15 linearly from `vss` to `vdd`; on each enabled rising `clk` edge update the buffered output toward that target.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "code_3",
        "code_2",
        "code_1",
        "code_0",
        "vout",
        "target_dbg",
        "settling_metric",
        "settled"
      ]
    },
    {
      "id": "P_APPLY_A_CODE_DEPENDENT_SETTLING_STEP",
      "observable_contract": "Apply a code-dependent settling step so large code jumps take more updates to settle.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "code_3",
        "code_2",
        "code_1",
        "code_0",
        "vout",
        "target_dbg",
        "settling_metric",
        "settled"
      ]
    },
    {
      "id": "P_EXPOSE_THE_CURRENT_TARGET_ON_TARGET",
      "observable_contract": "Expose the current target on `target_dbg` and the remaining error on `settling_metric`.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "code_3",
        "code_2",
        "code_1",
        "code_0",
        "vout",
        "target_dbg",
        "settling_metric",
        "settled"
      ]
    },
    {
      "id": "P_ASSERT_SETTLED_AFTER_THE_REMAINING_ERROR",
      "observable_contract": "Assert `settled` after the remaining error stays below `settle_tol` for two enabled updates.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "enable",
        "code_3",
        "code_2",
        "code_1",
        "code_0",
        "vout",
        "target_dbg",
        "settling_metric",
        "settled"
      ]
    }
  ],
