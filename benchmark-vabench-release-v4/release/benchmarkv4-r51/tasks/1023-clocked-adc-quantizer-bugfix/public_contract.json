  "properties": [
    {
      "id": "P_RISING_EDGE_QUANTIZATION",
      "observable_contract": "At each rising CLK crossing, VIN is quantized into one of eight uniform bins spanning vrefn to vrefp.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "dout2",
        "dout1",
        "dout0"
      ]
    },
    {
      "id": "P_CODE_CLAMP",
      "observable_contract": "Samples at or outside the conversion endpoints produce codes clamped to the inclusive range 0 through 7.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "dout2",
        "dout1",
        "dout0"
      ]
    },
    {
      "id": "P_BINARY_RAIL_ENCODING",
      "observable_contract": "DOUT2 through DOUT0 encode the held code from MSB to LSB using VDD for one and VSS for zero.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "dout2",
        "dout1",
        "dout0"
      ]
    },
    {
      "id": "P_CODE_MONOTONICITY",
      "observable_contract": "For increasing VIN samples across the conversion range, the sampled three-bit code is nondecreasing.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "dout2",
        "dout1",
        "dout0"
      ]
    },
    {
      "id": "P_SAMPLE_HOLD",
      "observable_contract": "The output code remains stable between rising CLK crossings even when VIN changes.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "dout2",
        "dout1",
        "dout0"
      ]
    }
