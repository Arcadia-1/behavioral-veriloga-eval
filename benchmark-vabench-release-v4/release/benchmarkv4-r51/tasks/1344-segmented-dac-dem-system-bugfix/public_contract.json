        "sel_2",
        "sel_1",
        "sel_0"
      ]
    },
    {
      "id": "P_DEM_POINTER_ADVANCE",
      "observable_contract": "After each update the pointer advances by the requested unit count modulo eight.",
      "required_signals": [
