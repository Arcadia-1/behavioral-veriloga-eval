    {
      "id": "P_DEM_DAC_TRANSFER",
      "observable_contract": "Each rising clock samples the unsigned 6-bit code and drives vref times code divided by 63.",
      "required_signals": [
        "time",
        "clk",
        "code_5",
        "code_4",
        "code_3",
        "code_2",
        "code_1",
        "code_0",
        "vout"
      ]
    },
    {
      "id": "P_DEM_ROTATED_MASK",
      "observable_contract": "The selection mask contains the requested number of consecutive circular unit elements starting at the prior pointer.",
      "required_signals": [
        "time",
        "clk",
        "code_5",
        "code_4",
        "code_3",
        "sel_7",
        "sel_6",
        "sel_5",
