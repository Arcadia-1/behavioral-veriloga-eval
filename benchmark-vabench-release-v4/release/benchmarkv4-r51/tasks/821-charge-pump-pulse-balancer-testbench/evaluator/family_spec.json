  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_DRIVE",
      "observable_contract": "On reset or when disabled, drive `vctrl` to `vcm`, clear imbalance, and clear `balanced`.",
      "required_signals": [
        "time",
        "up",
        "dn",
        "clk",
        "rst",
        "enable",
        "vctrl",
        "imbalance_metric",
        "balanced"
      ]
    },
    {
      "id": "P_ON_EACH_RISING_CLK_EDGE_OBSERVE",
      "observable_contract": "On each rising `clk` edge, observe voltage-coded `up` and `dn` pulse states.",
      "required_signals": [
        "time",
        "up",
        "dn",
        "clk",
        "rst",
        "enable",
        "vctrl",
        "imbalance_metric",
        "balanced"
      ]
    },
    {
      "id": "P_INCREASE_VCTRL_FOR_UP_ONLY_DECREASE",
      "observable_contract": "Increase `vctrl` for UP-only, decrease it for DN-only, and hold for simultaneous or inactive pulses.",
      "required_signals": [
        "time",
        "up",
        "dn",
        "clk",
        "rst",
        "enable",
        "vctrl",
        "imbalance_metric",
        "balanced"
      ]
    },
    {
      "id": "P_DRIVE_IMBALANCE_METRIC_FROM_THE_ACCUMULATED",
      "observable_contract": "Drive `imbalance_metric` from the accumulated UP-minus-DN activity.",
      "required_signals": [
        "time",
        "up",
        "dn",
        "clk",
        "rst",
        "enable",
        "vctrl",
        "imbalance_metric",
        "balanced"
      ]
    },
    {
      "id": "P_ASSERT_BALANCED_ONLY_WHEN_THE_RECENT",
      "observable_contract": "Assert `balanced` only when the recent absolute imbalance is below `balance_tol`.",
      "required_signals": [
        "time",
        "up",
        "dn",
        "clk",
        "rst",
        "enable",
        "vctrl",
        "imbalance_metric",
        "balanced"
      ]
    }
  ],
