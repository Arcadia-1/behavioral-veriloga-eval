  "family_id": "110",
  "form": "dut",
  "identity": {
    "category": "data_converter",
    "difficulty": "D2",
    "level": "L1",
    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "Start Gated Offset Search"
  },
  "modeling_constraints": [
    "Gate and reinitialize the search from START and update it only on falling CLK events.",
    "Maintain symmetric voltage-domain outputs around the public vcm parameter.",
    "Do not use current contributions, ddt(), idt(), validation hooks, hard-coded waveform sample points, or simulator-specific side channels."
  ],
  "properties": [
    {
      "id": "P_DISABLED_COMMON_MODE",
      "observable_contract": "While START is below vstart_th, VINP and VINN both equal vcm and the internal search state is reset.",
      "required_signals": [
        "time",
        "start",
        "vinp",
        "vinn"
      ]
    },
    {
      "id": "P_START_REINITIALIZATION",
      "observable_contract": "Each rising START crossing through vstart_th reinitializes differential value to zero, step to 20 mV, and remembered direction high.",
      "required_signals": [
        "time",
        "start",
        "vinp",
        "vinn"
      ]
    },
    {
      "id": "P_FALLING_CLOCK_UPDATES",
      "observable_contract": "While START is high, search updates occur only on falling CLK crossings through vdd/2.",
      "required_signals": [
        "time",
        "clk",
        "start",
        "vout",
        "vinp",
        "vinn"
      ]
    },
    {
      "id": "P_DECISION_DIRECTED_STEP",
      "observable_contract": "At each enabled update, VOUT above vdd/2 moves the differential value positive and VOUT at or below vdd/2 moves it negative.",
      "required_signals": [
        "time",
        "clk",
        "vout",
        "vinp",
        "vinn"
      ]
    },
    {
      "id": "P_REVERSAL_STEP_HALVING",
      "observable_contract": "When the newly sampled decision direction differs from the remembered direction, the current step is halved before applying the move.",
      "required_signals": [
        "time",
        "clk",
        "vout",
        "vinp",
        "vinn"
      ]
    },
    {
      "id": "P_COMMON_MODE_AND_DIFFERENTIAL",
      "observable_contract": "During search, the average of VINP and VINN remains vcm and their difference equals the accumulated differential search value.",
      "required_signals": [
        "time",
        "start",
        "vinp",
        "vinn"
      ]
    }
  ],
  "schema_version": "v4-benchmarkv4-public-contract-v1",
