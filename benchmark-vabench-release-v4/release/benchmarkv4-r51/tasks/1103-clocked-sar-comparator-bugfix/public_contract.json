    "level": "L1",
    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "Clocked SAR Comparator"
  },
  "modeling_constraints": [
    "Update decision state only at CMPCK crossings through vdd/2 and hold it between events.",
    "Drive smooth voltage-coded outputs using td_cmp and tr.",
    "Do not use current contributions, ddt(), idt(), validation hooks, testbench-specific sample points, or simulator-specific side channels."
  ],
  "problem_statement": "the supplied system violates the public contract",
  "properties": [
    {
      "id": "P_INITIAL_PRECHARGE",
      "observable_contract": "Both decision outputs initialize high at vdd.",
      "required_signals": [
        "time",
        "dcmpn",
        "dcmpp"
      ]
    },
    {
      "id": "P_FALLING_EDGE_PRECHARGE",
      "observable_contract": "Each falling CMPCK crossing through vdd/2 resets both DCMPN and DCMPP high.",
      "required_signals": [
        "time",
        "cmpck",
        "dcmpn",
        "dcmpp"
      ]
    },
    {
      "id": "P_POSITIVE_DIFFERENTIAL_DECISION",
      "observable_contract": "On a rising CMPCK crossing with VINP greater than VINN, DCMPP is high and DCMPN is low.",
      "required_signals": [
        "time",
        "cmpck",
        "vinp",
        "vinn",
        "dcmpn",
        "dcmpp"
      ]
    },
    {
      "id": "P_NEGATIVE_DIFFERENTIAL_DECISION",
      "observable_contract": "On a rising CMPCK crossing with VINP less than VINN, DCMPN is high and DCMPP is low.",
      "required_signals": [
        "time",
        "cmpck",
        "vinp",
        "vinn",
        "dcmpn",
        "dcmpp"
      ]
    },
    {
      "id": "P_EQUAL_INPUT_DECISION",
      "observable_contract": "On a rising CMPCK crossing with equal differential inputs, both decision outputs become low.",
      "required_signals": [
        "time",
        "cmpck",
        "vinp",
        "vinn",
        "dcmpn",
        "dcmpp"
      ]
    },
    {
      "id": "P_LATCHED_HOLD_AND_TIMING",
      "observable_contract": "The precharged or decided state holds between clock events and output changes use td_cmp delay and tr smoothing.",
      "required_signals": [
        "time",
        "cmpck",
        "dcmpn",
        "dcmpp"
      ]
    }
  ],
