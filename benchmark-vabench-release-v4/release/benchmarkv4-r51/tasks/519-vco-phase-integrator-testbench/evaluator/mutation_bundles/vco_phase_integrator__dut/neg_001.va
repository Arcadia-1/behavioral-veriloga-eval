// vaBench partial-pass negative 1 for vco_phase_integrator:dut
// Intended to preserve interface/smoke behavior while failing full checks.
`include "constants.vams"
`include "disciplines.vams"
module vco_phase_integrator(vctrl,phase,clk);
    input vctrl; output phase,clk; electrical vctrl,phase,clk; parameter real tr=200p; real ph; integer c;
    analog begin @(initial_step) begin ph=0.0; c=0; end @(timer(0,1n)) begin ph=ph; if (ph>=0.95) begin ph=ph-1.0; c=0; end end V(phase)<+transition(ph,0,tr,tr); V(clk)<+transition(c?0.9:0.0,0,tr,tr); end
endmodule
