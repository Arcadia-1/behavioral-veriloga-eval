  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_CLEAR",
      "observable_contract": "On reset or when disabled, clear early/late flags, eye metric, lock hint, and `valid`.",
      "required_signals": [
        "time",
        "data_in",
        "sample_clk",
        "rst",
        "enable",
        "early",
        "late",
        "eye_metric",
        "lock_hint",
        "valid"
      ]
    },
    {
      "id": "P_ON_EACH_SAMPLING_CLOCK_EDGE_COMPARE",
      "observable_contract": "On each sampling-clock edge, compare the sampled data level with the previous sample.",
      "required_signals": [
        "time",
        "data_in",
        "sample_clk",
        "rst",
        "enable",
        "early",
        "late",
        "eye_metric",
        "lock_hint",
        "valid"
      ]
    },
    {
      "id": "P_RAISE_EARLY_OR_LATE_ACCORDING_TO",
      "observable_contract": "Raise `early` or `late` according to the sign of the edge-position proxy around the sample instant.",
      "required_signals": [
        "time",
        "data_in",
        "sample_clk",
        "rst",
        "enable",
        "early",
        "late",
        "eye_metric",
        "lock_hint",
        "valid"
      ]
    },
    {
      "id": "P_DRIVE_EYE_METRIC_FROM_RECENT_TRANSITION",
      "observable_contract": "Drive `eye_metric` from recent transition stability and sample margin.",
      "required_signals": [
        "time",
        "data_in",
        "sample_clk",
        "rst",
        "enable",
        "early",
        "late",
        "eye_metric",
        "lock_hint",
        "valid"
      ]
    },
    {
      "id": "P_ASSERT_LOCK_HINT_AFTER_FOUR_CONSECUTIVE",
      "observable_contract": "Assert `lock_hint` after four consecutive samples with eye metric above `eye_min`.",
      "required_signals": [
        "time",
        "data_in",
        "sample_clk",
        "rst",
        "enable",
        "early",
        "late",
        "eye_metric",
        "lock_hint",
        "valid"
      ]
    }
  ],
