  "modeling_constraints": [
    "Use deterministic voltage-coded ramp, chirp, and gated burst generation.",
    "Use smoothed voltage contributions only; absolute transient time may shape public stimulus segments.",
    "Do not use current contributions, ddt(), idt(), transistor-level devices, waveform tables, validation hooks, or simulator-specific side channels."
  ],
  "properties": [
    {
      "id": "P_RESET_IDLE",
      "observable_contract": "When rst is above the 0.45 V control threshold, out is held near 0.45 V and metric is low.",
      "required_signals": [
        "time",
        "rst",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_RAMP_MODE",
      "observable_contract": "For mode below 0.30 V outside reset, out produces a monotonic ramp segment from about 0.18 V toward 0.45 V and metric is near 0.20 V.",
      "required_signals": [
        "time",
        "rst",
        "mode",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_CHIRP_MODE",
      "observable_contract": "For mode from 0.30 V through below 0.60 V, out is a sine segment centered near 0.45 V whose instantaneous frequency increases over the segment, with metric near 0.50 V.",
      "required_signals": [
        "time",
        "rst",
        "mode",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_BURST_GATE",
      "observable_contract": "For mode at or above 0.60 V and gate high, out produces a deterministic PRBS-like burst between the low and high stimulus levels.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "mode",
        "gate",
        "out"
      ]
    },
    {
      "id": "P_BURST_IDLE",
      "observable_contract": "In burst mode with gate low, out returns near 0.45 V and metric reports the idle rather than active-burst status.",
      "required_signals": [
        "time",
        "rst",
        "mode",
        "gate",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_CONTROL_DRIVEN_SELECTION",
      "observable_contract": "Mode and gate behavior follows the voltage-coded inputs over arbitrary legal control schedules rather than a fixed stimulus timeline.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "mode",
        "gate",
        "out",
        "metric"
      ]
    }
  ],
