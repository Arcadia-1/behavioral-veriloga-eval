  "modeling_constraints": [
    "Use deterministic rising-edge voltage-domain state updates.",
    "Clamp the public target before applying the declared settling step.",
    "Do not introduce current-domain regulation, undeclared rails, or validation-only state."
  ],
  "properties": [
    {
      "id": "P_CLOCKED_UPDATE",
      "observable_contract": "Bias state changes are evaluated on rising clk crossings through vth and hold between clock updates.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_DISABLE_RESET",
      "observable_contract": "At an update, rst above vth or vin below 0.25 V disables the generator, returning out and metric to 0 V.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_TRIM_TARGET",
      "observable_contract": "When enabled, the target is 0.28 V plus 0.55 times (vin minus 0.25 V) divided by 0.65 V, clamped to 0.28 V through 0.82 V.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out"
      ]
    },
    {
      "id": "P_SETTLING",
      "observable_contract": "At each enabled update, out advances by 45 percent of the remaining difference to the current target rather than jumping directly.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out"
      ]
    },
    {
      "id": "P_MONOTONIC_TRIM",
      "observable_contract": "For otherwise equal enabled histories, a higher trim request produces a target and settled out value no lower than a smaller request.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out"
      ]
    },
    {
      "id": "P_ENABLE_METRIC",
      "observable_contract": "metric approaches 0.9 V while enabled and 0 V while disabled, with transition smoothing set by tr.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "metric"
      ]
    }
  ],
