      "id": "P_DIVIDED_PERIOD",
      "observable_contract": "For ratios above one, successive clk_out rising edges span the decoded number of clk_in rising edges.",
      "required_signals": [
        "time",
        "clk_in",
        "clk_out"
      ]
    },
    {
      "id": "P_ODD_RATIO_DUTY",
      "observable_contract": "Odd ratios retain both phases with floor/ceil segment lengths differing by at most one input cycle.",
