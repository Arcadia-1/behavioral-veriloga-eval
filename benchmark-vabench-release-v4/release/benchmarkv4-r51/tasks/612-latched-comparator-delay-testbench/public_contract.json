  "modeling_constraints": [
    "Initialize rail references and the random seed at initial_step, then sample only on rising CLK midpoint crossings.",
    "Use seeded repeatable decision noise and a smoothed supply-referenced voltage contribution for DOUT.",
    "Do not use current contributions, ddt(), idt(), validation hooks, hard-coded waveform sample points, or simulator-specific side channels."
  ],
  "properties": [
    {
      "id": "P_SUPPLY_REFERENCED_THRESHOLD",
      "observable_contract": "The latch clock threshold is the midpoint of VDD and GND, and DOUT low and high levels use those same rails.",
      "required_signals": [
        "time",
        "vdd",
        "clk",
        "dout"
      ]
    },
    {
      "id": "P_RISING_EDGE_LATCH",
      "observable_contract": "Each rising CLK midpoint crossing latches one comparison result; falling crossings do not resample the input.",
      "required_signals": [
        "time",
        "vdd",
        "clk",
        "vinn",
        "vinp",
        "dout"
      ]
    },
    {
      "id": "P_OFFSET_DECISION",
      "observable_contract": "With vn zero, DOUT latches high exactly when VINP minus VINN exceeds vos and low otherwise.",
      "required_signals": [
        "time",
        "clk",
        "vinn",
        "vinp",
        "dout"
      ]
    },
    {
      "id": "P_SEEDED_RANDOM_TERM",
      "observable_contract": "With vn nonzero, each latch decision includes a normal input-referred term scaled by vn from the sequence initialized by seed_init.",
      "required_signals": [
        "time",
        "clk",
        "vinn",
        "vinp",
        "dout"
      ]
    },
    {
      "id": "P_INTEREDGE_HOLD",
      "observable_contract": "The latched decision holds between rising CLK events even if VINP or VINN changes.",
      "required_signals": [
        "time",
        "clk",
        "vinn",
        "vinp",
        "dout"
      ]
    },
    {
      "id": "P_DELAY_AND_SMOOTHING",
      "observable_contract": "DOUT applies td delay and tr transition smoothing after each latch event.",
      "required_signals": [
        "time",
        "clk",
        "dout"
      ]
    }
  ],
