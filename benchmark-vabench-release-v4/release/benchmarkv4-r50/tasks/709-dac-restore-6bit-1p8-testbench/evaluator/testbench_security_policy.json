{
  "allowed_dut_root": "./dut",
  "candidate_artifacts": [
    "testbench.scs"
  ],
  "forbid": [
    "undeclared_include",
    "absolute_path",
    "path_traversal",
    "process_execution",
    "network_access",
    "dut_redefinition",
    "direct_dut_output_drive",
    "private_hierarchical_probe",
    "unbounded_resource_use"
  ],
  "require": [
    "declared_dut_binding",
    "transient_analysis",
    "all_required_public_traces"
  ],
  "schema_version": "v4-testbench-security-policy-v1"
}
