  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_CLEAR",
      "observable_contract": "On reset or when disabled, clear boost code, output, metric, and `locked`.",
      "required_signals": [
        "time",
        "vin",
        "edge_metric_in",
        "clk",
        "rst",
        "enable",
        "boost_2",
        "boost_1",
        "boost_0",
        "vout",
        "adapt_metric",
        "locked"
      ]
    },
    {
      "id": "P_ON_EACH_ENABLED_RISING_CLK_EDGE",
      "observable_contract": "On each enabled rising `clk` edge, compare `edge_metric_in` with `edge_target`.",
      "required_signals": [
        "time",
        "vin",
        "edge_metric_in",
        "clk",
        "rst",
        "enable",
        "boost_2",
        "boost_1",
        "boost_0",
        "vout",
        "adapt_metric",
        "locked"
      ]
    },
    {
      "id": "P_INCREASE_BOOST_CODE_WHEN_EDGE_METRIC",
      "observable_contract": "Increase boost code when edge metric is too low and decrease it when too high.",
      "required_signals": [
        "time",
        "vin",
        "edge_metric_in",
        "clk",
        "rst",
        "enable",
        "boost_2",
        "boost_1",
        "boost_0",
        "vout",
        "adapt_metric",
        "locked"
      ]
    },
    {
      "id": "P_DRIVE_VOUT_AS_A_BOOSTED_VERSION",
      "observable_contract": "Drive `vout` as a boosted version of `vin - vcm` using the active boost code.",
      "required_signals": [
        "time",
        "vin",
        "edge_metric_in",
        "clk",
        "rst",
        "enable",
        "boost_2",
        "boost_1",
        "boost_0",
        "vout",
        "adapt_metric",
        "locked"
      ]
    },
    {
      "id": "P_ASSERT_LOCKED_AFTER_THREE_CONSECUTIVE_UPDATES",
      "observable_contract": "Assert `locked` after three consecutive updates within the target tolerance.",
      "required_signals": [
        "time",
        "vin",
        "edge_metric_in",
        "clk",
        "rst",
        "enable",
        "boost_2",
        "boost_1",
        "boost_0",
        "vout",
        "adapt_metric",
        "locked"
      ]
    }
