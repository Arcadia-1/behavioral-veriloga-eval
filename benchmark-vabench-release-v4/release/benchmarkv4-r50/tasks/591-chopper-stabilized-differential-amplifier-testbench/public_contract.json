  "modeling_constraints": [
    "Both chopper polarities must update a retained low-pass state.",
    "The amplifier offset is inserted between chopping and synchronous demodulation.",
    "Reset and disable clear asynchronously; hold preserves retained state.",
    "No file I/O, final_step, current contributions, auto-zero storage, or trim servo."
  ],
  "properties": [
    {
      "id": "P_CHOP_DEMOD_BASEBAND_GAIN",
      "observable_contract": "Synchronous chopping and demodulation preserve gain times the differential input at baseband.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "chop_clk",
        "voutp",
        "voutn"
      ]
    },
    {
      "id": "P_INTERNAL_OFFSET_SUPPRESSION",
      "observable_contract": "The post-chopper amplifier offset alternates after demodulation and is attenuated by the retained low-pass state.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "chop_clk",
        "offset_residual"
      ]
    },
    {
      "id": "P_EVENT_DRIVEN_LOWPASS",
      "observable_contract": "Outputs update toward each demodulated sample only on either chopper edge and remain retained between events.",
      "required_signals": [
        "time",
        "chop_clk",
        "voutp",
        "voutn",
        "offset_residual"
      ]
    },
    {
      "id": "P_RESET_ENABLE_CLEAR",
      "observable_contract": "Active reset or disabled operation clears state, residual, and settled asynchronously.",
      "required_signals": [
        "time",
        "rst",
        "enable",
        "voutp",
        "voutn",
        "settled",
        "offset_residual"
      ]
    },
    {
      "id": "P_HOLD_PRESERVES_STATE",
      "observable_contract": "Hold preserves every retained output across chopper edges.",
      "required_signals": [
        "time",
        "chop_clk",
        "hold",
        "voutp",
        "voutn",
        "settled",
        "offset_residual"
      ]
    },
    {
      "id": "P_SETTLED_QUALIFICATION",
      "observable_contract": "Settled asserts only after the configured consecutive residual-qualified active updates.",
      "required_signals": [
        "time",
        "chop_clk",
        "settled",
        "offset_residual"
      ]
    }
  ],
