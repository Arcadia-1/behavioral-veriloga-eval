  "properties": [
    {
      "id": "P_RESET_CLEAR",
      "observable_contract": "Reset clears mapped level, transition delta, and output drive.",
      "required_signals": [
        "time",
        "rst",
        "vout",
        "level_1",
        "level_0",
        "delta_dbg"
      ]
    },
    {
      "id": "P_GRAY_LEVEL_MAP",
      "observable_contract": "The input bits map to levels 0, 1, 2, 3 in the declared Gray order.",
      "required_signals": [
        "time",
        "bit_msb",
        "bit_lsb",
        "clk",
        "rst",
        "level_1",
        "level_0"
      ]
    },
    {
      "id": "P_LEVEL_DAC",
      "observable_contract": "The mapped level selects the corresponding level-step voltage.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "level_1",
        "level_0",
        "vout"
      ]
    },
    {
      "id": "P_PREEMPHASIS",
      "observable_contract": "Enabled pre-emphasis follows the sign of the symbol-to-symbol mapped-level transition.",
      "required_signals": [
        "time",
        "bit_msb",
        "bit_lsb",
        "clk",
        "rst",
        "emph_en",
        "vout",
        "level_1",
        "level_0",
        "delta_dbg"
      ]
    },
    {
      "id": "P_OUTPUT_CLAMP",
      "observable_contract": "The driven output remains between VSS and VDD.",
      "required_signals": [
        "time",
        "rst",
        "vout"
      ]
    }
  ],
