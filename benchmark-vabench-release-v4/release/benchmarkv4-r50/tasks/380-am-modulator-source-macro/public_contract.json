  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_DRIVE",
      "observable_contract": "On reset or when disabled, drive `vout` to `vcm`, clear `envelope_dbg`, and clear `valid`.",
      "required_signals": [
        "time",
        "carrier_in",
        "mod_in",
        "enable",
        "rst",
        "vout",
        "envelope_dbg",
        "valid"
      ]
    },
    {
      "id": "P_WHEN_ENABLED_TREAT_CARRIER_IN_AND",
      "observable_contract": "When enabled, treat `carrier_in` and `mod_in` as deviations around `vcm`.",
      "required_signals": [
        "time",
        "carrier_in",
        "mod_in",
        "enable",
        "rst",
        "vout",
        "envelope_dbg",
        "valid"
      ]
    },
    {
      "id": "P_DRIVE_AN_AMPLITUDE_MODULATED_OUTPUT_WHOSE",
      "observable_contract": "Drive an amplitude-modulated output whose carrier deviation increases when `mod_in` rises above `vcm` and decreases when it falls below `vcm`.",
      "required_signals": [
        "time",
        "carrier_in",
        "mod_in",
        "enable",
        "rst",
        "vout",
        "envelope_dbg",
        "valid"
      ]
    },
    {
      "id": "P_CLAMP_THE_ENVELOPE_MULTIPLIER_SO_THE",
      "observable_contract": "Clamp the envelope multiplier so the output stays within `[vss, vdd]`.",
      "required_signals": [
        "time",
        "carrier_in",
        "mod_in",
        "enable",
        "rst",
        "vout",
        "envelope_dbg",
        "valid"
      ]
    },
    {
      "id": "P_ENVELOPE_DBG_MUST_EXPOSE_THE_ACTIVE",
      "observable_contract": "`envelope_dbg` must expose the active voltage-domain envelope multiplier mapped into the output voltage range.",
      "required_signals": [
        "time",
        "carrier_in",
        "mod_in",
        "enable",
        "rst",
        "vout",
        "envelope_dbg",
        "valid"
      ]
    },
    {
      "id": "P_ASSERT_VALID_WHILE_ENABLED_AFTER_RESET",
      "observable_contract": "Assert `valid` while enabled after reset has been released.",
      "required_signals": [
        "time",
        "carrier_in",
        "mod_in",
        "enable",
        "rst",
        "vout",
        "envelope_dbg",
        "valid"
      ]
    }
