      "id": "P_RESET_OR_LOW_ENABLE_DRIVES_VOUT",
      "observable_contract": "Reset or low `enable` drives `vout` to common mode and clears metrics.",
      "required_signals": [
        "time",
        "vin",
        "vbias",
        "vdd_sense",
        "enable",
        "rst",
        "vout",
        "gain_metric",
        "headroom_ok"
      ]
    },
    {
      "id": "P_WHEN_ENABLED_COMPUTE_AN_INVERTING_GAIN",
      "observable_contract": "While enabled compute rail_limit=min(vdd_sense,vbias)-headroom_drop and the inverting raw output vcm-gain*(vin-vcm).",
      "required_signals": [
        "time",
        "vin",
        "vbias",
        "vdd_sense",
        "enable",
        "rst",
        "vout",
        "gain_metric",
        "headroom_ok"
      ]
    },
    {
      "id": "P_CLAMP_THE_OUTPUT_BETWEEN_VSS_AND",
      "observable_contract": "Drive vout=clamp(vcm-gain*(vin-vcm),vss,rail_limit).",
      "required_signals": [
        "time",
        "vin",
        "vbias",
        "vdd_sense",
        "enable",
        "rst",
        "vout",
        "gain_metric",
        "headroom_ok"
      ]
    },
    {
      "id": "P_GAIN_METRIC_REPORTS_THE_ABSOLUTE_OUTPUT",
      "observable_contract": "`gain_metric` reports the absolute output excursion from common mode.",
      "required_signals": [
        "time",
        "vin",
        "vbias",
        "vdd_sense",
        "enable",
        "rst",
        "vout",
        "gain_metric",
        "headroom_ok"
      ]
    },
    {
      "id": "P_HEADROOM_OK_IS_HIGH_ONLY_WHEN",
      "observable_contract": "Drive headroom_ok=0.9V exactly when rail_limit>vcm+0.05V, otherwise vss; reset or disable clears headroom_ok and gain_metric and drives vout=vcm.",
