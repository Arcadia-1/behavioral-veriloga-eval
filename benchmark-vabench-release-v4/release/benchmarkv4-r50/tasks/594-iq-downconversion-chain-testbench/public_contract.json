  "modeling_constraints": [
    "Use deterministic rising-edge four-state quadrature and sampled baseband state.",
    "Use bounded smoothed voltage contributions only.",
    "Do not use transistor-level devices, S-parameters, AC/noise analysis, communication decoding, or validation side channels."
  ],
  "properties": [
    {
      "id": "P_RESET_COMMON_MODE",
      "observable_contract": "Active-high reset returns I/Q baseband outputs, LO monitors, and mixer monitors to 0.45 V and phase_mon to 0.9 V.",
      "required_signals": [
        "time",
        "rst",
        "out",
        "metric",
        "lo_i",
        "lo_q",
        "mix_i",
        "mix_q",
        "phase_mon"
      ]
    },
    {
      "id": "P_QUADRATURE_SEQUENCE",
      "observable_contract": "Successive non-reset rising clk edges cycle the I/Q coefficient pairs through (1,0), (0,1), (-1,0), and (0,-1), then wrap.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "lo_i",
        "lo_q",
        "phase_mon"
      ]
    },
    {
      "id": "P_LO_MONITORS",
      "observable_contract": "Lo_i and lo_q equal 0.45 V plus 0.40 V times their current quadrature coefficients.",
      "required_signals": [
        "time",
        "lo_i",
        "lo_q",
        "phase_mon"
      ]
    },
    {
      "id": "P_MIXER_MONITORS",
      "observable_contract": "Each mixer monitor equals 0.45 V plus 1.25 times the vin deviation times its LO coefficient, clamped to 0.02 V through 0.88 V.",
      "required_signals": [
        "time",
        "vin",
        "lo_i",
        "lo_q",
        "mix_i",
        "mix_q"
      ]
    },
    {
      "id": "P_BASEBAND_UPDATES",
      "observable_contract": "On each valid edge, out and metric apply the public 0.85 first-order update toward mix_i and mix_q respectively and remain clamped to 0.02 V through 0.88 V.",
      "required_signals": [
        "time",
        "clk",
        "mix_i",
        "mix_q",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_PHASE_MONITOR",
      "observable_contract": "Phase_mon exposes the current four-state phase as phase/3 times 0.9 V.",
      "required_signals": [
        "time",
        "clk",
        "phase_mon"
      ]
    }
  ],
