  "properties": [
    {
      "id": "P_APERTURE_CAPTURE",
      "observable_contract": "Each rising clk crossing schedules capture of vin after taperture rather than sampling at an unrelated time.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "vout"
      ]
    },
    {
      "id": "P_SUPPLY_CLAMPED_SAMPLE",
      "observable_contract": "At aperture capture, the held output updates to the sampled vin clamped between the instantaneous vss and vdd rails.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "clk",
        "vin",
        "vout"
      ]
    },
    {
      "id": "P_COARSE_DECISION",
      "observable_contract": "At each capture, coarse is high when the sampled value exceeds vth and low otherwise, then holds until the next capture.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "coarse"
      ]
    },
    {
      "id": "P_VALID_PULSE",
      "observable_contract": "Valid asserts at the aperture sample and deasserts after valid_width.",
      "required_signals": [
        "time",
        "clk",
        "valid"
      ]
    },
    {
      "id": "P_LOW_PHASE_DROOP",
      "observable_contract": "While clk is low, vout applies bounded droop updates governed by tau and dt instead of remaining ideal or changing discontinuously.",
      "required_signals": [
        "time",
        "clk",
        "vout"
      ]
    },
    {
      "id": "P_NO_TRACK_THROUGH",
      "observable_contract": "Between aperture captures, vout does not transparently track changes on vin; only the specified droop behavior is permitted.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "vout"
      ]
    }
