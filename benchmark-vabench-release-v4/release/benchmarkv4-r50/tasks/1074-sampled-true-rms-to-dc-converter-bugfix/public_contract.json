  "problem_statement": "the supplied system violates the public contract",
  "properties": [
    {
      "id": "P_DIFFERENTIAL_RMS",
      "observable_contract": "rms_out equals sqrt(mean((vinp-vinn)^2)) for each completed window.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "reset",
        "enable",
        "rms_out",
        "valid"
      ]
    },
    {
      "id": "P_FOUR_SAMPLE_WINDOW",
      "observable_contract": "Exactly four enabled rising-edge samples form each non-overlapping result window.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "reset",
        "enable",
        "rms_out",
        "valid"
      ]
    },
    {
      "id": "P_ENABLE_FREEZE",
      "observable_contract": "Disabled clock edges preserve partial accumulation and rms_out while deasserting valid.",
      "required_signals": [
        "time",
        "clk",
        "enable",
        "rms_out",
        "valid"
      ]
    },
    {
      "id": "P_ASYNC_RESET",
      "observable_contract": "Active-high reset asynchronously clears partial state and both outputs.",
      "required_signals": [
        "time",
        "clk",
        "reset",
        "rms_out",
        "valid"
      ]
    },
    {
      "id": "P_VALID_PULSE",
      "observable_contract": "valid is high for one sampling interval after each completed window.",
      "required_signals": [
        "time",
        "clk",
        "valid"
      ]
    },
    {
      "id": "P_OUTPUT_HOLD",
      "observable_contract": "rms_out holds between completed windows.",
      "required_signals": [
        "time",
        "clk",
        "rms_out"
      ]
    }
  ],
