    "title": "Configurable Pulse Train Generator"
  },
  "modeling_constraints": [
    "AMS role: finite pulse-train sequencer for calibration, startup, and sampled-data control timing.",
    "Use deterministic rising-edge clocked state for command capture and pulse sequencing.",
    "Decode each four-bit control word as unsigned with bit 3 as the MSB and bit 0 as the LSB.",
    "Do not add undeclared reset, debug, or validation-only ports or behavior."
  ],
  "properties": [
    {
      "id": "P_IDLE_CAPTURE",
      "observable_contract": "A sampled high start while idle captures unsigned period3:period0, width3:width0, and count3:count0 on a rising clk crossing.",
      "required_signals": [
        "time",
        "clk",
        "start",
        "period0",
        "period1",
        "period2",
        "period3",
        "width0",
        "width1",
        "width2",
        "width3",
        "count0",
        "count1",
        "count2",
        "count3",
        "pulse",
        "done"
      ]
    },
    {
      "id": "P_ZERO_CODE_MINIMUM",
      "observable_contract": "A zero-coded period, width, or count is interpreted as one clock sample rather than zero.",
      "required_signals": [
        "time",
        "clk",
        "period0",
        "period1",
        "period2",
        "period3",
        "width0",
        "width1",
        "width2",
        "width3",
        "count0",
        "count1",
        "count2",
        "count3",
        "pulse",
        "done"
      ]
    },
    {
      "id": "P_PULSE_COUNT",
      "observable_contract": "Each accepted command emits exactly the captured count number of pulses.",
      "required_signals": [
        "time",
        "clk",
        "start",
        "count0",
        "count1",
        "count2",
        "count3",
        "pulse",
        "done"
      ]
    },
    {
      "id": "P_WIDTH_AND_PERIOD",
      "observable_contract": "Each pulse remains high for the captured width in clock samples and pulse starts are separated by the captured period in clock samples.",
      "required_signals": [
        "time",
        "clk",
        "period0",
        "period1",
        "period2",
        "period3",
        "width0",
        "width1",
        "width2",
        "width3",
        "pulse"
      ]
    },
    {
      "id": "P_COMPLETION",
      "observable_contract": "After the final pulse completes, pulse is low and done is asserted.",
      "required_signals": [
        "time",
        "clk",
        "pulse",
        "done"
      ]
    },
    {
      "id": "P_OUTPUT_LEVELS",
      "observable_contract": "pulse and done use 0 V and vdd levels with finite transition smoothing set by tr.",
      "required_signals": [
        "time",
        "pulse",
        "done"
      ]
    }
  ],
