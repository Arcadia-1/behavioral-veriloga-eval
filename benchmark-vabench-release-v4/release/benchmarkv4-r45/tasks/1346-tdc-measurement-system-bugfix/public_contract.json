      "id": "P_TDC_RESTART_CLEAR",
      "observable_contract": "Each rising start edge begins a new interval and clears valid and overflow.",
      "required_signals": [
        "time",
        "start",
        "rst",
        "valid",
        "overflow"
      ]
    },
    {
      "id": "P_TDC_INTERVAL_COUNT",
      "observable_contract": "The first stop after start latches the number of intervening rising clock edges.",
      "required_signals": [
        "time",
        "start",
        "stop",
        "clk",
        "code_7",
        "code_6",
        "code_5",
        "code_4",
        "code_3",
        "code_2",
        "code_1",
        "code_0"
      ]
    },
    {
      "id": "P_TDC_VALID_LATCH",
      "observable_contract": "A completed interval asserts valid and preserves its code until restart or reset.",
      "required_signals": [
        "time",
        "start",
        "stop",
        "clk",
        "valid",
        "code_7",
        "code_0"
      ]
    },
    {
      "id": "P_TDC_OVERFLOW",
      "observable_contract": "The 256th armed clock saturates code at 255, asserts overflow and valid, and disarms.",
