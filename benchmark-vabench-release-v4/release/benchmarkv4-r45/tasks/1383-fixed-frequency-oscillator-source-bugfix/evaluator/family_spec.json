  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_DRIVE",
      "observable_contract": "On reset or when disabled, drive `osc_out`, `period_metric`, and `valid` low.",
      "required_signals": [
        "time",
        "enable",
        "rst",
        "osc_out",
        "period_metric",
        "valid"
      ]
    },
    {
      "id": "P_WHEN_ENABLED_GENERATE_A_PERIODIC_VOLTAGE",
      "observable_contract": "When enabled, generate a periodic voltage-domain clock that toggles between `vss` and `vdd` with the configured period.",
      "required_signals": [
        "time",
        "enable",
        "rst",
        "osc_out",
        "period_metric",
        "valid"
      ]
    },
    {
      "id": "P_PERIOD_METRIC_MUST_EXPOSE_A_STABLE",
      "observable_contract": "`period_metric` must expose a stable voltage-coded representation of the configured period after the first complete cycle.",
      "required_signals": [
        "time",
        "enable",
        "rst",
        "osc_out",
        "period_metric",
        "valid"
      ]
    },
    {
      "id": "P_ASSERT_VALID_AFTER_THE_FIRST_COMPLETE",
      "observable_contract": "Assert `valid` after the first complete oscillator cycle following enable.",
      "required_signals": [
        "time",
        "enable",
        "rst",
        "osc_out",
        "period_metric",
        "valid"
      ]
    },
    {
      "id": "P_RESET_OR_DISABLE_MUST_RESTART_THE",
      "observable_contract": "Reset or disable must restart the oscillator phase deterministically.",
      "required_signals": [
        "time",
        "enable",
        "rst",
        "osc_out",
        "period_metric",
        "valid"
      ]
    }
