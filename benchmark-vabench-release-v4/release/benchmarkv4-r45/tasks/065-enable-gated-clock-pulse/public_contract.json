        "clk",
        "en",
        "pulse"
      ]
    },
    {
      "id": "P_ENABLE_GATING",
      "observable_contract": "Changing en gates the observed clock level without creating a high output while clk is logically low.",
      "required_signals": [
        "time",
        "clk",
        "en",
        "pulse"
      ]
    },
    {
      "id": "P_OUTPUT_LEVELS",
      "observable_contract": "pulse uses voltage-coded 0 V and vdd levels with finite transition smoothing set by tr.",
