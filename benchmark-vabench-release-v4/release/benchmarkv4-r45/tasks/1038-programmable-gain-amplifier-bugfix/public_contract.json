      "id": "P_RESET_UNITY",
      "observable_contract": "While rst is active, the sampled gain is unity, out is vcm, and metric is low.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_SAMPLED_GAIN_SELECT",
      "observable_contract": "Each rising clk crossing with reset inactive samples gain_sel, selecting gain_high above vth and gain_low below vth; the selection holds between crossings.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "gain_sel",
        "vin",
        "out"
      ]
    },
    {
      "id": "P_COMMON_MODE_GAIN",
      "observable_contract": "The unclamped output target is vcm plus the sampled gain times vin minus vcm.",
      "required_signals": [
        "time",
        "vin",
        "out"
      ]
    },
    {
      "id": "P_OUTPUT_CLAMP",
      "observable_contract": "Out is limited to the inclusive vmin through vmax range with finite smoothing.",
      "required_signals": [
        "time",
        "out"
      ]
    },
    {
      "id": "P_CLIP_METRIC",
      "observable_contract": "Metric is high exactly when the unclamped target lies outside vmin through vmax, and low otherwise; reset forces it low.",
      "required_signals": [
        "time",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    }
