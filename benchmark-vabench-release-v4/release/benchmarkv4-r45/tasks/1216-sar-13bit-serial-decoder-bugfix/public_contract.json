  "properties": [
    {
      "id": "P_CONSUME_ONE_MSB_FIRST_BIT_ON",
      "observable_contract": "Consume one MSB-first bit on each rising `ready` crossing, starting with bit 12 and ending with bit 0.",
      "required_signals": [
        "time",
        "clks",
        "din",
        "dnum",
        "dout",
        "ready"
      ]
    },
    {
      "id": "P_ADD_THE_CORRESPONDING_BINARY_WEIGHT_WHEN",
      "observable_contract": "Add the corresponding binary weight when `din` is high.",
      "required_signals": [
        "time",
        "clks",
        "din",
        "dnum",
        "dout",
        "ready"
      ]
    },
    {
      "id": "P_INCREMENT_DNUM_FOR_EACH_HIGH_DECISION",
      "observable_contract": "Increment `dnum` for each high decision in the current frame.",
      "required_signals": [
        "time",
        "clks",
        "din",
        "dnum",
        "dout",
        "ready"
      ]
    },
    {
      "id": "P_ON_EACH_RISING_CLKS_CROSSING_PUBLISH",
      "observable_contract": "On each rising `clks` crossing, publish the previous frame as a normalized bipolar output.",
      "required_signals": [
        "time",
        "clks",
        "din",
        "dnum",
        "dout",
        "ready"
      ]
    },
    {
      "id": "P_MAP_AN_ALL_LOW_FRAME_TO",
      "observable_contract": "Map an all-low frame to `-0.5` and an all-high frame near `+0.5`.",
      "required_signals": [
        "time",
        "clks",
        "din",
        "dnum",
        "dout",
        "ready"
      ]
    },
    {
      "id": "P_AFTER_PUBLISHING_RESET_THE_ACCUMULATOR_HIGH",
      "observable_contract": "After publishing, reset the accumulator, high-bit count, and bit pointer for the next frame.",
      "required_signals": [
        "time",
        "clks",
        "din",
        "dnum",
        "dout",
        "ready"
      ]
    }
