  "properties": [
    {"id": "P_ALIGNMENT_STREAK", "observable_contract": "lock asserts only after need consecutive reference edges whose most recent feedback edge is within tol.", "required_signals": ["time", "ref_clk", "fb_clk", "rst_n", "lock"]},
    {"id": "P_PREMATURE_LOCK", "observable_contract": "lock remains low before the need-th consecutive aligned reference event.", "required_signals": ["time", "ref_clk", "fb_clk", "lock"]},
