  "properties": [
    {
      "id": "P_RAIL_DERIVED_LIMITS",
      "observable_contract": "Derive the upper limit as `V(vdd) - V(vmax)` and the lower limit as `V(vss) + V(vmin)`.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "vin",
        "vmax",
        "vmin",
        "vout"
      ]
    },
    {
      "id": "P_PASS_WITHIN_LIMITS",
      "observable_contract": "When `V(vin)` lies between the derived limits, drive `vout` to `V(vin)`.",
      "required_signals": [
        "time",
        "vin",
        "vout"
      ]
    },
    {
      "id": "P_LIMIT_ABOVE_UPPER",
      "observable_contract": "When `V(vin)` exceeds the upper limit, drive `vout` to the upper limit.",
      "required_signals": [
        "time",
        "vdd",
        "vin",
        "vmax",
        "vout"
      ]
    },
    {
      "id": "P_LIMIT_BELOW_LOWER",
      "observable_contract": "When `V(vin)` is below the lower limit, drive `vout` to the lower limit.",
      "required_signals": [
        "time",
        "vss",
        "vin",
        "vmin",
        "vout"
      ]
    }
  ],
