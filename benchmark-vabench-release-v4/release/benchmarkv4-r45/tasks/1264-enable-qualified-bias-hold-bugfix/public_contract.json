  "properties": [
    {
      "id": "P_MEASURE_ANALOG_INPUTS_RELATIVE_TO_THE",
      "observable_contract": "Measure analog inputs relative to the local `vss` rail and normalize by the current local supply span. Let `span = V(vdd, vss)` and treat the row as valid only when `V(en) > vth` and `span_min <= span <= span_max`. If `span` is below `0.05 V`, use `0.05 V` as the normalization span. Define `clip01(y)` as `y` limited to the range `[0, 1]`, `x0..x3 = clip01((V(inN) - V(vss)) / span)`, and `c0 = clip01(V(ctrl0) / vhi)`.",
      "required_signals": [
        "time",
        "clk",
        "ctrl0",
        "ctrl1",
        "en",
        "flag",
        "in0",
        "in1",
        "in2",
        "in3",
        "metric",
        "out",
        "rst",
        "vdd",
        "vss"
      ]
    },
    {
      "id": "P_INITIALIZE_THE_HELD_BIAS_OUTPUT_FLAG",
      "observable_contract": "Initialize the held bias output, `flag`, and `metric` to `0 V`. On a rising edge of `clk`, clear all observables when `rst` is high or the row is not valid. Otherwise, when `c0 > 0.45`, update the held output to `out = vhi * clip01(0.70 * x0 + 0.30 * x1)` and assert `flag = vhi`. When `c0 <= 0.45`, hold the previous output value and drive `flag = 0 V`. After the update or hold decision, drive `metric = vhi * clip01(abs((out / vhi) - x2))`. Hold the last observable values between rising clock edges, except that a reset assertion clears them.",
      "required_signals": [
        "time",
        "clk",
        "ctrl0",
        "ctrl1",
        "en",
        "flag",
        "in0",
        "in1",
        "in2",
        "in3",
        "metric",
        "out",
        "rst",
        "vdd",
        "vss"
      ]
    }
  ],
