{
  "artifact_contract": {
    "files": [
      {
        "modules": [
          {
            "depends_on": [],
            "name": "calibration_deadband_controller",
            "parameters": [
              {
                "default": 1e-10,
                "name": "tr",
                "override_behavior": "sets output transition smoothing",
                "type": "real",
                "units": "s",
                "valid_range": "tr > 0"
              },
              {
                "default": 0.45,
                "name": "vth",
                "override_behavior": "sets clk and rst logic threshold",
                "type": "real",
                "units": "V",
                "valid_range": "finite real"
              },
              {
                "default": 0.45,
                "name": "target",
                "override_behavior": "sets initial, reset, and zero-error trim target",
                "type": "real",
                "units": "V",
                "valid_range": "vmin <= target <= vmax"
              },
              {
                "default": 0.05,
                "name": "deadband",
                "override_behavior": "sets the symmetric no-update error interval",
                "type": "real",
                "units": "V",
                "valid_range": "deadband >= 0"
              },
              {
                "default": 0.06,
                "name": "step_size",
                "override_behavior": "sets trim increment or decrement per accepted update",
                "type": "real",
                "units": "V",
                "valid_range": "step_size > 0"
              },
              {
                "default": 0.05,
                "name": "vmin",
                "override_behavior": "sets lower output clamp",
                "type": "real",
                "units": "V",
                "valid_range": "vmin <= target and vmin < vmax"
              },
              {
                "default": 0.85,
                "name": "vmax",
                "override_behavior": "sets upper output clamp",
                "type": "real",
                "units": "V",
                "valid_range": "vmax >= target and vmax > vmin"
              }
            ],
            "ports": [
              {
                "direction": "input",
                "discipline": "electrical",
                "name": "clk",
                "position": 0
              },
              {
                "direction": "input",
                "discipline": "electrical",
                "name": "rst",
                "position": 1
              },
              {
                "direction": "input",
                "discipline": "electrical",
                "name": "vin",
                "position": 2
              },
              {
                "direction": "output",
                "discipline": "electrical",
                "name": "out",
                "position": 3
              },
              {
                "direction": "output",
                "discipline": "electrical",
                "name": "metric",
                "position": 4
              }
            ],
            "role": "entry"
          }
        ],
        "path": "calibration_deadband_controller.va"
      }
    ],
    "mode": "single_file"
  },
  "evas": {
    "available_in_modes": [
      "G2",
      "G3",
      "G4",
      "G5"
    ],
    "command": "evas simulate public/task/visible_test.scs -o public/submission/evas-output --spectre-strict",
    "visible_and_final_test": "identical"
  },
  "family_id": "021",
  "form": "dut",
  "identity": {
    "category": "calibration_control",
    "difficulty": "D2",
    "level": "L1",
    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "Calibration Deadband Controller"
  },
  "modeling_constraints": [
    "Use deterministic rising-edge sampled state updates.",
    "Use voltage contributions only.",
    "Do not use current contributions, transistor-level devices, AC/noise analysis, or validation side channels."
  ],
  "properties": [
    {
      "id": "P_INITIAL_AND_RESET_TARGET",
      "observable_contract": "Out initializes to target and returns to target while rst is above vth; metric is low during reset.",
      "required_signals": [
        "time",
        "rst",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_POSITIVE_ERROR_STEP",
      "observable_contract": "At a rising clock crossing with vin minus target greater than deadband, out increases by one step_size and metric goes high.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_NEGATIVE_ERROR_STEP",
      "observable_contract": "At a rising clock crossing with vin minus target less than negative deadband, out decreases by one step_size and metric goes high.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_DEADBAND_HOLD",
      "observable_contract": "At a rising clock crossing with signed error inside the inclusive deadband, out holds and metric remains low.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_OUTPUT_CLAMP",
      "observable_contract": "Repeated updates cannot drive out below vmin or above vmax.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out"
      ]
    },
    {
      "id": "P_BETWEEN_EDGE_HOLD",
      "observable_contract": "Out state does not follow vin between rising clock crossings.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "out"
      ]
    }
  ],
  "schema_version": "v4-benchmarkv4-public-contract-v1",
