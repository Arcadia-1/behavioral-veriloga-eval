`include "disciplines.vams"
module subradix_dac10(vd9, vd8, vd7, vd6, vd5, vd4, vd3, vd2, vd1, vd0, vout);
input vd9,vd8,vd7,vd6,vd5,vd4,vd3,vd2,vd1,vd0; output vout; electrical vd9,vd8,vd7,vd6,vd5,vd4,vd3,vd2,vd1,vd0,vout; parameter real vth=0.45; parameter real vref=1.0;
analog begin V(vout)<+vref*(((V(vd9)>vth)?512.0:0.0)+((V(vd8)>vth)?256.0:0.0)+((V(vd7)>vth)?128.0:0.0)+((V(vd6)>vth)?64.0:0.0)+((V(vd5)>vth)?32.0:0.0)+((V(vd4)>vth)?16.0:0.0)+((V(vd3)>vth)?8.0:0.0)+((V(vd2)>vth)?4.0:0.0)+((V(vd1)>vth)?2.0:0.0)+((V(vd0)>vth)?1.0:0.0))/1024.0; end
endmodule
