  ],
  "properties": [
    {
      "id": "P_ZERO_INSIDE_DEADBAND",
      "observable_contract": "For `dead_low <= V(sigin) <= dead_high`, drive `sigout` to 0 V.",
      "required_signals": [
        "time",
        "sigin",
        "sigout"
      ]
    },
    {
      "id": "P_LOWER_RESIDUE",
      "observable_contract": "For `V(sigin) < dead_low`, drive `sigout` to `V(sigin) - dead_low`.",
      "required_signals": [
        "time",
        "sigin",
        "sigout"
      ]
    },
    {
      "id": "P_UPPER_RESIDUE",
      "observable_contract": "For `V(sigin) > dead_high`, drive `sigout` to `V(sigin) - dead_high`.",
      "required_signals": [
        "time",
        "sigin",
        "sigout"
      ]
    }
  ],
