  ],
  "properties": [
    {
      "id": "P_PWR_ASYNC_CLEAR",
      "observable_contract": "External reset or a brownout clears por_n, core reset release, enables, and ready without waiting for sequence completion.",
      "required_signals": [
        "time",
        "vdd_sense",
        "rst_n_ext",
        "por_n",
        "rst_n_core",
        "en_ana",
        "en_dig",
        "ready"
      ]
    },
    {
      "id": "P_PWR_POR_DEBOUNCE",
      "observable_contract": "por_n asserts only after two consecutive good-power rising clock edges.",
      "required_signals": [
        "time",
        "vdd_sense",
        "clk",
        "rst_n_ext",
        "por_n"
      ]
    },
    {
      "id": "P_PWR_SEQUENCE_ORDER",
      "observable_contract": "With power good and enable requested, rst_n_core, en_ana, and en_dig release on successive rising clock edges.",
      "required_signals": [
        "time",
        "vdd_sense",
        "clk",
        "rst_n_ext",
        "enable_req",
        "por_n",
        "rst_n_core",
        "en_ana",
        "en_dig"
      ]
    },
    {
      "id": "P_PWR_READY_DELAY",
      "observable_contract": "ready asserts one rising clock after both enables are high.",
      "required_signals": [
        "time",
        "clk",
        "en_ana",
        "en_dig",
        "ready"
      ]
    }
  ],
