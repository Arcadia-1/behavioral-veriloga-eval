  "properties": [
    {
      "id": "P_ON_RESET_CLEAR_THE_TRIM_STATE",
      "observable_contract": "On reset, clear the trim state, drive `vout` to `vcm`, clear `offset_metric`, and clear `ready`.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "cal_en",
        "trim_2",
        "trim_1",
        "trim_0",
        "vout",
        "offset_metric",
        "ready"
      ]
    },
    {
      "id": "P_DECODE_TRIM_2_TRIM_0_AS",
      "observable_contract": "Decode `trim_2..trim_0` as a signed offset correction around zero.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "cal_en",
        "trim_2",
        "trim_1",
        "trim_0",
        "vout",
        "offset_metric",
        "ready"
      ]
    },
    {
      "id": "P_WHILE_CAL_EN_IS_HIGH_UPDATE",
      "observable_contract": "While `cal_en` is high, update the internal trim accumulator once per rising `clk` edge toward reducing the measured input offset.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "cal_en",
        "trim_2",
        "trim_1",
        "trim_0",
        "vout",
        "offset_metric",
        "ready"
      ]
    },
    {
      "id": "P_DRIVE_VOUT_FROM_THE_CORRECTED_DIFFERENTIAL",
      "observable_contract": "Drive `vout` from the corrected differential input and clamp to the output rails.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "cal_en",
        "trim_2",
        "trim_1",
        "trim_0",
        "vout",
        "offset_metric",
        "ready"
      ]
    },
    {
      "id": "P_EXPOSE_THE_ACTIVE_CORRECTION_ON_OFFSET",
      "observable_contract": "Expose the active correction on `offset_metric` and assert `ready` after three calibration updates.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "cal_en",
        "trim_2",
        "trim_1",
        "trim_0",
        "vout",
        "offset_metric",
        "ready"
      ]
    },
    {
      "id": "P_USE_ONLY_VOLTAGE_DOMAIN_BEHAVIORAL_STATE",
      "observable_contract": "Use only voltage-domain behavioral state and voltage contributions on public electrical outputs.",
      "required_signals": [
        "time",
        "vinp",
        "vinn",
        "clk",
        "rst",
        "cal_en",
        "trim_2",
        "trim_1",
        "trim_0",
        "vout",
        "offset_metric",
        "ready"
      ]
    }
  ],
