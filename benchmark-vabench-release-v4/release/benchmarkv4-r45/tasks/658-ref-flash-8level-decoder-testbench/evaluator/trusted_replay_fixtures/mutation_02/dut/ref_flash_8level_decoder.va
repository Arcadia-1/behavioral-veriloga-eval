`include "disciplines.vams"

module ref_flash_8level_decoder(vin, dt0, dt1, dt2, dt3, dt4, dt5, dt6, dt7, clks, dout, vres);
input vin, dt0, dt1, dt2, dt3, dt4, dt5, dt6, dt7, clks;
output dout, vres;
electrical vin, dt0, dt1, dt2, dt3, dt4, dt5, dt6, dt7, clks, dout, vres;

parameter real vth = 0.45;
parameter real tt = 10p;
parameter real vref = 1;
real doutvalsum, doutval, resval;

analog begin
    @(initial_step) begin
        doutval = 0;
        resval = 0;
    end

    @(cross(V(clks) - vth, +1)) begin
        doutvalsum = 0;
        doutvalsum = doutvalsum + (V(dt0) > vth);
        doutvalsum = doutvalsum + (V(dt1) > vth);
        doutvalsum = doutvalsum + (V(dt2) > vth);
        doutvalsum = doutvalsum + (V(dt3) > vth);
        doutvalsum = doutvalsum + (V(dt4) > vth);
        doutvalsum = doutvalsum + (V(dt5) > vth);
        doutvalsum = doutvalsum + (V(dt6) > vth);
        doutvalsum = doutvalsum + (V(dt7) > vth);
        doutval = doutvalsum / 8.0;
        resval = V(vin) - doutvalsum * vref / 8.0;
    end

    V(dout) <+ transition(doutval, 0, tt, tt);
    V(vres) <+ transition(resval, 0, tt, tt);
end

endmodule
