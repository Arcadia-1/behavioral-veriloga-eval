  "properties": [
    {
      "id": "P_REF_SETS_UP",
      "observable_contract": "A rising REF edge asserts UP, and falling REF edges do not set either output.",
      "required_signals": [
        "time",
        "ref",
        "up"
      ]
    },
    {
      "id": "P_DIV_SETS_DN",
      "observable_contract": "A rising DIV edge asserts DN, and falling DIV edges do not set either output.",
      "required_signals": [
        "time",
        "div",
        "dn"
      ]
    },
    {
      "id": "P_RESET_RACE_CLEAR",
      "observable_contract": "If a rising edge arrives while the opposite output state is already high, both UP and DN clear immediately for REF-leading and DIV-leading orderings.",
      "required_signals": [
        "time",
        "ref",
        "div",
        "up",
        "dn"
      ]
    },
    {
      "id": "P_NO_PERSISTENT_OVERLAP",
      "observable_contract": "UP and DN are not intentionally held high together beyond finite transition smoothing overlap.",
