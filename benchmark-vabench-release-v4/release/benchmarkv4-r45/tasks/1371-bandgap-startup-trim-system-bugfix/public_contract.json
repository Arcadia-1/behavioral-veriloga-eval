      "id": "P_POR_STARTUP",
      "observable_contract": "Enable the reference only after vdd_sense remains above vpor for two consecutive rising clock edges.",
      "required_signals": [
        "time",
        "vdd_sense",
        "clk",
        "rst",
        "trim_req",
        "temp_proxy",
        "vref",
        "trim_3",
