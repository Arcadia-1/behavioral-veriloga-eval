        "ready",
        "error_metric"
      ]
    },
    {
      "id": "P_TRIM_SEARCH",
      "observable_contract": "When trim_req is high, update the 4-bit trim code once per rising clock edge to reduce reference error.",
      "required_signals": [
        "time",
        "vdd_sense",
        "clk",
        "rst",
        "trim_req",
        "temp_proxy",
        "vref",
        "trim_3",
