{
  "artifact_contract": {
    "files": [
      {
        "modules": [
          {
            "depends_on": [],
            "name": "source_crossing_pulse_detector",
            "parameters": [
              {
                "default": 4e-09,
                "name": "pulse_width",
                "override_behavior": "sets output high duration after each qualifying crossing",
                "type": "real",
                "units": "s",
                "valid_range": "pulse_width > 0"
              },
              {
                "default": 0.45,
                "name": "sigcrossing",
                "override_behavior": "sets the bidirectional sigin detection threshold",
                "type": "real",
                "units": "V",
                "valid_range": "finite real"
              },
              {
                "default": 0.9,
                "name": "vlogic_high",
                "override_behavior": "sets the asserted output level",
                "type": "real",
                "units": "V",
                "valid_range": "finite real"
              },
              {
                "default": 0.0,
                "name": "vlogic_low",
                "override_behavior": "sets the deasserted output level",
                "type": "real",
                "units": "V",
                "valid_range": "finite real"
              },
              {
                "default": 1e-09,
                "name": "tdel",
                "override_behavior": "sets output transition delay",
                "type": "real",
                "units": "s",
                "valid_range": "tdel >= 0"
              },
              {
                "default": 2e-11,
                "name": "trise",
                "override_behavior": "sets sigout rise smoothing",
                "type": "real",
                "units": "s",
                "valid_range": "trise > 0"
              },
              {
                "default": 2e-11,
                "name": "tfall",
                "override_behavior": "sets sigout fall smoothing",
                "type": "real",
                "units": "s",
                "valid_range": "tfall > 0"
              }
            ],
            "ports": [
              {
                "direction": "input",
                "discipline": "electrical",
                "name": "sigin",
                "position": 0
              },
              {
                "direction": "output",
                "discipline": "electrical",
                "name": "sigout",
                "position": 1
              }
            ],
            "role": "entry"
          }
        ],
        "path": "source_crossing_pulse_detector.va"
      }
    ],
    "mode": "single_file"
  },
  "evas": {
