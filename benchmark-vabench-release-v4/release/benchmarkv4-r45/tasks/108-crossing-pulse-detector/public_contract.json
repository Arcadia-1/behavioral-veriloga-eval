  "family_id": "108",
  "form": "dut",
  "identity": {
    "category": "timing_primitive",
    "difficulty": "D2",
    "level": "L1",
    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "Crossing Pulse Detector"
  },
  "modeling_constraints": [
    "Use bidirectional threshold crossing detection and timer-controlled pulse state.",
    "Drive sigout with a smoothed voltage contribution using the public timing parameters.",
    "Do not use current contributions, ddt(), idt(), transistor-level devices, AC/noise analysis, validation hooks, or simulator-specific side channels."
  ],
  "properties": [
    {
      "id": "P_RISING_CROSS_PULSE",
      "observable_contract": "A rising sigin crossing through sigcrossing initiates a sigout pulse.",
      "required_signals": [
        "time",
        "sigin",
        "sigout"
      ]
    },
    {
      "id": "P_FALLING_CROSS_PULSE",
      "observable_contract": "A falling sigin crossing through sigcrossing also initiates a sigout pulse.",
      "required_signals": [
        "time",
        "sigin",
        "sigout"
      ]
    },
    {
      "id": "P_PULSE_WIDTH",
      "observable_contract": "After each qualifying crossing, the output target remains at vlogic_high for pulse_width before returning to vlogic_low.",
      "required_signals": [
        "time",
        "sigin",
        "sigout"
      ]
    },
    {
      "id": "P_LOW_BETWEEN_EVENTS",
      "observable_contract": "Sigout returns to vlogic_low between sufficiently separated threshold crossings.",
      "required_signals": [
        "time",
        "sigin",
        "sigout"
      ]
    },
    {
      "id": "P_REPEATABLE_BIDIRECTIONAL_EVENTS",
      "observable_contract": "Alternating rising and falling crossings each produce corresponding pulses rather than only the first event or one polarity.",
      "required_signals": [
        "time",
        "sigin",
        "sigout"
      ]
    },
    {
      "id": "P_TRANSITION_TIMING",
      "observable_contract": "Sigout changes use tdel delay with trise and tfall smoothing.",
      "required_signals": [
        "time",
        "sigin",
        "sigout"
      ]
    }
  ],
