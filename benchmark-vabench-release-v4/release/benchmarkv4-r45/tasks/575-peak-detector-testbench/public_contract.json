  "form": "testbench",
  "identity": {
    "category": "measurement_instrumentation_flows",
    "difficulty": "D2",
    "level": "L1",
    "supported_scope": "pure voltage-domain timer-sampled transient behavioral Verilog-A for resettable peak measurement",
    "title": "Peak Detector"
  },
  "modeling_constraints": [
    "Use deterministic 500 ps timer sampling and retained voltage-domain state.",
    "Reset takes precedence over peak accumulation while asserted.",
    "Do not add undeclared sample controls, files, or validation-only outputs."
  ],
  "properties": [
    {
      "id": "P_INITIAL_ZERO",
      "observable_contract": "The retained peak and vout initialize to 0 V.",
      "required_signals": [
        "time",
        "vout"
      ]
    },
    {
      "id": "P_SAMPLED_MEASUREMENT",
      "observable_contract": "When reset is inactive, vin is considered for peak updates at periodic 500 ps sample instants.",
      "required_signals": [
        "time",
        "vin",
        "rst",
        "vout"
      ]
    },
    {
      "id": "P_MAX_RETENTION",
      "observable_contract": "At each sample, a vin value above the retained peak replaces it; lower or equal samples leave vout unchanged.",
      "required_signals": [
        "time",
        "vin",
        "rst",
        "vout"
      ]
    },
    {
      "id": "P_MONOTONIC_HOLD",
      "observable_contract": "Between resets, the retained peak does not decrease and remains held between sample instants.",
      "required_signals": [
        "time",
        "vin",
        "rst",
        "vout"
      ]
    },
    {
      "id": "P_RESET_CLEAR",
      "observable_contract": "While rst is above vth, the retained peak is cleared and vout returns to 0 V.",
      "required_signals": [
        "time",
        "rst",
        "vout"
      ]
    },
    {
      "id": "P_OUTPUT_SMOOTHING",
      "observable_contract": "Changes of the retained peak appear on vout with finite transition smoothing set by tr.",
      "required_signals": [
        "time",
        "vout"
      ]
    }
  ],
  "schema_version": "v4-benchmarkv4-public-contract-v1",
