  "problem_statement": "the supplied system violates the public contract",
  "properties": [
    {
      "id": "P_INITIAL_VALUE",
      "observable_contract": "At initialization, the held output is established from the initial observed vin value.",
      "required_signals": [
        "time",
        "vin",
        "vout"
      ]
    },
    {
      "id": "P_APERTURE_ARM",
      "observable_contract": "Each rising crossing of clk through vth arms exactly one sample for the corresponding delayed aperture instant.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "vout"
      ]
    },
    {
      "id": "P_DELAYED_CAPTURE",
      "observable_contract": "At taperture after the rising clk crossing, vout captures the vin value present at that delayed instant rather than at the clock edge.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "vout"
      ]
    },
    {
      "id": "P_HOLD",
      "observable_contract": "Between delayed aperture instants, vout retains the most recently captured value and does not track vin.",
      "required_signals": [
        "time",
        "clk",
        "vin",
        "vout"
      ]
    },
    {
      "id": "P_RAIL_OBSERVABILITY",
      "observable_contract": "VDD and VSS are public supply-observation ports for harness compatibility only; they do not clamp, scale, or shift the captured vin value.",
      "required_signals": [
        "time",
        "VDD",
        "VSS",
        "vin",
        "vout"
      ]
    },
    {
      "id": "P_OUTPUT_SMOOTHING",
      "observable_contract": "Changes in the held value appear on vout with finite transition smoothing set by tedge.",
      "required_signals": [
        "time",
        "vin",
        "vout"
      ]
    }
  ],
