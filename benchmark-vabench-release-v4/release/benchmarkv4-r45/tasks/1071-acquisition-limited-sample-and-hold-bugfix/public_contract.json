  "properties": [
    {
      "id": "P_RESET",
      "observable_contract": "While rst is above vth, vout returns to vinit and metric is low.",
      "required_signals": [
        "time",
        "rst",
        "vout",
        "metric"
      ]
    },
    {
      "id": "P_ACQUISITION_ENABLE",
      "observable_contract": "When sample is above vth and reset is inactive, metric is high and vout is allowed to acquire vin.",
      "required_signals": [
        "time",
        "sample",
        "rst",
        "vin",
        "vout",
        "metric"
      ]
    },
    {
      "id": "P_FINITE_ACQUISITION",
      "observable_contract": "At each tick during acquisition, vout advances by alpha times the remaining difference from the current vin rather than jumping instantaneously.",
      "required_signals": [
        "time",
        "sample",
        "vin",
        "vout"
      ]
    },
    {
      "id": "P_ACQUISITION_CONVERGENCE",
      "observable_contract": "For a constant vin and repeated acquisition updates, vout moves monotonically toward vin without overshoot for the declared alpha range.",
      "required_signals": [
        "time",
        "sample",
        "vin",
        "vout"
      ]
    },
    {
      "id": "P_HOLD",
      "observable_contract": "A falling sample crossing freezes the last acquired value; vout holds it and metric remains low until acquisition resumes or reset is asserted.",
      "required_signals": [
        "time",
        "sample",
        "rst",
        "vin",
        "vout",
        "metric"
      ]
    }
