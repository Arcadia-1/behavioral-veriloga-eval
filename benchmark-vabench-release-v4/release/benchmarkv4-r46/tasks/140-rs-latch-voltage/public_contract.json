    {
      "id": "P_SET_RESET_PRIORITY",
      "observable_contract": "A set-only input drives Q high, and a reset-only input drives Q low.",
      "required_signals": [
        "time",
        "vin_s",
        "vin_r",
        "vout_q",
        "vout_qbar"
      ]
    },
    {
      "id": "P_HOLD_STATE",
      "observable_contract": "When neither set-only nor reset-only is asserted, preserve the previous Q state after initializing Q low.",
      "required_signals": [
        "time",
        "vin_s",
        "vin_r",
        "vout_q",
        "vout_qbar"
      ]
    },
    {
      "id": "P_QBAR_COMPLEMENT",
      "observable_contract": "Drive `vout_qbar` as the logical complement of Q.",
      "required_signals": [
        "time",
        "vout_q",
        "vout_qbar"
      ]
    }
