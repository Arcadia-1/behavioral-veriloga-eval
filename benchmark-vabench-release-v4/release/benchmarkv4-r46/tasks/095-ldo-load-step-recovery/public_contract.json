  "identity": {
    "category": "bias_reference_power_management",
    "difficulty": "D2",
    "level": "L2",
    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "LDO Load Step Recovery"
  },
  "modeling_constraints": [
    "Use deterministic rising-edge sampled load-step and recovery state.",
    "Use bounded smoothed voltage contributions only.",
    "Do not use branch-current contributions, transistor-level devices, AC/noise analysis, KCL/KVL regulation loops, or validation side channels."
  ],
  "properties": [
    {
      "id": "P_RESET_REGULATION_STATE",
      "observable_contract": "Active-high reset initializes out and target to 0.60 V, load_mon to 0.10 V, ctrl_mon to 0.50 V, metric to 0.9 V, and clears recovery progress.",
      "required_signals": [
        "time",
        "rst",
        "out",
        "metric",
        "load_mon",
        "ctrl_mon"
      ]
    },
    {
      "id": "P_BOUNDED_LOAD_AND_TARGET",
      "observable_contract": "Each non-reset rising clk edge clips vin to 0 V through 0.9 V on load_mon and uses the public load-dependent target 0.61 V minus 0.025 times load.",
      "required_signals": [
        "time",
        "clk",
        "rst",
        "vin",
        "load_mon",
        "out"
      ]
    },
    {
      "id": "P_CONTROL_MONITOR",
      "observable_contract": "Ctrl_mon represents the public load and regulation-error control expression and remains clamped to 0.05 V through 0.85 V.",
      "required_signals": [
        "time",
        "clk",
        "load_mon",
        "out",
        "ctrl_mon"
      ]
    },
    {
      "id": "P_HEAVY_LOAD_DROOP",
      "observable_contract": "A sampled load increase greater than 0.20 V causes the public 0.13 V transient droop before first-order recovery and restarts recovery qualification.",
      "required_signals": [
        "time",
        "clk",
        "load_mon",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_LIGHT_LOAD_KICK",
      "observable_contract": "A sampled load decrease greater than 0.20 V causes the public 0.05 V light-load recovery kick before first-order recovery and restarts qualification.",
      "required_signals": [
        "time",
        "clk",
        "load_mon",
        "out",
        "metric"
      ]
    },
    {
      "id": "P_RECOVERY_AND_SETTLING",
      "observable_contract": "Every non-reset update applies the public 0.30 first-order recovery, clamps out to 0.20 V through 0.75 V, and sets metric high only after at least five updates with target error below 0.045 V.",
      "required_signals": [
        "time",
        "clk",
        "out",
        "metric",
        "load_mon"
      ]
    }
  ],
