  "properties": [
    {
      "id": "P_ON_RESET_OR_WHEN_DISABLED_CLEAR",
      "observable_contract": "On reset or when disabled, clear the calibration code, metric, and `done`.",
      "required_signals": [
        "time",
        "err_in",
        "clk",
        "rst",
        "enable",
        "cal_3",
        "cal_2",
        "cal_1",
        "cal_0",
        "correction_metric",
        "done"
      ]
    },
    {
      "id": "P_ON_EACH_ENABLED_RISING_CLK_EDGE",
      "observable_contract": "On each enabled rising `clk` edge, update a signed correction accumulator using the sign of `err_in - vcm`.",
      "required_signals": [
        "time",
        "err_in",
        "clk",
        "rst",
        "enable",
        "cal_3",
        "cal_2",
        "cal_1",
        "cal_0",
        "correction_metric",
        "done"
      ]
    },
    {
      "id": "P_SATURATE_THE_PUBLIC_4_BIT_CALIBRATION",
      "observable_contract": "Saturate the public 4-bit calibration code at the endpoints.",
      "required_signals": [
        "time",
        "err_in",
        "clk",
        "rst",
        "enable",
        "cal_3",
        "cal_2",
        "cal_1",
        "cal_0",
        "correction_metric",
        "done"
      ]
    },
    {
      "id": "P_DRIVE_CORRECTION_METRIC_AS_THE_VOLTAGE",
      "observable_contract": "Drive `correction_metric` as the voltage-coded correction applied by the active code.",
      "required_signals": [
        "time",
        "err_in",
        "clk",
        "rst",
        "enable",
        "cal_3",
        "cal_2",
        "cal_1",
        "cal_0",
        "correction_metric",
        "done"
      ]
    },
    {
      "id": "P_ASSERT_DONE_AFTER_EIGHT_ENABLED_UPDATES",
      "observable_contract": "Assert `done` after eight enabled updates or when the error remains within `err_tol` for two updates.",
      "required_signals": [
        "time",
        "err_in",
        "clk",
        "rst",
        "enable",
        "cal_3",
        "cal_2",
        "cal_1",
        "cal_0",
        "correction_metric",
        "done"
      ]
    },
    {
      "id": "P_USE_ONLY_VOLTAGE_DOMAIN_BEHAVIORAL_STATE",
      "observable_contract": "Use only voltage-domain behavioral state and voltage contributions on public electrical outputs.",
      "required_signals": [
        "time",
        "err_in",
        "clk",
        "rst",
        "enable",
        "cal_3",
        "cal_2",
        "cal_1",
        "cal_0",
        "correction_metric",
        "done"
      ]
    }
  ],
