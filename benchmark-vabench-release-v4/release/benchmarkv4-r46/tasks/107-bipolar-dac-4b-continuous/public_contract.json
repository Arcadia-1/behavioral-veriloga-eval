        "time",
        "vd3",
        "vd2",
        "vd1",
        "vd0",
        "vout"
      ]
    },
    {
      "id": "P_UNIFORM_CODE_STEP",
      "observable_contract": "Every one-code increase raises the output target by the same voltage increment across codes 0 through 15.",
      "required_signals": [
        "time",
        "vd3",
        "vd2",
        "vd1",
        "vd0",
        "vout"
      ]
    },
    {
      "id": "P_MONOTONIC_TRANSFER",
      "observable_contract": "The output is strictly monotonic with increasing unsigned code for vref greater than zero.",
      "required_signals": [
        "time",
        "vd3",
        "vd2",
        "vd1",
        "vd0",
        "vout"
      ]
    },
    {
      "id": "P_CONTINUOUS_REEVALUATION",
      "observable_contract": "The DAC target responds to input-code threshold changes without requiring a clock event, using tdel, trise, and tfall for output timing.",
      "required_signals": [
