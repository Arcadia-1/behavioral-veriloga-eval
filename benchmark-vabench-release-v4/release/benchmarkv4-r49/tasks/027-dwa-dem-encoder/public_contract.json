  "properties": [
    {
      "id": "P_V2B_ROUND_AND_CLAMP",
      "observable_contract": "On each rising helper clock crossing, vin rounds to the nearest integer and clamps to a four-bit code from 0 through 15.",
      "required_signals": [
        "time",
        "clk_i",
        "vin_node",
        "code_3",
        "code_2",
        "code_1",
        "code_0"
      ]
    },
    {
