    {
      "id": "P_VARIABLE_GAIN_MIDPOINT",
      "observable_contract": "Drive the unclamped target as `2.0 * V(sigctrl_p, sigctrl_n) * V(sigin_p, sigin_n) + 0.2`.",
      "required_signals": [
        "time",
        "sigin_p",
        "sigin_n",
        "sigctrl_p",
        "sigctrl_n",
        "sigout"
      ]
    },
    {
      "id": "P_OUTPUT_CLAMP",
      "observable_contract": "Clamp the final output target to the inclusive interval `[-0.4 V, 0.8 V]`.",
      "required_signals": [
