  "properties": [
    {
      "id": "P_ON_RESET_CLEAR_CLK_OUT_QUADRANT",
      "observable_contract": "On reset, clear `clk_out`, quadrant outputs, and `phase_metric`.",
      "required_signals": [
        "time",
        "clk_i",
        "clk_q",
        "rst",
        "code_4",
        "code_0",
        "clk_out",
        "quadrant_1",
        "quadrant_0",
        "phase_metric"
      ]
    },
    {
      "id": "P_OBSERVE_THE_RISING_EDGES_OF_CLK",
      "observable_contract": "Observe the rising edges of `clk_i` and `clk_q` and maintain a four-quadrant phase reference.",
      "required_signals": [
        "time",
        "clk_i",
        "clk_q",
        "rst",
        "code_4",
        "code_0",
        "clk_out",
        "quadrant_1",
        "quadrant_0",
        "phase_metric"
      ]
    },
    {
      "id": "P_DECODE_CODE_4_CODE_0_AS",
      "observable_contract": "Decode `code_4..code_0` as an unsigned phase code from 0 to 31.",
      "required_signals": [
        "time",
        "clk_i",
        "clk_q",
        "rst",
        "code_4",
        "code_0",
        "clk_out",
        "quadrant_1",
        "quadrant_0",
        "phase_metric"
      ]
    },
    {
      "id": "P_GENERATE_CLK_OUT_EDGES_DELAYED_FROM",
      "observable_contract": "Generate `clk_out` edges delayed from the selected quadrant reference by `unit_delay` times the intra-quadrant code.",
      "required_signals": [
        "time",
        "clk_i",
        "clk_q",
        "rst",
        "code_4",
        "code_0",
        "clk_out",
        "quadrant_1",
        "quadrant_0",
        "phase_metric"
      ]
    },
    {
      "id": "P_QUADRANT_1_QUADRANT_0_MUST_EXPOSE",
      "observable_contract": "`quadrant_1..quadrant_0` must expose the selected quadrant.",
      "required_signals": [
        "time",
        "clk_i",
        "clk_q",
        "rst",
        "code_4",
        "code_0",
        "clk_out",
        "quadrant_1",
        "quadrant_0",
        "phase_metric"
      ]
    },
    {
      "id": "P_PHASE_METRIC_MUST_EXPOSE_THE_DECODED",
      "observable_contract": "`phase_metric` must expose the decoded phase code as a voltage-level metric.",
      "required_signals": [
        "time",
        "clk_i",
        "clk_q",
        "rst",
        "code_4",
        "code_0",
        "clk_out",
        "quadrant_1",
        "quadrant_0",
        "phase_metric"
      ]
    }
  ],
