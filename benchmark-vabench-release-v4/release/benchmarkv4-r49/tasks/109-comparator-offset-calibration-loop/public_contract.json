  "identity": {
    "category": "comparator",
    "difficulty": "D3",
    "level": "L2",
    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "Comparator Offset Calibration Loop"
  },
  "modeling_constraints": [
    "Treat the companion comparator as a supplied harness component coupled only through the declared voltage-domain ports.",
    "Update search state on falling clock events and drive symmetric stimulus and status through smoothed voltage contributions.",
    "Do not use current contributions, ddt(), idt(), validation hooks, hard-coded waveform sample points, or simulator-specific side channels."
  ],
  "properties": [
    {
      "id": "P_ZERO_INITIAL_ESTIMATE",
      "observable_contract": "The signed estimate initializes to zero, the search increment initializes to step_initial, and valid begins low.",
      "required_signals": [
        "time",
        "offset_est",
        "valid"
      ]
    },
    {
      "id": "P_FALLING_EDGE_UPDATE",
      "observable_contract": "The calibration state updates only on falling clk crossings through the midpoint of vdd and vss.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "clk",
        "dcmpp",
        "offset_est"
      ]
    },
    {
      "id": "P_DECISION_DIRECTION",
      "observable_contract": "At an update, a high dcmpp decreases the estimate by the current step and a low dcmpp increases it by the current step.",
      "required_signals": [
        "time",
        "clk",
        "dcmpp",
        "offset_est"
      ]
    },
    {
      "id": "P_SUCCESSIVE_STEP_HALVING",
      "observable_contract": "The magnitude of the search increment halves after every update, yielding a successive-approximation trajectory.",
      "required_signals": [
        "time",
        "clk",
        "dcmpp",
        "offset_est"
      ]
    },
    {
      "id": "P_SYMMETRIC_DIFFERENTIAL_STIMULUS",
      "observable_contract": "Vinp and vinn remain symmetric around mid-supply and vinp minus vinn equals offset_est.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "vinp",
        "vinn",
        "offset_est"
      ]
    },
    {
      "id": "P_VALID_COMPLETION",
      "observable_contract": "Valid remains at vss until iterations updates complete, then rises to vdd and the reported estimate resolves the supplied comparator trip point represented by vos_ref within the search resolution.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "clk",
        "offset_est",
        "valid",
        "vos_ref"
      ]
    }
  ],
