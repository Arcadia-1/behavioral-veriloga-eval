    {
      "id": "P_PASSBAND_TRANSFER",
      "observable_contract": "When the referenced input lies inside `[vclamp_lower, vclamp_upper]`, pass that referenced voltage to the output.",
      "required_signals": [
        "time",
        "vin",
        "vout"
      ]
    },
    {
      "id": "P_LOWER_CLAMP",
      "observable_contract": "When the referenced input is below `vclamp_lower`, drive the lower clamp value.",
