simulator lang=spectre
global 0

ahdl_include "./dut/dac_restore_10bit_offset.va"

Vclk (clk 0) vsource type=pwl wave=[0 0 1n 0 1.05n 0.9 1.50n 0.9 1.55n 0 11n 0 11.05n 0.9 11.50n 0.9 11.55n 0 21n 0 21.05n 0.9 21.50n 0.9 21.55n 0 31n 0 31.05n 0.9 31.50n 0.9 31.55n 0]
VD1 (D1 0) vsource type=pwl wave=[0 0 27.95n 0 28n 0.9]
