  "observable_contract": [
    {
      "contract": "Compare the analog voltage difference directly. Drive `vout` near `vh` when `abs(V(vin1) - V(vin2)) <= match_tol`; otherwise drive it near `0 V`. The decision should be deterministic and memoryless, with a smoothed voltage transition on the output.",
      "property_id": "P_COMPARE_THE_ANALOG_VOLTAGE_DIFFERENCE_DIRECTLY",
      "required_signals": [
        "time",
        "vin1",
        "vin2",
        "vout"
      ]
    },
    {
      "contract": "`match_tol = 0.05 V from [0:inf)`: maximum allowed absolute input difference for a match.",
      "property_id": "P_MATCH_TOL_0_05_V_FROM",
      "required_signals": [
        "time",
        "vin1",
        "vin2",
        "vout"
      ]
    },
    {
      "contract": "`vh = 0.9 V`: match output level.",
      "property_id": "P_VH_0_9_V_MATCH_OUTPUT",
      "required_signals": [
        "time",
        "vin1",
        "vin2",
        "vout"
      ]
    },
    {
      "contract": "`tr = 20 ps from [0:inf)`: output transition smoothing time.",
      "property_id": "P_TR_20_PS_FROM_0_INF",
      "required_signals": [
        "time",
        "vin1",
        "vin2",
        "vout"
      ]
    },
    {
      "contract": "- `match_tol = 0.05 V from [0:inf)`: maximum allowed absolute input difference for a match. - `vh = 0.9 V`: match output level. - `tr = 20 ps from [0:inf)`: output transition smoothing time.",
      "property_id": "P_MATCH_TOL_0_05_V_FROM_2",
      "required_signals": [
        "time",
        "vin1",
        "vin2",
        "vout"
      ]
    },
    {
      "contract": "Use deterministic voltage-domain Verilog-A and voltage contributions only. Do not emit a testbench, checker logic, out-of-band test hooks, hard-code testbench sample points, use current contributions, transistor-level devices, `ddt()`, `idt()`, or simulator side channels.",
      "property_id": "P_USE_DETERMINISTIC_VOLTAGE_DOMAIN_VERILOG_A",
      "required_signals": [
        "time",
        "vin1",
        "vin2",
        "vout"
      ]
    }
