  "properties": [
    {
      "id": "P_RESET_OR_LOW_ENABLE_DRIVES_VOUT",
      "observable_contract": "Reset or low `enable` drives `vout` to common mode, clears residual metric, and clears `valid`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "offset_2",
        "offset_1",
        "offset_0",
        "vout",
        "residual_metric",
        "valid"
      ]
    },
    {
      "id": "P_ON_EACH_ENABLED_RISING_CLK_SAMPLE",
      "observable_contract": "On each enabled rising `clk`, sample gain and offset trim codes.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "offset_2",
        "offset_1",
        "offset_0",
        "vout",
        "residual_metric",
        "valid"
      ]
    },
    {
      "id": "P_USE_GAIN_GAIN_BASE_GAIN_STEP",
      "observable_contract": "Use `gain = gain_base + gain_step * gain_code`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "offset_2",
        "offset_1",
        "offset_0",
        "vout",
        "residual_metric",
        "valid"
      ]
    },
    {
      "id": "P_USE_SIGNED_OFFSET_OFFSET_CODE_3",
      "observable_contract": "Use signed offset `(offset_code - 3) * offset_lsb`.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "offset_2",
        "offset_1",
        "offset_0",
        "vout",
        "residual_metric",
        "valid"
      ]
    },
    {
      "id": "P_DRIVE_VOUT_AS_THE_CLIPPED_GAIN",
      "observable_contract": "Drive `vout` as the clipped gain-and-offset adjusted input around common mode.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "offset_2",
        "offset_1",
        "offset_0",
        "vout",
        "residual_metric",
        "valid"
      ]
    },
    {
      "id": "P_RESIDUAL_METRIC_REPORTS_THE_ABSOLUTE_OUTPUT",
      "observable_contract": "`residual_metric` reports the absolute output distance from common mode and `valid` marks that a trim sample has occurred.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "rst",
        "enable",
        "gain_2",
        "gain_1",
        "gain_0",
        "offset_2",
        "offset_1",
