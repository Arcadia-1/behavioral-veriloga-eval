        "time",
        "aout",
        "din0",
        "din1",
        "din2",
        "din3",
        "din4",
        "din5",
        "rdy"
      ]
    },
    {
      "id": "P_TEXT_WEIGHTED_CODE_16_DIN5_8",
      "observable_contract": "```text weighted_code = 16*din5 + 8*din4 + 4*din3 + 2*din2 + 1*din1 + 0.5*din0 aout = (weighted_code / 47.5) * 2.0 * vdd - vdd ```",
      "required_signals": [
        "time",
        "aout",
        "din0",
        "din1",
        "din2",
        "din3",
        "din4",
        "din5",
        "rdy"
      ]
    },
    {
      "id": "P_EACH_DIN_TERM_IS_1_WHEN",
      "observable_contract": "Each `din*` term is `1` when the corresponding voltage is above `vth` and `0` otherwise. The denominator `47.5` is the fixed source normalization basis including the non-switching reference contribution.",
