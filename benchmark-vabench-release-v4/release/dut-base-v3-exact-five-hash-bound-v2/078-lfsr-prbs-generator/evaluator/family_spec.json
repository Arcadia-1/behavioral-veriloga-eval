  "family_id": "078",
  "identity": {
    "category": "stimulus_source_generators",
    "difficulty": "D2",
    "level": "L1",
    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A for resettable PRBS-7 stimulus generation",
    "title": "LFSR PRBS Generator"
  },
  "modeling_constraints": [
    "Use deterministic rising-edge state updates with active-low reset semantics.",
    "Preserve the public bit ordering and expose every state bit continuously.",
    "Do not add undeclared taps, seed ports, files, or validation-only states."
  ],
  "properties": [
    {
      "id": "P_RESET_SEED",
      "observable_contract": "When rst_n is below vth, the exposed seven-bit state is loaded from seed[6:0]; legal seed overrides are integers 0 through 127 inclusive, and seed 0 is remapped to 7'b0000001 to avoid the LFSR lock-up state.",
      "required_signals": [
        "time",
        "rst_n",
        "state_0",
        "state_1",
        "state_2",
        "state_3",
        "state_4",
        "state_5",
        "state_6"
      ]
    },
    {
      "id": "P_ENABLE_GATING",
      "observable_contract": "On rising clk crossings, the state advances only when rst_n and en are both above vth; otherwise it holds or resets as applicable.",
      "required_signals": [
        "time",
        "clk",
        "rst_n",
        "en",
        "state_0",
        "state_1",
        "state_2",
        "state_3",
        "state_4",
        "state_5",
        "state_6"
      ]
    },
    {
      "id": "P_FEEDBACK_POLYNOMIAL",
      "observable_contract": "Each enabled update sets next state_0 to previous state_6 XOR previous state_5, implementing x^7 + x^6 + 1.",
      "required_signals": [
        "time",
        "clk",
        "en",
        "state_0",
        "state_5",
        "state_6"
      ]
    },
    {
      "id": "P_SHIFT_SEQUENCE",
      "observable_contract": "Each enabled update sets next state_i to previous state_(i-1) for i from 1 through 6.",
      "required_signals": [
        "time",
        "clk",
        "en",
        "state_0",
        "state_1",
        "state_2",
        "state_3",
        "state_4",
        "state_5",
        "state_6"
      ]
    },
    {
      "id": "P_SERIAL_OUTPUT",
      "observable_contract": "serial_out always represents the current state_6 bit.",
      "required_signals": [
        "time",
        "serial_out",
        "state_6"
      ]
    },
    {
      "id": "P_OUTPUT_LEVELS",
      "observable_contract": "serial_out and every state output use 0 V and vdd levels with delay td and transition smoothing trf.",
      "required_signals": [
        "time",
        "serial_out",
        "state_0",
        "state_1",
        "state_2",
        "state_3",
        "state_4",
        "state_5",
        "state_6"
      ]
    }
  ],
