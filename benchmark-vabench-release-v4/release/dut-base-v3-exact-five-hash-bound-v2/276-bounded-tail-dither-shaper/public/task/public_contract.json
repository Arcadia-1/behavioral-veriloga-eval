  "observable_contract": [
    {
      "description": "Measure analog inputs relative to the local `vss` rail and normalize by the current local supply span `span = V(vdd, vss)`. Clear all observables when `en` is low or when `span` is outside `[span_min, span_max]`. The DUT updates its observable state on rising `clk` crossings and clears state while `rst` is high.",
      "id": "P_MEASURE_ANALOG_INPUTS_RELATIVE_TO_THE",
      "required_signals": [
        "time",
        "clk",
        "ctrl0",
        "ctrl1",
        "en",
        "flag",
        "in0",
        "in1",
        "in2",
        "in3",
        "metric",
        "out",
        "rst",
        "vdd",
        "vss"
      ]
    },
    {
      "description": "For each valid update, compute:",
      "id": "P_FOR_EACH_VALID_UPDATE_COMPUTE",
      "required_signals": [
        "time",
        "clk",
        "ctrl0",
        "ctrl1",
        "en",
        "flag",
        "in0",
        "in1",
        "in2",
        "in3",
        "metric",
        "out",
        "rst",
        "vdd",
        "vss"
      ]
    },
    {
      "description": "```text x0 = clip01((V(in0) - V(vss)) / span) x1 = clip01((V(in1) - V(vss)) / span) c0 = clip01(V(ctrl0) / vhi) aux = clip01(abs(x0 - x1) + 0.35*c0) acc = clip01(0.62*previous_acc + 0.32*aux) out = vhi*acc flag = vhi when acc > 0.58, otherwise 0 metric = vhi*aux ```",
      "id": "P_TEXT_X0_CLIP01_V_IN0_V",
      "required_signals": [
        "time",
        "clk",
        "ctrl0",
        "ctrl1",
        "en",
        "flag",
        "in0",
        "in1",
        "in2",
        "in3",
        "metric",
        "out",
        "rst",
        "vdd",
        "vss"
      ]
    },
    {
      "description": "Reset, disabled, and out-of-range supply conditions set `previous_acc`, `out`, `flag`, and `metric` to 0. Preserve `in2`, `in3`, and `ctrl1` as public interface inputs; they are not part of the bounded-tail update formula for this task.",
      "id": "P_RESET_DISABLED_AND_OUT_OF_RANGE",
      "required_signals": [
        "time",
        "clk",
        "ctrl0",
        "ctrl1",
        "en",
        "flag",
        "in0",
        "in1",
        "in2",
        "in3",
        "metric",
        "out",
        "rst",
        "vdd",
        "vss"
      ]
    }
  ],
