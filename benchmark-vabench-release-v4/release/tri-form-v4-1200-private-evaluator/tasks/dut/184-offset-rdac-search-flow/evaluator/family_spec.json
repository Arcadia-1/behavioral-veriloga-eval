  "properties": [
    {
      "id": "P_TWO_PHASE_CLOCKED_FLOW",
      "observable_contract": "Rising `ck` crossings execute the deterministic RDAC-refinement phase before the offset-search phase, using `d < 0.5 V` as the low comparator direction.",
