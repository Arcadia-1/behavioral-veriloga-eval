  "identity": {
    "category": "pll_clock_timing_systems",
    "difficulty": "D2",
    "level": "L2",
    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "ADPLL Ratio Hop Timer"
  },
  "modeling_constraints": [
    "Use a deterministic timing loop whose feedback clock is derived from the generated DCO.",
    "Use rail-referenced voltage-coded outputs and appropriate oscillator timestep guidance.",
    "Do not hard-code validation stimulus, stop times, sample windows, gold internals, or simulator side channels."
  ],
  "properties": [
    {
      "id": "P_RATIO_REQUEST_CLAMP",
      "observable_contract": "The voltage-coded ratio request rounds V(ratio_ctrl) to the nearest integer with half-step boundaries and then clips the feedback divide ratio to the inclusive ratio_min through ratio_max range, including legal non-default override ranges.",
      "required_signals": [
        "time",
        "ratio_ctrl",
        "vout",
        "fb_clk"
      ]
    },
    {
      "id": "P_RATIO_HALF_STEP_ROUNDING",
      "observable_contract": "Requests immediately below a positive half-step round down while an exact positive half-step rounds up before divider selection.",
      "required_signals": [
        "time",
        "ratio_ctrl",
        "vout",
        "fb_clk"
      ]
    },
    {
      "id": "P_RATIO_OVERRIDE_SATURATION",
      "observable_contract": "Requests below ratio_min or above ratio_max saturate to the respective inclusive endpoint when legal non-default bounds are configured.",
      "required_signals": [
        "time",
        "ratio_ctrl",
        "vout",
        "fb_clk"
      ]
    },
    {
      "id": "P_DCO_FREQUENCY_BOUNDS",
      "observable_contract": "The behavioral DCO on vout remains within the configured f_min and f_max limits.",
      "required_signals": [
        "time",
        "vout"
      ]
    },
    {
      "id": "P_FEEDBACK_DERIVED_FROM_DCO",
      "observable_contract": "Feedback-clock activity is derived by dividing vout activity by the requested ratio rather than from an independent clock source.",
      "required_signals": [
        "time",
        "ratio_ctrl",
        "vout",
        "fb_clk"
      ]
    },
    {
      "id": "P_BOUNDED_CONTROL_MONITOR",
      "observable_contract": "Reference-versus-feedback timing error adjusts a bounded control state represented by rail-referenced vctrl_mon.",
      "required_signals": [
        "time",
        "vdd",
        "vss",
        "ref_clk",
        "fb_clk",
        "vctrl_mon"
      ]
    },
    {
      "id": "P_PRE_HOP_LOCK",
      "observable_contract": "Stable pre-hop tracking produces lock only after lock_count_target consecutive feedback events satisfy lock_tol.",
      "required_signals": [
        "time",
        "ref_clk",
        "fb_clk",
        "lock"
      ]
    },
    {
      "id": "P_RATIO_HOP_REACQUISITION",
      "observable_contract": "A changed ratio request causes loss of lock qualification followed by renewed lock after the loop tracks the new feedback cadence.",
      "required_signals": [
        "time",
        "ratio_ctrl",
        "ref_clk",
        "fb_clk",
        "vctrl_mon",
        "lock"
      ]
    }
  ],
