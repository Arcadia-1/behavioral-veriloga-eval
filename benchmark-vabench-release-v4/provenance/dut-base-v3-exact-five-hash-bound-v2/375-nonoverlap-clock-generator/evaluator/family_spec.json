  "properties": [
    {
      "id": "P_RESET_OR_A_LOW_ENABLE_CLEARS",
      "observable_contract": "Reset or a low `enable` clears both phases, `deadtime_metric`, and `valid`.",
      "required_signals": [
        "time",
        "clk_in",
        "rst",
        "enable",
        "phi1",
        "phi2",
        "deadtime_metric",
        "valid"
      ]
    },
    {
      "id": "P_A_RISING_CLK_IN_REQUEST_EVENTUALLY",
      "observable_contract": "A rising `clk_in` request eventually enables `phi1`; a falling `clk_in` request eventually enables `phi2`.",
      "required_signals": [
        "time",
        "clk_in",
        "rst",
        "enable",
        "phi1",
        "phi2",
        "deadtime_metric",
        "valid"
      ]
    },
    {
      "id": "P_DURING_EACH_HANDOFF_BOTH_PHI1_AND",
      "observable_contract": "During each handoff, both `phi1` and `phi2` remain low for the configured dead-time interval.",
      "required_signals": [
        "time",
        "clk_in",
        "rst",
        "enable",
        "phi1",
        "phi2",
        "deadtime_metric",
        "valid"
      ]
    },
    {
      "id": "P_PHI1_AND_PHI2_MUST_NEVER_BE",
      "observable_contract": "`phi1` and `phi2` must never be high at the same time.",
      "required_signals": [
        "time",
        "clk_in",
        "rst",
        "enable",
        "phi1",
        "phi2",
        "deadtime_metric",
        "valid"
      ]
    },
    {
      "id": "P_DEADTIME_METRIC_IS_HIGH_ONLY_WHILE",
      "observable_contract": "`deadtime_metric` is high only while a pending phase request is in the enforced both-low interval.",
      "required_signals": [
        "time",
        "clk_in",
        "rst",
        "enable",
        "phi1",
        "phi2",
        "deadtime_metric",
        "valid"
      ]
    },
    {
      "id": "P_VALID_BECOMES_HIGH_AFTER_THE_FIRST",
      "observable_contract": "`valid` becomes high after the first enabled handoff completes and remains high until reset or disable.",
      "required_signals": [
        "time",
        "clk_in",
        "rst",
        "enable",
        "phi1",
        "phi2",
        "deadtime_metric",
        "valid"
      ]
    }
