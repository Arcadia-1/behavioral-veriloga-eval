  "observable_contract": [
    {
      "contract": "Define `upper_th = offset + vhys/2` and `lower_th = offset - vhys/2`. On initialization, set the output state high if `V(inp,inm)` is at or above the upper threshold; otherwise set it low. After initialization, switch high only on a rising crossing of `upper_th`, switch low only on a falling crossing of `lower_th`, and hold the previous state inside the hysteresis band. Drive `out` to the selected rail with delay `td` and transition time `tr`.",
      "property_id": "P_DEFINE_UPPER_TH_OFFSET_VHYS_2",
      "required_signals": [
        "time",
        "inm",
        "inp",
        "out"
      ]
    },
    {
      "contract": "`vout_high = 0.9 V`: high output rail.",
      "property_id": "P_VOUT_HIGH_0_9_V_HIGH",
      "required_signals": [
        "time",
        "inm",
        "inp",
        "out"
      ]
    },
    {
      "contract": "`vout_low = 0.0 V`: low output rail.",
      "property_id": "P_VOUT_LOW_0_0_V_LOW",
      "required_signals": [
        "time",
        "inm",
        "inp",
        "out"
      ]
    },
    {
      "contract": "`offset = 0.0 V`: input-referred switching offset.",
      "property_id": "P_OFFSET_0_0_V_INPUT_REFERRED",
      "required_signals": [
        "time",
        "inm",
        "inp",
        "out"
      ]
    },
    {
      "contract": "`vhys = 40 mV from [0:inf)`: total hysteresis width.",
      "property_id": "P_VHYS_40_MV_FROM_0_INF",
      "required_signals": [
        "time",
        "inm",
        "inp",
        "out"
      ]
    },
    {
      "contract": "`td = 400 ps from [0:inf)`: propagation delay from a qualifying threshold crossing to the output state change.",
      "property_id": "P_TD_400_PS_FROM_0_INF",
      "required_signals": [
        "time",
        "inm",
        "inp",
        "out"
      ]
    }
  ],
