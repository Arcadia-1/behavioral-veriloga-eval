  "properties": [
    {
      "id": "P_RESET_DISABLE_CLEAR",
      "observable_contract": "Reset or low enable restores phase_center and clears detector, lock, and recovered-clock state.",
      "required_signals": [
        "time",
        "rst",
        "enable",
        "recovered_clk",
        "early",
        "late",
        "phase_4",
        "phase_3",
        "phase_2",
        "phase_1",
        "phase_0",
        "lock"
      ]
    },
    {
      "id": "P_BANGBANG_DECISION",
      "observable_contract": "Each data edge is classified against the nearest recovered-clock edge as early, late, or coincident.",
      "required_signals": [
        "time",
        "data_edge",
        "recovered_clk",
        "rst",
        "enable",
        "early",
        "late"
      ]
    },
    {
      "id": "P_PHASE_CODE_UPDATE",
      "observable_contract": "Late and early decisions move the clamped phase code in opposite declared directions.",
      "required_signals": [
        "time",
        "data_edge",
        "recovered_clk",
        "early",
        "late",
        "phase_4",
        "phase_3",
        "phase_2",
        "phase_1",
        "phase_0"
      ]
    },
    {
      "id": "P_PHASE_ROTATION",
      "observable_contract": "Recovered-clock edges preserve the reference-clock waveform with phase-code-proportional delay.",
      "required_signals": [
        "time",
        "ref_clk",
        "recovered_clk",
        "rst",
        "enable",
        "phase_4",
        "phase_3",
        "phase_2",
        "phase_1",
        "phase_0"
      ]
    },
    {
      "id": "P_LOCK_QUALIFICATION",
      "observable_contract": "Lock requires four in-window decisions and drops after two consecutive out-of-window decisions.",
      "required_signals": [
        "time",
        "data_edge",
        "recovered_clk",
        "rst",
        "enable",
        "phase_4",
        "phase_3",
        "phase_2",
        "phase_1",
        "phase_0",
        "lock"
      ]
    }
  ],
