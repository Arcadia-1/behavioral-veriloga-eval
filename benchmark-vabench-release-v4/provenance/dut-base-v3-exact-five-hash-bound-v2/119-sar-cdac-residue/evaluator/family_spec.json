          {
            "depends_on": [],
            "name": "sar_cdac_residue",
            "parameters": [
              {
                "default": 0.9,
                "name": "vdd",
                "override_behavior": "sets the rising CLK sampling threshold at one half of vdd",
                "type": "real",
                "units": "V",
                "valid_range": "vdd > 0"
              },
              {
                "default": 0.9,
                "name": "vrefp",
                "override_behavior": "sets the upper endpoint of the reference span used by all residue steps",
                "type": "real",
                "units": "V",
                "valid_range": "vrefp > vrefn"
              },
              {
                "default": 0.0,
                "name": "vrefn",
                "override_behavior": "sets the lower endpoint of the reference span used by all residue steps",
                "type": "real",
                "units": "V",
                "valid_range": "vrefn < vrefp"
              },
              {
                "default": 1e-12,
                "name": "tr",
                "override_behavior": "sets the transition time of the VRES voltage output",
                "type": "real",
                "units": "s",
                "valid_range": "tr > 0"
              }
