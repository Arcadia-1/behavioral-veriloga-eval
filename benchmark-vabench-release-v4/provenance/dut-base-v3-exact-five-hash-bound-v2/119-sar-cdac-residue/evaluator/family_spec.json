  "family_id": "119",
  "identity": {
    "category": "mixed_signal",
    "difficulty": "D2",
    "level": "L1",
    "supported_scope": "pure voltage-domain event-driven transient behavioral Verilog-A",
    "title": "SAR CDAC Residue"
  },
  "modeling_constraints": [
    "Use deterministic event-driven residue state updates with the declared edge directions.",
    "Use the full vrefp minus vrefn span for every weighted update.",
    "Do not omit S1, substitute different edge polarities, use current contributions, or add validation-only hooks."
  ],
  "properties": [
    {
      "id": "P_INPUT_SAMPLE",
      "observable_contract": "At initial_step and each rising CLK crossing through vdd/2, the residue state samples VIN.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "vres"
      ]
    },
    {
      "id": "P_S6_HALF_ADD",
      "observable_contract": "Each falling S6 crossing through vdd/2 adds one half of the public reference span to the current residue.",
      "required_signals": [
        "time",
        "s6",
        "vres"
      ]
    },
    {
      "id": "P_BINARY_SUBTRACTIONS",
      "observable_contract": "Rising crossings of S5, S4, S3, S2, and S1 through vdd/2 subtract one fourth, one eighth, one sixteenth, one thirty-second, and one sixty-fourth of the public reference span respectively.",
      "required_signals": [
        "time",
        "s5",
        "s4",
        "s3",
        "s2",
        "s1",
        "vres"
      ]
    },
    {
      "id": "P_EDGE_POLARITY",
      "observable_contract": "S6 updates only on falling vdd/2 threshold crossings, while S5 through S1 update only on rising vdd/2 threshold crossings.",
      "required_signals": [
        "time",
        "s6",
        "s5",
        "s4",
        "s3",
        "s2",
        "s1",
        "vres"
      ]
    },
    {
      "id": "P_ACCUMULATED_STATE",
      "observable_contract": "Between declared sampling and switch events, VRES represents and holds the accumulated residue state.",
      "required_signals": [
        "time",
        "vin",
        "clk",
        "s6",
        "s5",
        "s4",
        "s3",
        "s2",
        "s1",
        "vres"
      ]
    },
    {
      "id": "P_OUTPUT_TRANSITION",
      "observable_contract": "VRES changes from the residue state using the declared tr transition time.",
      "required_signals": [
        "time",
        "vres"
      ]
    }
  ],
