{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vabench.local/schemas/v4/derivation_manifest.schema.json",
  "title": "vaBench v4 tri-form negative assignment",
  "oneOf": [
    {"$ref": "#/$defs/legacy_partition_manifest"},
    {"$ref": "#/$defs/canonical_assignment_manifest"}
  ],
  "$defs": {
    "mutation_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_]*$"
    },
    "legacy_partition_manifest": {
      "description": "Migration-only v1 input. P/H buckets no longer define distinct visible and hidden behavior suites.",
      "type": "object",
      "required": ["schema_version", "family_id", "mutation_catalog_sha256", "mutation_partition"],
      "properties": {
        "schema_version": {"const": "v4-derivation-manifest-v1"},
        "family_id": {"type": "string", "pattern": "^[0-9]{3}$"},
        "mutation_catalog_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "mutation_partition": {
          "type": "object",
          "required": ["bugfix_seed", "testbench_public_feedback", "testbench_private_score"],
          "properties": {
            "bugfix_seed": {
              "type": "array",
              "minItems": 1,
              "maxItems": 1,
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/mutation_id"}
            },
            "testbench_public_feedback": {
              "type": "array",
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/mutation_id"}
            },
            "testbench_private_score": {
              "type": "array",
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/mutation_id"}
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "canonical_assignment_manifest": {
      "type": "object",
      "required": ["schema_version", "family_id", "negative_assignment"],
      "properties": {
        "schema_version": {"const": "v4-derivation-manifest-v2"},
        "family_id": {"type": "string", "pattern": "^[0-9]{3}$"},
        "mutation_catalog_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "base_dut": {"type": "object"},
        "negative_assignment": {
          "type": "object",
          "required": ["bugfix_seed", "testbench_suite"],
          "properties": {
            "bugfix_seed": {"$ref": "#/$defs/mutation_id"},
            "testbench_suite": {
              "type": "array",
              "minItems": 5,
              "maxItems": 5,
              "uniqueItems": true,
              "items": {"$ref": "#/$defs/mutation_id"}
            }
          },
          "additionalProperties": false
        },
        "selection_evidence": {"type": "object"},
        "private_materialization": {"type": "object"}
      },
      "anyOf": [
        {"required": ["mutation_catalog_sha256"]},
        {"required": ["base_dut"]}
      ],
      "additionalProperties": false
    }
  }
}
