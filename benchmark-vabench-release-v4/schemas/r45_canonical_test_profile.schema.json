{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vabench.local/schemas/r45/canonical_test_profile.schema.json",
  "title": "vaBench r45 canonical test profile",
  "type": "object",
  "required": [
    "schema_version",
    "profile_name",
    "generated_from",
    "source",
    "property_ids",
    "parameters",
    "corners",
    "deterministic_seed",
    "simulator_options",
    "canonical_semantics_sha256",
    "test_deck_sha256",
    "reuse_policy"
  ],
  "properties": {
    "schema_version": {"const": "r45-canonical-test-profile-v1"},
    "profile_name": {"const": "canonical_test"},
    "generated_from": {
      "type": "object",
      "required": ["script", "version"],
      "properties": {
        "script": {"const": "render_r45_canonical_test.py"},
        "version": {"const": "r45-canonical-test-renderer-v1"}
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": [
        "schema_version",
        "family_id",
        "task_id",
        "harness_spec_sha256",
        "feedback_semantics_sha256",
        "score_semantics_sha256"
      ],
      "properties": {
        "schema_version": {"const": "v4-harness-spec-v1"},
        "family_id": {"type": "string", "pattern": "^[0-9]{3}$"},
        "task_id": {"type": "string", "pattern": "^v4-[0-9]{3,4}$"},
        "harness_spec_sha256": {"$ref": "#/$defs/sha256"},
        "feedback_semantics_sha256": {"$ref": "#/$defs/sha256"},
        "score_semantics_sha256": {"$ref": "#/$defs/sha256"}
      },
      "additionalProperties": false
    },
    "property_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^P_[A-Z0-9_]+$"},
      "uniqueItems": true
    },
    "parameters": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/scalar"}
    },
    "corners": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "deterministic_seed": {"type": "integer", "minimum": 0},
    "simulator_options": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/scalar"}
    },
    "canonical_semantics_sha256": {"$ref": "#/$defs/sha256"},
    "test_deck_sha256": {"$ref": "#/$defs/sha256"},
    "reuse_policy": {"const": "public_visible_and_final_trusted_replay_same_bytes"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "scalar": {"type": ["string", "number", "integer", "boolean"]}
  },
  "additionalProperties": false
}
