{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vabench.local/schemas/v4/tri_form_rollout.schema.json",
  "title": "vaBench v4 DUT tri-form rollout plan",
  "type": "object",
  "required": ["schema_version", "generated_at", "policy", "summary", "batches"],
  "properties": {
    "schema_version": {"const": "v4-tri-form-rollout-v1"},
    "generated_at": {"type": "string", "format": "date-time"},
    "policy": {"type": "object"},
    "summary": {"type": "object"},
    "batches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["batch_id", "family_ids", "source_slugs", "stage_order", "status"],
        "properties": {
          "batch_id": {"type": "string", "pattern": "^dut-[0-9]{3}-[0-9]{3}$"},
          "family_ids": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^[0-9]{3}$"}},
          "source_slugs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "stage_order": {"type": "array", "minItems": 1, "items": {"type": "string"}},
          "status": {"enum": ["blocked_on_release_controls", "ready_for_family_backfill", "in_progress", "complete"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
