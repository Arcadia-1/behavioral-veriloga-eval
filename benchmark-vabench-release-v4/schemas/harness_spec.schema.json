{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vabench.local/schemas/v4/harness_spec.schema.json",
  "title": "vaBench v4 canonical harness specification",
  "type": "object",
  "required": [
    "schema_version",
    "family_id",
    "task_id",
    "generator",
    "candidate",
    "deck",
    "property_ids",
    "profile_defaults"
  ],
  "properties": {
    "schema_version": {"const": "v4-harness-spec-v1"},
    "family_id": {"type": "string", "pattern": "^[0-9]{3}$"},
    "task_id": {"type": "string", "pattern": "^v4-[0-9]{3,4}$"},
    "generator": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": {"const": "render_v4_harness.py"},
        "version": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "source_contract": {
      "type": "object",
      "properties": {
        "family_spec_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "checker_profile_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      },
      "additionalProperties": false
    },
    "candidate": {
      "type": "object",
      "required": ["source_root", "artifact_paths"],
      "properties": {
        "source_root": {"type": "string", "minLength": 1},
        "artifact_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)*\\.va$"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "support": {
      "type": "object",
      "required": ["source_root", "artifact_paths"],
      "properties": {
        "source_root": {"const": "./support"},
        "artifact_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)*\\.va$"
          },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "deck": {
      "type": "object",
      "required": ["header", "body_lines", "analyses", "save_signals"],
      "properties": {
        "header": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string"}
        },
        "include_templates": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "support_include_templates": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "body_lines": {
          "type": "array",
          "items": {"type": "string"}
        },
        "analyses": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "save_signals": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "property_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^P_[A-Z0-9_]+$"},
      "uniqueItems": true
    },
    "profile_defaults": {
      "type": "object",
      "required": ["feedback", "score"],
      "properties": {
        "feedback": {"$ref": "#/$defs/profile_spec"},
        "score": {"$ref": "#/$defs/profile_spec"}
      },
      "additionalProperties": false
    },
    "migration": {
      "type": "object",
      "properties": {
        "legacy_feedback_deck": {"type": "string", "minLength": 1},
        "legacy_feedback_deck_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "legacy_score_deck": {"type": "string", "minLength": 1},
        "legacy_score_deck_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "notes": {"type": "array", "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    },
    "canonical_semantics": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {"const": "single_deck_v1"}
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "scalar": {"type": ["string", "number", "integer", "boolean"]},
    "profile_spec": {
      "type": "object",
      "properties": {
        "parameters": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/scalar"}
        },
        "corners": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        },
        "deterministic_seed": {"type": "integer", "minimum": 0},
        "simulatorOptions": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/scalar"}
        },
        "deck_overrides": {"$ref": "#/$defs/deck_overrides"}
      },
      "additionalProperties": false
    },
    "deck_overrides": {
      "type": "object",
      "properties": {
        "body_lines": {
          "type": "array",
          "items": {"type": "string"}
        },
        "analyses": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "save_signals": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
