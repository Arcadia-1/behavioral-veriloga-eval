{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vabench.local/schemas/v4/harness_profile.schema.json",
  "title": "vaBench v4 generated harness profile",
  "type": "object",
  "required": [
    "schema_version",
    "profile_name",
    "harness_spec_sha256",
    "generated_from",
    "property_ids",
    "parameters",
    "corners",
    "deterministic_seed",
    "simulatorOptions",
    "public_visible"
  ],
  "properties": {
    "schema_version": {"const": "v4-harness-profile-v1"},
    "profile_name": {"enum": ["feedback", "score"]},
    "harness_spec_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "generated_from": {
      "type": "object",
      "required": ["script", "version"],
      "properties": {
        "script": {"const": "render_v4_harness.py"},
        "version": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "property_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^P_[A-Z0-9_]+$"},
      "uniqueItems": true
    },
    "parameters": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/scalar"}
    },
    "corners": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "deterministic_seed": {"type": "integer", "minimum": 0},
    "simulatorOptions": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/scalar"}
    },
    "deck_overrides": {"$ref": "#/$defs/deck_overrides"},
    "public_visible": {"type": "boolean"}
  },
  "$defs": {
    "scalar": {"type": ["string", "number", "integer", "boolean"]},
    "deck_overrides": {
      "type": "object",
      "properties": {
        "body_lines": {
          "type": "array",
          "items": {"type": "string"}
        },
        "analyses": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "save_signals": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {"properties": {"profile_name": {"const": "feedback"}}, "required": ["profile_name"]},
      "then": {
        "properties": {
          "simulatorOptions": {
            "type": "object",
            "required": ["evas_profile"],
            "properties": {"evas_profile": {"const": "balanced"}},
            "additionalProperties": {"$ref": "#/$defs/scalar"}
          },
          "public_visible": {"const": true}
        }
      }
    },
    {
      "if": {"properties": {"profile_name": {"const": "score"}}, "required": ["profile_name"]},
      "then": {"properties": {"public_visible": {"const": false}}}
    }
  ],
  "additionalProperties": false
}
