{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vaBench partial-pass negative candidate manifest",
  "type": "object",
  "required": [
    "task_id",
    "negative_count",
    "policy",
    "negatives"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*:(dut|tb|bugfix|e2e)$"
    },
    "negative_count": {
      "const": 5
    },
    "policy": {
      "const": "five_partial_pass_near_miss_negatives_per_task"
    },
    "negatives": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "source",
          "derived_from",
          "source_kind",
          "expected",
          "partial_pass_requirement",
          "shallow_passes",
          "full_failures",
          "validation_evidence",
          "note",
          "sha256"
        ],
        "properties": {
          "id": {
            "pattern": "^neg_[0-9]{3}$"
          },
          "kind": {
            "enum": [
              "boundary_near_miss",
              "timing_window_near_miss",
              "polarity_direction_near_miss",
              "state_reset_near_miss",
              "metric_writeout_near_miss"
            ]
          },
          "source": {
            "type": "string"
          },
          "derived_from": {
            "type": "string"
          },
          "source_kind": {
            "enum": [
              "existing_gold",
              "proposed_gold"
            ]
          },
          "expected": {
            "const": "FAIL_FULL_CHECKER"
          },
          "partial_pass_requirement": {
            "type": "string",
            "minLength": 1
          },
          "shallow_passes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "full_failures": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "validation_evidence": {
            "type": "object",
            "required": [
              "static_shallow_shape",
              "simulator_shallow_lane",
              "full_checker_lane",
              "publication_status"
            ],
            "properties": {
              "static_shallow_shape": {
                "enum": [
                  "pending_audit",
                  "pass"
                ]
              },
              "simulator_shallow_lane": {
                "enum": [
                  "pending_external_evas_spectre",
                  "pass"
                ]
              },
              "full_checker_lane": {
                "enum": [
                  "pending_external_evas_spectre",
                  "fail_as_expected"
                ]
              },
              "publication_status": {
                "enum": [
                  "asset_ready_not_simulator_certified",
                  "simulator_validated_partial_pass"
                ]
              }
            },
            "additionalProperties": false
          },
          "note": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
