{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vaBench 300-task expansion manifest",
  "type": "object",
  "required": [
    "date",
    "release",
    "status",
    "package_root",
    "summary",
    "tasks",
    "claim_boundary"
  ],
  "properties": {
    "date": {
      "type": "string"
    },
    "release": {
      "const": "vabench-300-expansion-v1.1"
    },
    "status": {
      "type": "string"
    },
    "package_root": {
      "const": "benchmark-vabench-release-v1/vabench-300-expansion"
    },
    "summary": {
      "type": "object",
      "required": [
        "task_count",
        "existing_certified_v1_task_count",
        "proposed_v11_task_count",
        "required_negative_per_task",
        "partial_pass_negative_count",
        "gold_reference_task_count",
        "certified_task_count",
        "pending_certification_task_count"
      ],
      "properties": {
        "task_count": {
          "const": 300
        },
        "existing_certified_v1_task_count": {
          "const": 271
        },
        "proposed_v11_task_count": {
          "const": 29
        },
        "required_negative_per_task": {
          "const": 5
        },
        "partial_pass_negative_count": {
          "const": 1500
        },
        "gold_reference_task_count": {
          "const": 300
        },
        "certified_task_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 300
        },
        "pending_certification_task_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 300
        },
        "negative_static_shallow_shape_verified_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1500
        },
        "negative_simulator_shallow_verified_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1500
        },
        "negative_full_checker_fail_verified_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1500
        }
      },
      "additionalProperties": true
    },
    "tasks": {
      "type": "array",
      "minItems": 300,
      "maxItems": 300,
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "topic_id",
          "legacy_task_id",
          "legacy_entry_id",
          "form",
          "family",
          "track",
          "difficulty",
          "category",
          "base_function",
          "release_task_manifest",
          "negative_manifest",
          "negative_count",
          "gold_status",
          "expansion_status"
        ],
        "properties": {
          "task_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*:(dut|tb|bugfix|e2e)$"
          },
          "topic_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
          },
          "legacy_task_id": {
            "type": "string",
            "pattern": "^vbr[0-9]+.*:(dut|tb|bugfix|e2e)$"
          },
          "legacy_entry_id": {
            "type": "string",
            "pattern": "^vbr[0-9]+.*$"
          },
          "form": {
            "enum": [
              "dut",
              "tb",
              "bugfix",
              "e2e"
            ]
          },
          "family": {
            "enum": [
              "spec-to-va",
              "tb-generation",
              "bugfix",
              "end-to-end"
            ]
          },
          "track": {
            "enum": [
              "core",
              "support"
            ]
          },
          "difficulty": {
            "enum": [
              "D1",
              "D2",
              "D3"
            ]
          },
          "negative_count": {
            "const": 5
          },
          "negative_manifest": {
            "type": "string"
          },
          "release_task_manifest": {
            "type": "string"
          },
          "gold_status": {
            "enum": [
              "existing_certified",
              "proposed_unverified"
            ]
          },
          "expansion_status": {
            "enum": [
              "existing_certified_v1",
              "proposed_v1.1_pending_certification"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "claim_boundary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
