{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "behavioral-va-eval task",
  "type": "object",
  "required": [
    "family",
    "category",
    "domain",
    "difficulty",
    "expected_backend",
    "scoring"
  ],
  "anyOf": [
    {
      "required": [
        "id"
      ]
    },
    {
      "required": [
        "task_id"
      ]
    }
  ],
  "properties": {
    "asset_type": {
      "type": "string",
      "enum": [
        "vabench_task"
      ]
    },
    "benchmark_split": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "family": {
      "type": "string",
      "enum": [
        "spec-to-va",
        "bugfix",
        "tb-generation",
        "end-to-end"
      ]
    },
    "category": {
      "type": "string"
    },
    "domain": {
      "type": "string",
      "enum": [
        "voltage"
      ]
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "easy",
        "medium",
        "hard"
      ]
    },
    "expected_backend": {
      "type": "string",
      "enum": [
        "evas"
      ]
    },
    "must_include": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "must_not_include": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scoring": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "syntax",
          "routing",
          "simulation",
          "behavior",
          "dut_compile",
          "tb_compile",
          "sim_correct"
        ]
      }
    },
    "release_form": {
      "type": "string",
      "enum": [
        "normal",
        "true-bugfix",
        "behavior-regression",
        "evidence-only"
      ]
    },
    "provenance_status": {
      "type": "string",
      "enum": [
        "clean",
        "badcase_available",
        "historical_bugfix_fixed_only",
        "reconstructed_badcase",
        "provenance_incomplete"
      ]
    },
    "source_main120_id": {
      "type": "string"
    },
    "badcase_origin": {
      "type": "string",
      "enum": [
        "original",
        "recovered",
        "reconstructed"
      ]
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model_capability": {
          "type": "boolean"
        },
        "benchmark_coverage": {
          "type": "boolean"
        },
        "bugfix_claim": {
          "type": "boolean"
        }
      }
    },
    "notes": {
      "type": "string"
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "release_form"
        ],
        "properties": {
          "release_form": {
            "const": "evidence-only"
          }
        }
      },
      "then": {
        "required": [
          "counts"
        ],
        "properties": {
          "counts": {
            "required": [
              "model_capability",
              "benchmark_coverage",
              "bugfix_claim"
            ],
            "properties": {
              "model_capability": {
                "const": false
              },
              "benchmark_coverage": {
                "const": false
              },
              "bugfix_claim": {
                "const": false
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "required": [
          "release_form"
        ],
        "properties": {
          "release_form": {
            "const": "true-bugfix"
          }
        }
      },
      "then": {
        "required": [
          "provenance_status"
        ],
        "properties": {
          "family": {
            "const": "bugfix"
          },
          "provenance_status": {
            "enum": [
              "badcase_available",
              "reconstructed_badcase"
            ]
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
