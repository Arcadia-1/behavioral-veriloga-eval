{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "vaBench release checksum manifest",
  "type": "object",
  "required": [
    "date",
    "release",
    "status",
    "algorithm",
    "file_count",
    "total_bytes",
    "category_counts",
    "excluded_files",
    "files",
    "notes"
  ],
  "properties": {
    "date": {
      "type": "string"
    },
    "release": {
      "const": "vabench-release-v1"
    },
    "status": {
      "enum": [
        "pass",
        "fail"
      ]
    },
    "algorithm": {
      "const": "sha256"
    },
    "file_count": {
      "type": "integer"
    },
    "total_bytes": {
      "type": "integer"
    },
    "category_counts": {
      "type": "object"
    },
    "excluded_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "category",
          "bytes",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "bytes": {
            "type": "integer"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        },
        "additionalProperties": true
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
