`include "constants.vams"
`include "disciplines.vams"

module soft_hysteretic_limiter(clk, rst, vin, out, metric);
input clk, rst, vin;
output out, metric;
electrical clk, rst, vin, out, metric;
parameter real tr = 100p;
parameter real gain = 1.8;
parameter real alpha = 0.18;
real s1, s2, y, hys;
analog begin
    @(initial_step) begin
        s1 = 0.0;
        s2 = 0.0;
        hys = 0.0;
    end
    @(cross(V(clk) - 0.45, +1)) begin
        if (V(rst) > 0.45) begin
            s1 = 0.0;
            s2 = 0.0;
            hys = 0.0;
        end else begin
            y = gain * (V(vin) - 0.45) + 0.45;
            hys = 0.0;
            s1 = s1 + alpha * (y + hys - s1);
            s2 = s1;
            y = s2;
            if (y > 0.9) y = 0.9; if (y < 0.0) y = 0.0;
        end
    end
    V(out) <+ transition(y, 0, tr, tr);
    V(metric) <+ transition(s1 - s2 + 0.45, 0, tr, tr);
end
endmodule

// vaBench partial-pass negative 3 for soft_hysteretic_limiter:bugfix
// Intended to preserve interface/smoke behavior while failing full checks.
// Mutation note: polarity_direction_near_miss.
