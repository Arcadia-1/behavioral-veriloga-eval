`include "constants.vams"
`include "disciplines.vams"

module mixed_logic_enable_voltage_driver(vin, clk, en, sel, a, b, vout);
    input vin, clk, en, sel, a, b;
    output vout;
    electrical vin, vout;
    logic clk, en, sel;
    wreal a, b, level;
    logic en_logic;
    parameter real tr = 200p;

    assign en_logic = en;

    analog begin
        V(vout) <+ transition(V(vin), 0.0, tr, tr);
    end
endmodule
