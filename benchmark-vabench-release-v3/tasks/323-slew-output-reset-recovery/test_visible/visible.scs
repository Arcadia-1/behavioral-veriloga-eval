simulator lang=spectre
global 0

ahdl_include "slew_output_reset_recovery.va"

Vvin (vin 0) vsource type=pwl wave=[ 0n 0.0 55n 0.0 ]
Vmode (mode 0) vsource type=pwl wave=[ 0n 0.0 55n 0.0 ]
Vrst (rst 0) vsource type=pwl wave=[ 0n 0.9 8n 0.9 8.1n 0 28n 0 28.1n 0.9 36n 0.9 36.1n 0 55n 0 ]
Vclk (clk 0) vsource type=pwl wave=[ 0n 0 4.9n 0 5.0n 0.9 5.5n 0.9 5.6n 0 19.9n 0 20.0n 0.9 20.5n 0.9 20.6n 0 44.9n 0 45.0n 0.9 45.5n 0.9 45.6n 0 55n 0 ]

XDUT (vin clk mode rst out metric) slew_output_reset_recovery

tran tran stop=55n
save vin clk mode rst out metric
