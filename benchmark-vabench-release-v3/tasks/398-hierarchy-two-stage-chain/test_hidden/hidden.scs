simulator lang=spectre
global 0

ahdl_include "v3_child_gain.va"
ahdl_include "hierarchy_two_stage_chain.va"

Vvin (vin 0) vsource dc=0.7
Vclk (clk 0) vsource dc=0.0
Vmode (mode 0) vsource dc=0.0
Vrst (rst 0) vsource dc=0.0

XDUT (vin clk mode rst out metric) hierarchy_two_stage_chain

tran tran stop=160n
save vin clk mode rst out metric
