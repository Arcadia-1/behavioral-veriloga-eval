simulator lang=spectre
global 0

ahdl_include "slew_asymmetric_rise_fall.va"

Vvin (vin 0) vsource type=pwl wave=[ 0n 0.0 55n 0.0 ]
Vmode (mode 0) vsource type=pwl wave=[ 0n 0.0 29n 0.0 30n 0.9 55n 0.9 ]
Vrst (rst 0) vsource type=pwl wave=[ 0n 0.9 8n 0.9 8.1n 0 55n 0 ]
Vclk (clk 0) vsource type=pwl wave=[ 0n 0 4.9n 0 5.0n 0.9 5.5n 0.9 5.6n 0 19.9n 0 20.0n 0.9 20.5n 0.9 20.6n 0 39.9n 0 40.0n 0.9 40.5n 0.9 40.6n 0 55n 0 ]

XDUT (vin clk mode rst out metric) slew_asymmetric_rise_fall

tran tran stop=55n
save vin clk mode rst out metric
