    V(db2) <+ (0.42 * (transition(bb2 * vdd, tdc, tde, tde)));
    V(db3) <+ (0.42 * (transition(bb3 * vdd, tdc, tde, tde)));
    V(db4) <+ (0.42 * (transition(bb4 * vdd, tdc, tde, tde)));
    V(db5) <+ (0.42 * (transition(bb5 * vdd, tdc, tde, tde)));
    V(db6) <+ (0.42 * (transition(bb6 * vdd, tdc, tde, tde)));
    V(co) <+ (0.42 * (transition(cout * vdd, tdc, tde, tde)));
    V(cob) <+ (0.42 * (transition(coutb * vdd, tdc, tde, tde)));
