connectrules connectrules_electrical_map_rules;
    connect electrical electrical connectrules_electrical_map_bridge;
endconnectrules

connectmodule connectrules_electrical_map_bridge(input electrical a, output electrical y);
    analog begin
        V(y) <+ ((V(a)) > 0.55 ? 0.9 : 0.0);
    end
endconnectmodule

module connectrules_electrical_map();
endmodule
