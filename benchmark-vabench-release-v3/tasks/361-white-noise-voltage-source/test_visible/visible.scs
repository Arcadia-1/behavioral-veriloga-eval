simulator lang=spectre
global 0

ahdl_include "white_noise_voltage_source.va"

Vctrl (ctrl 0) vsource type=pwl wave=[0 0.2 99n 0.2 100n 0.6 199n 0.6 200n 0.3 299n 0.3 300n 0.8 420n 0.8]
Vclk (clk 0) vsource type=pwl wave=[0 0.0 49n 0.0 50n 1.0 79n 1.0 80n 0.0 149n 0.0 150n 1.0 179n 1.0 180n 0.0 249n 0.0 250n 1.0 279n 1.0 280n 0.0 349n 0.0 350n 1.0 420n 1.0]

XDUT (ctrl clk out metric) white_noise_voltage_source

tran tran stop=420n
save ctrl clk out metric
