`include "constants.vams"
`include "disciplines.vams"

module rf_source_info_registration (
    input  electrical in,
    output electrical out
);
parameter string fundname = "rf";
parameter real freq = 1G;
analog begin
    $cds_set_rf_source_info(fundname, freq);
    V(out) <+ V(in);
end
endmodule
