simulator lang=spectre
global 0

ahdl_include "table_model_temperature_profile.va"

Vvin (vin 0) vsource type=pwl wave=[0 -40.0 99n -40.0 100n 25.0 199n 25.0 200n 85.0 299n 85.0 300n 125.0 420n 125.0]
Vclk (clk 0) vsource type=pwl wave=[0 0.0 49n 0.0 50n 1.0 79n 1.0 80n 0.0 149n 0.0 150n 1.0 179n 1.0 180n 0.0 249n 0.0 250n 1.0 279n 1.0 280n 0.0 349n 0.0 350n 1.0 420n 1.0]
Vmode (mode 0) vsource dc=0.0
Vrst (rst 0) vsource dc=0.0

XDUT (vin clk mode rst out metric) table_model_temperature_profile

tran tran stop=420n
save vin clk mode rst out metric
