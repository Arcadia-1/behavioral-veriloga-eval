simulator lang=spectre
global 0

ahdl_include "task_dual_output_update.va"

Vvin (vin 0) vsource type=pwl wave=[0 0.2 99n 0.2 100n 0.7 199n 0.7 200n 0.6 299n 0.6 300n -0.1 420n -0.1]
Vclk (clk 0) vsource type=pwl wave=[0 0.0 49n 0.0 50n 1.0 79n 1.0 80n 0.0 149n 0.0 150n 1.0 179n 1.0 180n 0.0 249n 0.0 250n 1.0 279n 1.0 280n 0.0 349n 0.0 350n 1.0 420n 1.0]
Vmode (mode 0) vsource type=pwl wave=[0 0.1 99n 0.1 100n -0.2 199n -0.2 200n 0.5 299n 0.5 300n 0.2 420n 0.2]
Vrst (rst 0) vsource dc=0.0

XDUT (vin clk mode rst out metric) task_dual_output_update

tran tran stop=420n
save vin clk mode rst out metric
