`include "constants.vams"
`include "disciplines.vams"

module cds_violation_threshold_assert (input electrical in, output electrical out);
real out_v;
analog begin
    if (V(in) > 1.0) begin
        $cds_violation("va_threshold", "threshold_exceeded", V(in));
        out_v = 1.0;
    end else begin
        out_v = V(in);
    end
    V(out) <+ out_v;
end
endmodule
