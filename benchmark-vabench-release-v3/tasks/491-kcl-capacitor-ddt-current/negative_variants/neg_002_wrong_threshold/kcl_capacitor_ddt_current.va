`include "constants.vams"
`include "disciplines.vams"

module kcl_capacitor_ddt_current (
    inout electrical p,
    inout electrical n,
    output electrical imon
);
parameter real c = 1p;
parameter real tr = 200p;
analog begin
    I(p, n) <+ 2.0 * c * ddt(V(p, n));
    V(imon) <+ transition(I(p, n), 0.0, tr, tr);
end
endmodule
