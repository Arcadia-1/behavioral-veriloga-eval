simulator lang=spectre
global 0

ahdl_include "idtmod_wrapped_ramp_source.va"

Vvin (vin 0) vsource dc=0.5 type=dc
Vmode (mode 0) vsource dc=0.6 type=dc
Vrst (rst 0) vsource type=pwl wave=[0 0.9 95n 0.9 100n 0.0 900n 0.0]
Vclk (clk 0) vsource dc=0.0 type=dc

XDUT (vin clk mode rst out metric) idtmod_wrapped_ramp_source

tran tran stop=900n
save vin clk mode rst out metric
