simulator lang=spectre
global 0

ahdl_include "hierarchy_nested_parameter_chain.va"

Vvin (vin 0) vsource type=pwl wave=[0 0.50 119n 0.50 120n 1.00 260n 1.00]
Vclk (clk 0) vsource dc=0.0
Vmode (mode 0) vsource dc=0.0
Vrst (rst 0) vsource type=pwl wave=[0 0.0 149n 0.0 150n 1.0 240n 1.0 241n 0.0 260n 0.0]

XDUT (vin clk mode rst out metric) hierarchy_nested_parameter_chain

tran tran stop=260n
save vin clk mode rst out metric
