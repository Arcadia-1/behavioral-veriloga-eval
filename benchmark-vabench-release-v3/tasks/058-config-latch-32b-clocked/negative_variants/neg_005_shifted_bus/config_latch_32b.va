        V(q21) <+ transition((V(en) > vth && V(d22) > vth) ? vdd : 0.0, 0, tr, tr);
        V(q22) <+ transition((V(en) > vth && V(d23) > vth) ? vdd : 0.0, 0, tr, tr);
        V(q23) <+ transition((V(en) > vth && V(d24) > vth) ? vdd : 0.0, 0, tr, tr);
        V(q24) <+ transition((V(en) > vth && V(d25) > vth) ? vdd : 0.0, 0, tr, tr);
        V(q25) <+ transition((V(en) > vth && V(d26) > vth) ? vdd : 0.0, 0, tr, tr);
