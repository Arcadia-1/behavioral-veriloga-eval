        V(q29) <+ transition((V(en) > vth && V(d30) > vth) ? vdd : 0.0, 0, tr, tr);
        V(q30) <+ transition((V(en) > vth && V(d31) > vth) ? vdd : 0.0, 0, tr, tr);
        V(q31) <+ transition((V(en) > vth && V(d0) > vth) ? vdd : 0.0, 0, tr, tr);
    end
endmodule
