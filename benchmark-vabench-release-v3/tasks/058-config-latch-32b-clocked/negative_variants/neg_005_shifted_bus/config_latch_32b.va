        V(q15) <+ transition((V(en) > vth && V(d16) > vth) ? vdd : 0.0, 0, tr, tr);
        V(q16) <+ transition((V(en) > vth && V(d17) > vth) ? vdd : 0.0, 0, tr, tr);
        V(q17) <+ transition((V(en) > vth && V(d18) > vth) ? vdd : 0.0, 0, tr, tr);
