simulator lang=spectre
global 0

ahdl_include "always_negedge_sampler.vams"

Vclk (clk 0) vsource type=pwl wave=[0 1.0 49n 1.0 50n 0.0 99n 0.0 100n 1.0 149n 1.0 150n 0.0 199n 0.0 200n 1.0 249n 1.0 250n 0.0 299n 0.0 300n 1.0 349n 1.0 350n 0.0 399n 0.0 400n 1.0 449n 1.0 450n 0.0 500n 0.0]
Vrst (rst 0) vsource type=pwl wave=[0 1.0 74n 1.0 75n 0.0 500n 0.0]
Vd (d 0) vsource type=pwl wave=[0 1.0 199n 1.0 200n 0.0 399n 0.0 400n 1.0 500n 1.0]
Ven (en 0) vsource type=pwl wave=[0 1.0 199n 1.0 200n 0.0 299n 0.0 300n 1.0 500n 1.0]

XDUT (clk rst d en q) always_negedge_sampler

tran tran stop=500n
save clk rst d en q
