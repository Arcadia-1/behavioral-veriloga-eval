simulator lang=spectre
global 0
ahdl_include "dac4bit_small_swing.va"
Vd0 (vd0 0) vsource type=pwl wave=[0 0 1.0n 0 1.05n 1 2.0n 1 2.05n 0 3.0n 0 3.05n 1 4.0n 1]
Vd1 (vd1 0) vsource type=pwl wave=[0 0 2.0n 0 2.05n 1 4.0n 1]
Vd2 (vd2 0) vsource type=pwl wave=[0 0 1.0n 0 1.05n 1 2.0n 1 2.05n 0 3.0n 0 3.05n 1 4.0n 1]
Vd3 (vd3 0) vsource type=pwl wave=[0 0 2.0n 0 2.05n 1 4.0n 1]
XDUT (vd3 vd2 vd1 vd0 vout) dac4bit_small_swing
tran tran stop=3.8n maxstep=5p
save vd3 vd2 vd1 vd0 vout
