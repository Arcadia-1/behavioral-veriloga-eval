nature V3Voltage;
    units = "V";
    access = V;
    abstol = 1u;
endnature

discipline v3electrical;
    potential V3Voltage;
enddiscipline

module custom_nature_discipline_voltage(a, y);
    input a;
    output y;
    v3electrical a, y;
    analog begin
        V(y) <+ (V(rst) > 0.45 ? 0.25 : (V(a)));
    end
endmodule
