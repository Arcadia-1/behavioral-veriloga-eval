simulator lang=spectre
global 0
ahdl_include "reset_sync_active_low.va"
Vclk (clk 0) vsource type=pulse val0=0 val1=0.9 period=10n delay=1n rise=50p fall=50p width=5n
Vrst_n (rst_n 0) vsource type=pwl wave=[0 0 22n 0 22.1n 0.9 85n 0.9 85.1n 0 105n 0 105.1n 0.9 150n 0.9]
XDUT (clk rst_n sync_rst_n) reset_sync_active_low
tran tran stop=150n maxstep=100p
save clk rst_n sync_rst_n
