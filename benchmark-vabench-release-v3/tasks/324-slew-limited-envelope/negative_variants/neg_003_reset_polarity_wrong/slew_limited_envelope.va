`include "constants.vams"
`include "disciplines.vams"

module slew_limited_envelope (
    input  electrical vin,
    input  electrical clk,
    input  electrical mode,
    input  electrical rst,
    output electrical out,
    output electrical metric
);
parameter real vth = 0.45;
parameter real rise_rate = 8.0e8;
parameter real fall_rate = 3.0e8;
real out_v;
real metric_v;
real env_v;
analog begin
    @(initial_step) begin out_v = 0.0; metric_v = 0.0; env_v = 0.0; end
    @(cross(V(clk) - vth, +1) or cross(V(rst) - vth, +1)) begin
        if (V(rst) < vth) begin
            env_v = 0.0;
            out_v = 0.0;
            metric_v = 0.0;
        end else begin
            if (V(mode) > vth) begin
                env_v = V(vin);
            end else if (V(vin) > env_v) begin
                env_v = V(vin);
            end
            if (env_v < 0.0) env_v = 0.0;
            if (env_v > 0.8) env_v = 0.8;
            out_v = env_v;
            metric_v = env_v / 0.8;
        end
    end
    V(out) <+ slew(out_v, rise_rate, -fall_rate);
    V(metric) <+ slew(metric_v, rise_rate, -fall_rate);
end
endmodule
