simulator lang=spectre
global 0

ahdl_include "gain_trim_controller.va"

Vclk (clk 0) vsource type=pulse val0=0 val1=0.9 delay=5n rise=100p fall=100p width=4n period=10n
Vrst (rst 0) vsource type=pwl wave=[0 0.9 12n 0.9 12.2n 0 120n 0]
Vmeas (meas 0) vsource type=pwl wave=[0 0.35 45n 0.35 45.2n 0.46 65n 0.46 65.2n 0.56 120n 0.56]
Vtarget (target 0) vsource dc=0.45

XDUT (clk rst meas target gain_ctrl) gain_trim_controller

tran tran stop=120n maxstep=500p
save clk rst meas target gain_ctrl
