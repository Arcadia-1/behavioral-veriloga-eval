`include "constants.vams"
`include "disciplines.vams"

module mixed_wreal_to_electrical_buffer(vin, clk, en, sel, a, b, vout);
    input vin, clk, en, sel, a, b;
    output vout;
    electrical vin, vout;
    logic clk, en, sel;
    wreal a, b, level;
    parameter real tr = 200p;

    assign level = a;

    analog begin
        V(vout) <+ transition(sel ? level : 0.0, 0.0, tr, tr);
    end
endmodule
