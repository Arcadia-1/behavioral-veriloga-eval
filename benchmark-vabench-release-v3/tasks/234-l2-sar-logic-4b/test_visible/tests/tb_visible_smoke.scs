simulator lang=spectre
global 0
ahdl_include "l2_sar_logic_4b.va"
Vclks (clks 0) vsource type=pulse val0=0 val1=1.1 delay=0.05n period=20n width=0.25n rise=20p fall=20p
Vclkc (clkc 0) vsource type=pulse val0=0 val1=1.1 delay=0.8n period=20n width=0.25n rise=20p fall=20p
Vp (dcmpp 0) vsource type=pwl wave=[0 0 1.25n 0 1.27n 1.1 1.55n 1.1 1.57n 0 2.65n 0 2.67n 1.1 2.95n 1.1 2.97n 0 5n 0]
Vn (dcmpn 0) vsource type=pwl wave=[0 0 1.95n 0 1.97n 1.1 2.25n 1.1 2.27n 0 3.35n 0 3.37n 1.1 3.65n 1.1 3.67n 0 5n 0]
XDUT (clkc clks dcmpp dcmpn cmpck do0 do1 do2 do3 dctrlp1 dctrlp2 dctrlp3 dctrln1 dctrln2 dctrln3) l2_sar_logic_4b
tran tran stop=4.8n maxstep=10p
save clkc clks dcmpp dcmpn cmpck do0 do1 do2 do3 dctrlp1 dctrlp2 dctrlp3 dctrln1 dctrln2 dctrln3
