simulator lang=spectre
global 0
ahdl_include "dac4bit_bipolar_252m.va"
Vd0 (d0 0) vsource type=pwl wave=[0 0 1n 0 1.05n 0.9 2n 0.9 2.05n 0 3n 0 3.05n 0.9 4n 0.9]
Vd1 (d1 0) vsource type=pwl wave=[0 0 2n 0 2.05n 0.9 4n 0.9]
Vd2 (d2 0) vsource type=pwl wave=[0 0 3n 0 3.05n 0.9 4n 0.9]
Vd3 (d3 0) vsource type=pwl wave=[0 0 4n 0]
XDUT (d3 d2 d1 d0 vout) dac4bit_bipolar_252m
tran tran stop=3.8n maxstep=5p
save d3 d2 d1 d0 vout
