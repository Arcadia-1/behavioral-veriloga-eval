simulator lang=spectre
global 0

ahdl_include "escaped_identifier_state.va"

Vvin (vin 0) vsource type=pwl wave=[0 0.3 100n 0.3 101n 0.4 200n 0.4 201n 0.6 300n 0.6 301n 0.5 420n 0.5]
Vclk (clk 0) vsource type=pwl wave=[0 0.0 49n 0.0 50n 1.0 79n 1.0 80n 0.0 149n 0.0 150n 1.0 179n 1.0 180n 0.0 249n 0.0 250n 1.0 279n 1.0 280n 0.0 349n 0.0 350n 1.0 420n 1.0]
Vmode (mode 0) vsource type=pwl wave=[0 0.0 100n 0.0 101n 1.0 200n 1.0 201n 0.0 300n 0.0 301n 1.0 420n 1.0]
Vrst (rst 0) vsource dc=0.0

XDUT (vin clk mode rst out metric) escaped_identifier_state

tran tran stop=420n
save vin clk mode rst out metric
