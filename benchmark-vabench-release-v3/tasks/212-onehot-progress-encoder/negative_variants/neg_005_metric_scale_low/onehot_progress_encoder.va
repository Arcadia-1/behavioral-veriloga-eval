`include "disciplines.vams"

module onehot_progress_encoder(ck, d0, d1, d2, d3, d4, d5, d6, d7, d8, d9, d10, d11, d12, d13, d14, d15, sum);
input ck;
output d0, d1, d2, d3, d4, d5, d6, d7, d8, d9, d10, d11, d12, d13, d14, d15, sum;
electrical ck, d0, d1, d2, d3, d4, d5, d6, d7, d8, d9, d10, d11, d12, d13, d14, d15, sum;

integer index;
integer d[0:15];
genvar i;

analog begin
    @(initial_step) begin
        index = 0;
        for (i = 0; i < 16; i = i + 1)
