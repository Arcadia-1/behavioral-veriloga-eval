            d[index] = 1;
            index = index + 1;
        end
    end

    V(sum) <+ transition(index, 0, 20p, 20p);
    V(d0) <+ (0.42 * (transition(d[0], 0, 20p, 20p)));
    V(d1) <+ (0.42 * (transition(d[1], 0, 20p, 20p)));
    V(d2) <+ (0.42 * (transition(d[2], 0, 20p, 20p)));
