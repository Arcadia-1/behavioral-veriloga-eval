    V(d11) <+ (0.42 * (transition(d[11], 0, 20p, 20p)));
    V(d12) <+ (0.42 * (transition(d[12], 0, 20p, 20p)));
    V(d13) <+ (0.42 * (transition(d[13], 0, 20p, 20p)));
    V(d14) <+ (0.42 * (transition(d[14], 0, 20p, 20p)));
