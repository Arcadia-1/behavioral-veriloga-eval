simulator lang=spectre
global 0

ahdl_include "cdac_cal.va"

Vvdd (VDD 0) vsource dc=0.9
Vvss (VSS 0) vsource dc=0
Vclk (CLK 0) vsource type=pulse val0=0 val1=0.9 delay=1n rise=20p fall=20p width=1n period=4n

Vd9 (D9 0) vsource type=pwl wave=[0 0 5.9n 0 6n 0.9 13.9n 0.9 14n 0 21.9n 0 22n 0.9 28n 0.9]
Vd8 (D8 0) vsource type=pwl wave=[0 0 28n 0]
Vd7 (D7 0) vsource type=pwl wave=[0 0 13.9n 0 14n 0.9 21.9n 0.9 22n 0 28n 0]
Vd6 (D6 0) vsource type=pwl wave=[0 0 28n 0]
Vd5 (D5 0) vsource type=pwl wave=[0 0 21.9n 0 22n 0.9 28n 0.9]
Vd4 (D4 0) vsource type=pwl wave=[0 0 28n 0]
Vd3 (D3 0) vsource type=pwl wave=[0 0 28n 0]
Vd2 (D2 0) vsource type=pwl wave=[0 0 28n 0]
Vd1 (D1 0) vsource type=pwl wave=[0 0 28n 0]
Vd0 (D0 0) vsource type=pwl wave=[0 0 28n 0]
Vcal0 (CAL0 0) vsource type=pwl wave=[0 0 13.9n 0 14n 0.9 21.9n 0.9 22n 0 28n 0]
Vcal1 (CAL1 0) vsource type=pwl wave=[0 0 21.9n 0 22n 0.9 28n 0.9]

XDUT (VDD VSS CLK D9 D8 D7 D6 D5 D4 D3 D2 D1 D0 CAL0 CAL1 VDAC_P VDAC_N) cdac_cal

tran tran stop=28n maxstep=20p
save CLK D9 D8 D7 D6 D5 D4 D3 D2 D1 D0 CAL0 CAL1 VDAC_P VDAC_N
