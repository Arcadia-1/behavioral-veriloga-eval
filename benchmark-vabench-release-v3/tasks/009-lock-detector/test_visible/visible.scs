simulator lang=spectre
global 0

ahdl_include "lock_detector.va"

Vrst (rst_n 0) vsource type=pwl wave=[ \
  0 0 \
  6n 0 \
  6.2n 0.9 \
  90n 0.9 \
]

Vref (ref_clk 0) vsource type=pwl wave=[ \
  0 0 \
  19.9n 0 20.0n 0.9 23.0n 0.9 23.2n 0 \
  39.9n 0 40.0n 0.9 43.0n 0.9 43.2n 0 \
  59.9n 0 60.0n 0.9 63.0n 0.9 63.2n 0 \
  79.9n 0 80.0n 0.9 83.0n 0.9 83.2n 0 \
  90n 0 \
]

Vfb (fb_clk 0) vsource type=pwl wave=[ \
  0 0 \
  19.0n 0 19.1n 0.9 22.0n 0.9 22.2n 0 \
  39.0n 0 39.1n 0.9 42.0n 0.9 42.2n 0 \
  59.0n 0 59.1n 0.9 62.0n 0.9 62.2n 0 \
  74.0n 0 74.1n 0.9 77.0n 0.9 77.2n 0 \
  90n 0 \
]

XDUT (ref_clk fb_clk rst_n lock) lock_detector

tran tran stop=90n maxstep=100p
save ref_clk fb_clk rst_n lock
