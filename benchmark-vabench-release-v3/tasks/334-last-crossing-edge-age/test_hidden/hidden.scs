simulator lang=spectre
global 0

ahdl_include "last_crossing_edge_age.va"

Vvin (vin 0) vsource type=pwl wave=[0 0.1 99n 0.1 100n 0.8 180n 0.8 181n 0.1 499n 0.1 500n 0.8 580n 0.8 581n 0.1 800n 0.1]
Vmode (mode 0) vsource dc=0.0 type=dc
Vrst (rst 0) vsource type=pwl wave=[0 0.0 699n 0.0 700n 0.9 720n 0.9 721n 0.0 800n 0.0]
Vclk (clk 0) vsource dc=0.0 type=dc

XDUT (vin clk mode rst out metric) last_crossing_edge_age

tran tran stop=800n
save vin clk mode rst out metric
