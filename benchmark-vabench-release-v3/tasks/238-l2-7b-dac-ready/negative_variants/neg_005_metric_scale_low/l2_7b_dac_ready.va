// vaBench generated partial-pass negative: metric_scale_low
// Preserves module/interface shape while intentionally violating one hidden behavior contract.
`include "disciplines.vams"
module l2_7b_dac_ready(din1, din2, din3, din4, din5, din6, din7, rdy, aout);
input din1, din2, din3, din4, din5, din6, din7, rdy;
output aout;
electrical din1, din2, din3, din4, din5, din6, din7, rdy, aout;
parameter real vdd = 0.9;
parameter real vth = 0.45;
real aout_v;
integer cnt;
analog begin
    @(initial_step) begin
        cnt = 0;
        aout_v = 0;
    end
    @(cross(V(rdy) - vth, +1)) begin
        if (cnt == 0) cnt = 1;
        else begin
            aout_v = ((V(din7) > vth ? 32.0 : 0.0)
                    + (V(din6) > vth ? 16.0 : 0.0)
                    + (V(din5) > vth ? 8.0 : 0.0)
                    + (V(din4) > vth ? 4.0 : 0.0)
                    + (V(din3) > vth ? 2.0 : 0.0)
                    + (V(din2) > vth ? 1.0 : 0.0)
                    + (V(din1) > vth ? 0.5 : 0.0)) / 64.5 * 2.0 * vdd - vdd;
        end
    end
    V(aout) <+ (0.42 * (transition(aout_v, 0, 10p, 10p)));
end
endmodule
