simulator lang=spectre
global 0
ahdl_include "offset_halving_search.va"
Vclk (clk 0) vsource type=pulse val0=0 val1=0.9 delay=0.2n period=1n width=0.5n rise=20p fall=20p
Vcmp (dcmpp 0) vsource type=pwl wave=[0 0.9 1.2n 0.9 1.25n 0 2.2n 0 2.25n 0 3.2n 0 3.25n 0.9 4.5n 0.9]
XDUT (clk dcmpp vinp vinn) offset_halving_search
tran tran stop=4.2n maxstep=10p
save clk dcmpp vinp vinn
