simulator lang=spectre
global 0

ahdl_include "always_posedged_dff.vams"

Vclk (clk 0) vsource type=pwl wave=[0 0.0 49n 0.0 50n 1.0 99n 1.0 100n 0.0 149n 0.0 150n 1.0 199n 1.0 200n 0.0 249n 0.0 250n 1.0 299n 1.0 300n 0.0 349n 0.0 350n 1.0 399n 1.0 400n 0.0 449n 0.0 450n 1.0 500n 1.0]
Vrst (rst 0) vsource type=pwl wave=[0 1.0 74n 1.0 75n 0.0 500n 0.0]
Vd (d 0) vsource type=pwl wave=[0 1.0 199n 1.0 200n 0.0 399n 0.0 400n 1.0 500n 1.0]
Ven (en 0) vsource type=pwl wave=[0 1.0 199n 1.0 200n 0.0 299n 0.0 300n 1.0 500n 1.0]

XDUT (clk rst d en q) always_posedged_dff

tran tran stop=500n
save clk rst d en q
