simulator lang=spectre
global 0

ahdl_include "half_adder_logic.va"

Vin1 (vin1 0) vsource type=pwl wave=[0 0.9 8n 0.9 8.1n 0 18n 0 18.1n 0.9 28n 0.9 28.1n 0 45n 0]
Vin2 (vin2 0) vsource type=pwl wave=[0 0 8n 0 8.1n 0.9 18n 0.9 18.1n 0.9 28n 0.9 28.1n 0 45n 0]

XDUT (vin1 vin2 vout_sum vout_carry) half_adder_logic

tran tran stop=40n maxstep=25p
save vin1 vin2 vout_sum vout_carry
