simulator lang=spectre
global 0
ahdl_include "dff_set_reset.va"
Vdd (vdd 0) vsource dc=0.9
Vgnd (gnd 0) vsource dc=0
Vclk (clk 0) vsource type=pulse val0=0 val1=0.9 delay=0.4n period=1n width=0.25n rise=20p fall=20p
Vd (d 0) vsource type=pwl wave=[0 0 0.9n 0 0.95n 0.9 1.9n 0.9 1.95n 0 3.8n 0]
Vrstb (rstb 0) vsource type=pwl wave=[0 0.9 2.1n 0.9 2.12n 0 2.45n 0 2.47n 0.9 3.8n 0.9]
Vsetb (setb 0) vsource type=pwl wave=[0 0.9 2.8n 0.9 2.82n 0 3.15n 0 3.17n 0.9 3.8n 0.9]
XDUT (setb rstb clk vdd gnd d q qb) dff_set_reset
tran tran stop=3.6n maxstep=5p
save setb rstb clk vdd gnd d q qb
