simulator lang=spectre
global 0

ahdl_include "case_resettable_state_decoder.va"

Vvin (vin 0) vsource type=pwl wave=[ 0n 0.5 45n 0.5 ]
Vmode (mode 0) vsource type=pwl wave=[ 0n 0.9 29n 0.9 30n 0.0 45n 0.0 ]
Vrst (rst 0) vsource type=pwl wave=[ 0n 0 45n 0 ]
Vclk (clk 0) vsource type=pwl wave=[ 0n 0 4.9n 0 5.0n 0.9 5.5n 0.9 5.6n 0 14.9n 0 15.0n 0.9 15.5n 0.9 15.6n 0 24.9n 0 25.0n 0.9 25.5n 0.9 25.6n 0 34.9n 0 35.0n 0.9 35.5n 0.9 35.6n 0 45n 0 ]

XDUT (vin clk mode rst out metric) case_resettable_state_decoder

tran tran stop=45n
save vin clk mode rst out metric
