`include "disciplines.vams"

module comp_os_detect (CLK, DCMPP, VINP, VINN);

input CLK, DCMPP;
output VINP, VINN;
electrical CLK, DCMPP, VINP, VINN;

parameter real vdd = 0.9;

real vin = 0;
real step = 50m;
integer sign = 1;

analog begin
    @(cross(V(CLK) - 0.5 * vdd, -1)) begin
        sign = V(DCMPP) > 0.5 * vdd;
        vin = vin - (2 * sign - 1) * step;
        step = step / 2.0;
    end

    V(VINP) <+ (0.5 * vdd + 0.5 * vin);
    V(VINN) <+ (0.5 * vdd - 0.5 * vin);
end

endmodule
